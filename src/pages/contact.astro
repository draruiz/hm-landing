<!-- ═══════════════════════════════════════════════════════════ -->
<!-- GSAP ANIMATIONS + FORM LOGIC                               -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  // ─── data-animate reveals ───
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    },
    { threshold: 0.15 },
  );
  document
    .querySelectorAll("[data-animate]")
    .forEach((el) => observer.observe(el));

  if (!prefersReduced) {
    // ─── Hero entrance timeline ───
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.fromTo(
      ".hero-label",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      0.2,
    );

    tl.to(
      ".hero-word-inner",
      { y: 0, opacity: 1, duration: 1, stagger: 0.06, ease: "power4.out" },
      0.4,
    );

    tl.to(
      ".hero-divider",
      { width: "60px", duration: 0.8, ease: "power2.inOut" },
      1.0,
    );

    tl.fromTo(
      ".hero-desc",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      1.1,
    );

    tl.fromTo(
      ".hero-cta",
      { y: 15, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7 },
      1.3,
    );

    tl.fromTo(
      ".hero-image-wrap",
      { scale: 1.05, opacity: 0 },
      { scale: 1, opacity: 1, duration: 1.2, ease: "power2.out" },
      0.5,
    );

    tl.fromTo(
      ".hero-frame",
      { opacity: 0, scale: 1.02 },
      { opacity: 1, scale: 1, duration: 1, ease: "power2.out" },
      0.7,
    );

    tl.fromTo(
      ".hero-image-mobile",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.8 },
      1.0,
    );

    tl.to(".hero-image", { scale: 1, duration: 8, ease: "power1.out" }, 0);

    // ─── Contact channels stagger ───
    ScrollTrigger.batch(".contact-channel", {
      onEnter: (elements) => {
        gsap.from(elements, {
          y: 20,
          opacity: 0,
          stagger: 0.08,
          duration: 0.6,
          ease: "power2.out",
        });
      },
      start: "top 90%",
      once: true,
    });

    // ─── Form fields stagger ───
    ScrollTrigger.create({
      trigger: ".form-container",
      start: "top 80%",
      once: true,
      onEnter: () => {
        gsap.from(".form-field", {
          y: 20,
          opacity: 0,
          stagger: 0.08,
          duration: 0.6,
          ease: "power2.out",
          delay: 0.2,
        });
      },
    });

    // ─── Input focus underline micro-interactions ───
    document
      .querySelectorAll<
        HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
      >("#contact-form input, #contact-form textarea, #contact-form select")
      .forEach((el) => {
        const parent = el.closest(".form-field");
        if (!parent) return;
        el.addEventListener("focus", () => {
          gsap.to(parent, {
            borderColor: "rgba(200,164,92,0.4)",
            duration: 0.3,
            ease: "power2.out",
          });
        });
        el.addEventListener("blur", () => {
          gsap.to(parent, {
            borderColor: "rgba(26,26,26,0.1)",
            duration: 0.3,
            ease: "power2.out",
          });
        });
      });
  } else {
    // Ensure hero elements are visible when motion is reduced
    document
      .querySelectorAll<HTMLElement>(
        ".hero-word-inner, .hero-label, .hero-divider, .hero-desc, .hero-cta, .hero-image-wrap, .hero-image-mobile, .hero-frame",
      )
      .forEach((el) => {
        el.style.opacity = "1";
        el.style.transform = "none";
      });
    const divider = document.querySelector<HTMLElement>(".hero-divider");
    if (divider) divider.style.width = "60px";
  }

  // ═══════════════════════════════════════════════════════════
  // FORM SUBMISSION LOGIC
  // ═══════════════════════════════════════════════════════════
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text")!;
  const btnArrow = document.getElementById("btn-arrow")!;
  const btnSpinner = document.getElementById("btn-spinner")!;
  const successMessage = document.getElementById("success-message")!;
  const errorMessage = document.getElementById("error-message")!;
  const hipaaError = document.getElementById("hipaa-error")!;
  const hipaaCheckbox = document.getElementById(
    "hipaaConsent",
  ) as HTMLInputElement;

  const API_BASE = import.meta.env.PUBLIC_HM_CMS_URL;

  hipaaCheckbox.addEventListener("change", () => {
    if (hipaaCheckbox.checked) {
      hipaaError.classList.add("hidden");
    }
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!hipaaCheckbox.checked) {
      hipaaError.classList.remove("hidden");
      hipaaCheckbox.focus();
      if (!prefersReduced) {
        gsap.fromTo(
          hipaaError,
          { x: -6 },
          { x: 0, duration: 0.4, ease: "elastic.out(1, 0.3)" },
        );
      }
      return;
    }

    const formData = new FormData(form);
    const payload = {
      name: (formData.get("name") as string).trim(),
      email: (formData.get("email") as string).trim(),
      phone: (formData.get("phone") as string).trim() || "",
      preferredDate: (formData.get("preferredDate") as string) || "",
      time: (formData.get("time") as string) || "",
      comment: (formData.get("comment") as string).trim() || "",
      hipaaConsent: true,
    };

    if (!payload.name || !payload.email) {
      return;
    }

    submitBtn.disabled = true;
    btnText.textContent = "Sending...";
    btnArrow.classList.add("hidden");
    btnSpinner.classList.remove("hidden");
    errorMessage.classList.add("hidden");

    try {
      const response = await fetch(`${API_BASE}/forms/contact`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`Server responded with ${response.status}`);
      }

      if (!prefersReduced) {
        gsap.to(form, {
          opacity: 0,
          y: -20,
          duration: 0.4,
          ease: "power2.in",
          onComplete: () => {
            form.classList.add("hidden");
            successMessage.classList.remove("hidden");
            gsap.from(successMessage, {
              opacity: 0,
              y: 20,
              duration: 0.6,
              ease: "power3.out",
            });
          },
        });
      } else {
        form.classList.add("hidden");
        successMessage.classList.remove("hidden");
      }
    } catch {
      errorMessage.classList.remove("hidden");
      if (!prefersReduced) {
        gsap.from(errorMessage, {
          opacity: 0,
          y: 10,
          duration: 0.4,
          ease: "power2.out",
        });
      }

      submitBtn.disabled = false;
      btnText.textContent = "Send Message";
      btnArrow.classList.remove("hidden");
      btnSpinner.classList.add("hidden");
    }
  });
</script>

