---
import Layout from "../layouts/Layout.astro";
import { breadcrumbSchema, localBusinessSchema } from "../utils/seo";

const siteUrl = "https://healthymindspecialists.com";
const siteName = "Healthy Mind Specialists";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Contact", url: `${siteUrl}/contact` },
  ]),
  localBusinessSchema({
    name: siteName,
    description:
      "Integrative psychological services providing individual, couples, family, and group therapy in a compassionate environment.",
    url: siteUrl,
    image: `${siteUrl}/og-default.png`,
    telephone: "813-609-2034",
    address: {
      street: "11906 Boyette Rd",
      city: "Riverview",
      region: "FL",
      country: "US",
      postal: "33569",
    },
  }),
];

const headingWords = "Get in touch.".split(" ");

const contactChannels = [
  {
    number: "01",
    label: "Phone",
    value: "(813) 609-2034",
    href: "tel:8136092034",
  },
  {
    number: "02",
    label: "Email",
    value: "info@healthymindspecialists.com",
    href: "mailto:info@healthymindspecialists.com",
  },
  {
    number: "03",
    label: "Location",
    value: "11906 Boyette Rd, Riverview, FL 33569",
    href: "https://maps.google.com/?q=11906+Boyette+Rd,+Riverview,+FL+33569",
  },
  { number: "04", label: "Hours", value: "Mon – Fri, 8 AM – 9 PM", href: null },
];
---

<Layout
  title='Contact Us — Reach Out for Mental Health Support'
  description='Get in touch with Healthy Mind Specialists in Tampa, FL. Schedule your appointment online, call us, or visit our Riverview office.'
  schema={schemas}
>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO — Split layout: Large type left + image right         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section
    id='contact-hero'
    class='relative min-h-[85vh] bg-brand-blue overflow-hidden'
    aria-label='Contact hero'
  >
    <!-- Background grid lines -->
    <div class='absolute inset-0 pointer-events-none z-0' aria-hidden='true'>
      <div
        class='absolute left-[25%] top-0 bottom-0 w-px bg-brand-white/[0.03]'
      >
      </div>
      <div
        class='absolute left-[50%] top-0 bottom-0 w-px bg-brand-white/[0.03]'
      >
      </div>
      <div
        class='absolute left-[75%] top-0 bottom-0 w-px bg-brand-white/[0.03]'
      >
      </div>
    </div>

    <div class='relative z-10 grid grid-cols-1 lg:grid-cols-2 min-h-[85vh]'>
      <!-- Left: Typography -->
      <div
        class='flex flex-col justify-center px-6 sm:px-10 md:px-16 lg:px-20 xl:px-28 py-32 lg:py-20'
      >
        <div class='hero-label opacity-0 mb-8 md:mb-12'>
          <span
            class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-gold'
          >
            Contact Us
          </span>
          <div class='w-12 h-px bg-brand-gold/40 mt-3'></div>
        </div>

        <h1 class='sr-only'>Get in touch with Healthy Mind Specialists</h1>

        <div class='hero-title-wrap mb-10 md:mb-14' aria-hidden='true'>
          <p
            class='text-[2rem] sm:text-4xl md:text-5xl lg:text-4xl xl:text-6xl font-display font-extrabold text-brand-white leading-[0.95] tracking-[-0.03em]'
          >
            {
              headingWords.map((word) => (
                <span class='hero-word inline-block overflow-hidden mr-[0.25em]'>
                  <span class='hero-word-inner inline-block translate-y-full opacity-0'>
                    {word}
                  </span>
                </span>
              ))
            }
          </p>
        </div>

        <div class='hero-divider w-0 h-px bg-brand-gold/50 mb-8 md:mb-10'></div>

        <p
          class='hero-desc opacity-0 text-brand-white/60 text-base md:text-lg font-light leading-relaxed max-w-md mb-10 md:mb-14'
        >
          We'd love to hear from you. Reach out to schedule an appointment, ask
          a question, or simply start a conversation about your care.
        </p>

        <div
          class='hero-cta flex flex-col sm:flex-row items-start gap-4 opacity-0'
        >
          <a
            href='#contact-form-section'
            class='group inline-flex items-center gap-3 px-8 py-4 text-sm font-semibold tracking-[0.15em] uppercase bg-brand-gold text-brand-blue transition-all duration-500 hover:bg-brand-gold-light'
          >
            <span>Send a Message</span>
            <svg
              class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
            </svg>
          </a>
          <a
            href='tel:8136092034'
            class='group inline-flex items-center gap-3 px-8 py-4 text-sm font-medium tracking-[0.15em] uppercase text-brand-white/70 border border-brand-white/15 transition-all duration-500 hover:text-brand-white hover:border-brand-white/40'
          >
            <span>Call Us</span>
            <svg
              class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Image accent -->
      <div
        class='hero-media relative hidden lg:flex items-center justify-center p-10 xl:p-16'
      >
        <div
          class='hero-frame absolute inset-10 xl:inset-16 border border-brand-gold/20 opacity-0'
        >
        </div>

        <div
          class='hero-image-wrap relative w-full aspect-[3/4] max-h-[75vh] overflow-hidden opacity-0'
        >
          <img
            src='/images/contact-hero.jpg'
            alt='Peaceful nature scene with warm sunlight for relaxation and mindfulness'
            width='800'
            height='1067'
            loading='eager'
            fetchpriority='high'
            class='hero-image absolute inset-0 w-full h-full object-cover scale-110'
          />
          <div class='absolute inset-0 bg-brand-blue/30 mix-blend-multiply'>
          </div>
          <div class='absolute bottom-6 left-6 right-6'>
            <span
              class='font-mono text-[10px] tracking-[0.2em] uppercase text-brand-white/50'
            >
              Tampa, FL — Riverview Office
            </span>
          </div>
        </div>

        <div
          class='absolute -right-2 top-1/2 -translate-y-1/2 -rotate-90 origin-center'
        >
          <span
            class='font-mono text-[10px] tracking-[0.4em] uppercase text-brand-white/20'
          >
            Healthy Mind Specialists
          </span>
        </div>
      </div>
    </div>

    <!-- Mobile image -->
    <div class='lg:hidden relative mx-6 mb-10 -mt-10'>
      <div
        class='hero-image-mobile relative aspect-video overflow-hidden opacity-0'
      >
        <img
          src='/images/contact-hero.jpg'
          alt='Peaceful nature scene with warm sunlight for relaxation and mindfulness'
          width='800'
          height='450'
          loading='eager'
          class='absolute inset-0 w-full h-full object-cover'
        />
        <div class='absolute inset-0 bg-brand-blue/30 mix-blend-multiply'></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CONTACT CHANNELS — Editorial numbered list                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section
    class='relative bg-brand-white py-24 md:py-36'
    aria-label='Contact information'
  >
    <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
      <div class='mb-16 md:mb-20'>
        <span
          class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted'
        >
          01 — Reach Us
        </span>
      </div>

      <div class='grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 mb-16'>
        <h2
          class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em]'
        >
          Multiple ways<br />to connect with us.
        </h2>
        <div class='flex flex-col justify-end'>
          <div class='w-10 h-px bg-brand-charcoal/15 mb-6'></div>
          <p class='text-black text-base md:text-lg leading-relaxed'>
            Whether by phone, email, or in person — our team is ready to answer
            your questions and help you get started on your path to wellness.
          </p>
        </div>
      </div>

      <!-- Channels list -->
      <div class='border-t border-brand-charcoal/10'>
        {
          contactChannels.map((channel) => {
            const Tag = channel.href ? "a" : "div";
            return (
              <Tag
                href={channel.href ?? undefined}
                target={channel.href?.startsWith("http") ? "_blank" : undefined}
                rel={
                  channel.href?.startsWith("http")
                    ? "noopener noreferrer"
                    : undefined
                }
                class:list={[
                  "contact-channel group flex flex-col md:flex-row md:items-center gap-4 md:gap-8 py-8 md:py-10 border-b border-brand-charcoal/10 -mx-6 px-6 sm:-mx-10 sm:px-10 md:-mx-16 md:px-16 lg:-mx-20 lg:px-20 transition-colors duration-300",
                  channel.href &&
                    "hover:bg-brand-charcoal/[0.02] cursor-pointer",
                ]}
              >
                <span class='font-mono text-[11px] tracking-[0.2em] text-brand-muted md:w-16 flex-shrink-0'>
                  {channel.number}
                </span>
                <span class='text-xs font-mono tracking-[0.15em] uppercase text-brand-gold md:w-24 flex-shrink-0'>
                  {channel.label}
                </span>
                <span
                  class:list={[
                    "text-xl md:text-2xl lg:text-3xl font-display font-bold text-black md:flex-1 transition-colors duration-300",
                    channel.href && "group-hover:text-brand-gold",
                  ]}
                >
                  {channel.value}
                </span>
                {channel.href && (
                  <svg
                    class='hidden md:block w-5 h-5 text-brand-charcoal/20 group-hover:text-brand-gold group-hover:translate-x-1 transition-all duration-300 flex-shrink-0'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke='currentColor'
                    stroke-width='1.5'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d='M17 8l4 4m0 0l-4 4m4-4H3'
                    />
                  </svg>
                )}
              </Tag>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- FORM SECTION — Brutalist editorial                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section
    id='contact-form-section'
    class='relative bg-brand-cream py-24 md:py-36'
    aria-labelledby='contact-form-heading'
  >
    <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
      <!-- Section header -->
      <div
        class='flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24'
      >
        <div>
          <span
            class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'
          >
            02 — Message
          </span>
          <h2
            id='contact-form-heading'
            class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em]'
          >
            Send us a<br />message.
          </h2>
        </div>
        <div class='max-w-sm'>
          <p class='text-black text-sm leading-relaxed'>
            Fill out the form below and our team will get back to you within 24
            hours. All information is kept confidential and secure.
          </p>
        </div>
      </div>

      <!-- Form grid -->
      <div class='grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20'>
        <!-- Form: 8 cols -->
        <div class='lg:col-span-8 form-container'>
          <form id='contact-form' class='space-y-0' novalidate>
            <!-- Name + Email row -->
            <div
              class='grid grid-cols-1 sm:grid-cols-2 border-t border-brand-charcoal/10'
            >
              <div
                class='form-field border-b border-brand-charcoal/10 sm:border-r py-6 sm:pr-6'
              >
                <label
                  for='name'
                  class='block font-mono text-[11px] tracking-[0.15em] uppercase text-brand-muted mb-3'
                >
                  Name <span class='text-brand-gold' aria-hidden='true'>*</span>
                </label>
                <input
                  type='text'
                  id='name'
                  name='name'
                  required
                  autocomplete='name'
                  placeholder='Your full name'
                  class='w-full bg-transparent text-brand-charcoal text-lg font-light placeholder:text-brand-charcoal/25 focus:outline-none border-none p-0'
                />
              </div>
              <div
                class='form-field border-b border-brand-charcoal/10 py-6 sm:pl-6'
              >
                <label
                  for='email'
                  class='block font-mono text-[11px] tracking-[0.15em] uppercase text-brand-muted mb-3'
                >
                  Email <span class='text-brand-gold' aria-hidden='true'>*</span
                  >
                </label>
                <input
                  type='email'
                  id='email'
                  name='email'
                  required
                  autocomplete='email'
                  placeholder='you@example.com'
                  class='w-full bg-transparent text-brand-charcoal text-lg font-light placeholder:text-brand-charcoal/25 focus:outline-none border-none p-0'
                />
              </div>
            </div>

            <!-- Phone row -->
            <div class='form-field border-b border-brand-charcoal/10 py-6'>
              <label
                for='phone'
                class='block font-mono text-[11px] tracking-[0.15em] uppercase text-brand-muted mb-3'
              >
                Phone
              </label>
              <input
                type='tel'
                id='phone'
                name='phone'
                autocomplete='tel'
                placeholder='(555) 000-0000'
                class='w-full bg-transparent text-brand-charcoal text-lg font-light placeholder:text-brand-charcoal/25 focus:outline-none border-none p-0'
              />
            </div>

            <!-- Date + Time row -->
            <div class='grid grid-cols-1 sm:grid-cols-2'>
              <div
                class='form-field border-b border-brand-charcoal/10 sm:border-r py-6 sm:pr-6'
              >
                <label
                  for='preferredDate'
                  class='block font-mono text-[11px] tracking-[0.15em] uppercase text-brand-muted mb-3'
                >
                  Preferred Date
                </label>
                <input
                  type='date'
                  id='preferredDate'
                  name='preferredDate'
                  class='w-full bg-transparent text-brand-charcoal text-lg font-light placeholder:text-brand-charcoal/25 focus:outline-none border-none p-0'
                />
              </div>
              <div
                class='form-field border-b border-brand-charcoal/10 py-6 sm:pl-6'
              >
                <label
                  for='time'
                  class='block font-mono text-[11px] tracking-[0.15em] uppercase text-brand-muted mb-3'
                >
                  Preferred Time
                </label>
                <select
                  id='time'
                  name='time'
                  class='w-full bg-transparent text-brand-charcoal text-lg font-light focus:outline-none border-none p-0 appearance-none cursor-pointer'
                >
                  <option value=''>Select a time</option>
                  <option value='8:00 AM'>8:00 AM</option>
                  <option value='9:00 AM'>9:00 AM</option>
                  <option value='10:00 AM'>10:00 AM</option>
                  <option value='11:00 AM'>11:00 AM</option>
                  <option value='12:00 PM'>12:00 PM</option>
                  <option value='1:00 PM'>1:00 PM</option>
                  <option value='2:00 PM'>2:00 PM</option>
                  <option value='3:00 PM'>3:00 PM</option>
                  <option value='4:00 PM'>4:00 PM</option>
                  <option value='5:00 PM'>5:00 PM</option>
                  <option value='6:00 PM'>6:00 PM</option>
                  <option value='7:00 PM'>7:00 PM</option>
                  <option value='8:00 PM'>8:00 PM</option>
                </select>
              </div>
            </div>

            <!-- Message row -->
            <div class='form-field border-b border-brand-charcoal/10 py-6'>
              <label
                for='comment'
                class='block font-mono text-[11px] tracking-[0.15em] uppercase text-brand-muted mb-3'
              >
                Message
              </label>
              <textarea
                id='comment'
                name='comment'
                rows='4'
                placeholder='Tell us how we can help you...'
                class='w-full bg-transparent text-brand-charcoal text-lg font-light placeholder:text-brand-charcoal/25 focus:outline-none border-none p-0 resize-none'
              ></textarea>
            </div>

            <!-- HIPAA Consent -->
            <div class='form-field py-6'>
              <label class='flex items-start gap-3 cursor-pointer group'>
                <input
                  type='checkbox'
                  id='hipaaConsent'
                  name='hipaaConsent'
                  required
                  class='mt-1 w-4 h-4 border-brand-charcoal/20 text-brand-gold focus:ring-brand-gold/30 accent-brand-gold cursor-pointer flex-shrink-0'
                />
                <span
                  class='text-sm text-brand-charcoal font-light leading-relaxed transition-colors duration-300'
                >
                  I have read and agree to the
                  <a
                    href='/legal/hipaa-consent'
                    target='_blank'
                    rel='noopener noreferrer'
                    class='text-brand-charcoal font-medium underline decoration-brand-gold/40 underline-offset-2 hover:decoration-brand-gold hover:text-brand-gold transition-colors duration-300'
                  >
                    HIPAA Notice of Privacy Practices
                  </a>
                  and consent to the collection and use of my information as described.
                  <span class='text-brand-gold' aria-hidden='true'>*</span>
                </span>
              </label>
              <p
                id='hipaa-error'
                class='hidden mt-3 text-sm text-red-500 pl-7 font-mono text-[11px]'
              >
                You must agree to the HIPAA consent before submitting.
              </p>
            </div>

            <!-- Submit + security -->
            <div
              class='flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 pt-4'
            >
              <button
                type='submit'
                id='submit-btn'
                class='group inline-flex items-center gap-3 px-8 py-4 text-sm font-semibold tracking-[0.15em] uppercase bg-brand-blue text-brand-white transition-all duration-500 hover:bg-brand-charcoal disabled:opacity-40 disabled:cursor-not-allowed'
              >
                <span class='flex items-center gap-2'>
                  <span id='btn-text'>Send Message</span>
                  <svg
                    id='btn-arrow'
                    class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke='currentColor'
                    stroke-width='2'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
                  </svg>
                  <svg
                    id='btn-spinner'
                    class='hidden w-4 h-4 animate-spin'
                    viewBox='0 0 24 24'
                    fill='none'
                  >
                    <circle
                      class='opacity-25'
                      cx='12'
                      cy='12'
                      r='10'
                      stroke='currentColor'
                      stroke-width='4'></circle>
                    <path
                      class='opacity-75'
                      fill='currentColor'
                      d='M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z'
                    ></path>
                  </svg>
                </span>
              </button>
              <span
                class='flex items-center gap-2 font-mono text-[10px] tracking-[0.15em] uppercase text-brand-muted'
              >
                <svg
                  class='w-3.5 h-3.5 text-green-600'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z'
                  ></path>
                </svg>
                Encrypted & Secure
              </span>
            </div>
          </form>

          <!-- Success message -->
          <div id='success-message' class='hidden'>
            <div class='py-20 text-center'>
              <div class='w-10 h-px bg-brand-gold mx-auto mb-8'></div>
              <h3
                class='text-3xl md:text-4xl font-display font-extrabold text-brand-charcoal mb-4'
              >
                Message sent.
              </h3>
              <p
                class='text-brand-charcoal font-light max-w-sm mx-auto leading-relaxed'
              >
                Thank you for reaching out. Our team will get back to you within
                24 hours.
              </p>
            </div>
          </div>

          <!-- Error message -->
          <div id='error-message' class='hidden mt-6'>
            <div
              class='border border-red-200 bg-red-50/50 p-5 flex items-start gap-3'
            >
              <svg
                class='w-4 h-4 text-red-500 flex-shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z'
                ></path>
              </svg>
              <p class='text-sm text-red-700 font-light'>
                Something went wrong. Please try again or call us at
                <a href='tel:8136092034' class='font-semibold underline'
                  >(813) 609-2034</a
                >.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar info: 4 cols -->
        <div class='lg:col-span-4'>
          <div class='lg:sticky lg:top-32 space-y-10'>
            <!-- Quick contact -->
            <div>
              <span
                class='font-mono text-[11px] tracking-[0.15em] uppercase text-brand-muted block mb-6'
              >
                Quick Contact
              </span>
              <address class='not-italic space-y-5 text-black'>
                <p class='flex items-start gap-3'>
                  <svg
                    class='w-4 h-4 text-brand-gold flex-shrink-0 mt-1'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke='currentColor'
                    stroke-width='1.5'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z'
                    ></path>
                  </svg>
                  <a
                    href='tel:8136092034'
                    class='hover:text-brand-gold transition-colors'
                    >(813) 609-2034</a
                  >
                </p>
                <p class='flex items-start gap-3'>
                  <svg
