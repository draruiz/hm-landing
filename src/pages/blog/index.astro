---
import Layout from "../../layouts/Layout.astro";
import { blogPosts } from "../../utils/blog-data";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const posts = blogPosts;

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Blog", url: `${siteUrl}/blog` },
  ]),
];
---

<Layout
  title='Mental Health Blog — Insights and Resources'
  description='Explore expert articles on anxiety, therapy, trauma recovery, and mental wellness from the team at Healthy Mind Specialists in Tampa, FL.'
  schema={schemas}
>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO BANNER                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section
    class='relative bg-brand-blue py-24 md:py-32 lg:py-40 overflow-hidden'
    aria-label='Blog hero'
  >
    <img
      src='https://images.unsplash.com/photo-1456324504439-367cee3b3c32?w=1920&h=1080&fit=crop&q=80'
      alt='Open journal and pen representing mental health writing and self-reflection'
      width='1920'
      height='1080'
      loading='eager'
      fetchpriority='high'
      class='absolute inset-0 w-full h-full object-cover'
    />
    <div class='absolute inset-0 bg-brand-blue/70' aria-hidden='true'></div>
    <div
      class='absolute inset-0 opacity-[0.06] pointer-events-none'
      aria-hidden='true'
    >
      <div
        class='absolute -top-32 -left-32 w-[600px] h-[600px] bg-brand-gold rounded-full blur-[140px]'
      >
      </div>
      <div
        class='absolute -bottom-40 -right-20 w-[500px] h-[500px] bg-brand-gold-light rounded-full blur-[120px]'
      >
      </div>
    </div>

    <div class='relative z-10 max-w-4xl mx-auto px-6 text-center'>
      <div
        class='flex items-center justify-center gap-3 mb-6'
        aria-hidden='true'
      >
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
        <span class='block w-2.5 h-2.5 rounded-full border border-brand-gold'
        ></span>
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
      </div>

      <h1
        class='text-4xl md:text-5xl lg:text-6xl font-display italic text-white leading-tight'
      >
        Our <span class='text-brand-gold-light'>Blog</span>
      </h1>

      <p
        class='mt-5 text-white/65 text-base md:text-lg lg:text-xl max-w-2xl mx-auto font-sans leading-relaxed'
      >
        Expert insights, practical tips, and resources for your mental health
        journey.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- BLOG GRID                                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='py-20 md:py-28 bg-white' aria-labelledby='posts-heading'>
    <div class='max-w-7xl mx-auto px-6'>
      <div class='text-center mb-16'>
        <span
          class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
          aria-hidden='true'></span>
        <h2
          id='posts-heading'
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-4'
        >
          Latest Articles
        </h2>
        <p class='text-brand-blue/60 text-lg max-w-xl mx-auto'>
          Stay informed with evidence-based articles from our clinical team.
        </p>
      </div>

      <div class='grid gap-10 md:grid-cols-2 lg:grid-cols-3'>
        {
          posts.map((post) => (
            <article class='group flex flex-col bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg transition-shadow duration-300 overflow-hidden'>
              <a
                href={`/blog/${post.slug}`}
                class='block overflow-hidden'
                aria-label={`Read ${post.title}`}
              >
                <img
                  src={post.heroImage}
                  alt={post.title}
                  width='800'
                  height='450'
                  loading='lazy'
                  class='w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500'
                />
              </a>

              <div class='flex flex-col flex-1 p-6'>
                <div class='flex items-center gap-3 text-sm text-brand-blue/50 mb-3'>
                  <span class='inline-block bg-brand-cream text-brand-blue font-medium px-3 py-1 rounded-full text-xs'>
                    {post.category}
                  </span>
                  <time datetime={post.publishedDate}>
                    {new Date(post.publishedDate).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>

                <h3 class='text-xl font-display italic text-brand-blue mb-2 group-hover:text-brand-gold transition-colors duration-200'>
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h3>

                <p class='text-brand-blue/60 text-sm leading-relaxed flex-1 mb-4'>
                  {post.description}
                </p>

                <div class='flex items-center justify-between text-sm text-brand-blue/40 mt-auto pt-4 border-t border-gray-100'>
                  <span>{post.author}</span>
                  <span>{post.readingTime}</span>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CTA                                                        -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='py-20 md:py-28 bg-brand-cream' aria-label='Call to action'>
    <div class='max-w-3xl mx-auto px-6 text-center'>
      <span
        class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
        aria-hidden='true'></span>
      <h2 class='text-3xl md:text-4xl font-display italic text-brand-blue mb-4'>
        Ready to Take the Next Step?
      </h2>
      <p class='text-brand-blue/60 text-lg max-w-xl mx-auto mb-10'>
        Our team is here to support you. Schedule a consultation and start your
        journey toward a healthier mind.
      </p>
      <a
        href='/get-started/appointment-request'
        class='inline-flex items-center gap-2 bg-brand-gold hover:bg-brand-gold-dark text-white font-semibold px-8 py-4 rounded-full transition-colors duration-300 shadow-lg shadow-brand-gold/20'
      >
        Book a Consultation
        <svg
          class='w-4 h-4'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          stroke-width='2'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
        </svg>
      </a>
    </div>
  </section>
</Layout>
