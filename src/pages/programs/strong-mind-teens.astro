---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Programs", url: `${siteUrl}/programs` },
    { name: "Strong Mind Teens", url: `${siteUrl}/programs/strong-mind-teens` },
  ]),
];

const coreIssues = [
  "Constant anxiety with no clear explanation",
  "Difficulty regulating emotions and emotional outbursts",
  "Low self-esteem and chronic comparison",
  "Ongoing conflict with parents and feeling misunderstood",
  "Excessive phone use as emotional escape",
  "Lack of motivation, apathy, and loss of direction",
  "Social anxiety and fear of rejection",
  "Feeling emotionally alone, even within the family system",
];

const programSteps = [
  {
    step: "01",
    title: "Parent Consultation",
    subtitle: "Initial Assessment",
    description:
      "The process begins with a parent consultation to determine whether the program is the right fit. Parents share concerns, ask questions, and gain clarity on how the program works before enrollment.",
  },
  {
    step: "02",
    title: "Intake & Goal Setting",
    subtitle: "Week 1",
    description:
      "The first session focuses on building rapport with the adolescent, understanding emotional stressors, daily routines, and communication patterns. Clear and realistic goals are established.",
  },
  {
    step: "03",
    title: "Weekly Coaching Sessions",
    subtitle: "Weeks 2–5",
    description:
      "Each week includes a 60-minute individual coaching session focused on emotional regulation, anxiety management, habit and routine development, communication skills, and accountability.",
  },
  {
    step: "04",
    title: "Parent Guidance & Check-Ins",
    subtitle: "Throughout Program",
    description:
      "Parents receive guidance throughout the program on how to support changes at home, reinforce boundaries, and reduce conflict. This ensures consistency and prevents mixed messages.",
  },
  {
    step: "05",
    title: "Progress Monitoring",
    subtitle: "Clinical Awareness",
    description:
      "Progress is monitored throughout the six weeks. The program operates within a clinically informed framework supported by Healthy Mind Specialists, ensuring responsible oversight.",
  },
  {
    step: "06",
    title: "Wrap-Up & Next Steps",
    subtitle: "Week 6",
    description:
      "The final session reviews progress, reinforces skills, and creates a forward plan. Parents receive feedback and guidance on sustaining improvements or exploring next steps if needed.",
  },
];

const outcomes = [
  {
    title: "Understand what they are feeling",
    description:
      "Identify what they are feeling and why they react the way they do. Recognition of emotional patterns and triggers.",
  },
  {
    title: "Learn emotional regulation",
    description:
      "Emotional regulation without suppression. Practical tools for daily emotional management.",
  },
  {
    title: "Develop internal security",
    description:
      "Build internal security and personal judgment. Strengthen self-confidence and decision-making.",
  },
  {
    title: "Improve communication",
    description:
      "Improve communication with parents without constant confrontation. Express needs and emotions effectively.",
  },
  {
    title: "Reduce anxiety",
    description:
      "Reduce anxiety and emotional dependence on their phone. Develop healthy coping mechanisms.",
  },
  {
    title: "Rebuild motivation",
    description:
      "Rebuild motivation and personal meaning. Find direction and purpose.",
  },
];
---

<Layout
  title='Strong Mind Teens — Adolescent Coaching Program'
  description='A premium 6-week adolescent coaching program at Healthy Mind Specialists. Structured, practical coaching for teens struggling with anxiety, emotional regulation, and family communication.'
  schema={schemas}
>
  <!-- Hero Banner -->
  <section
    class='relative h-[500px] md:h-[600px] overflow-hidden bg-brand-blue'
  >
    <img
      src='https://images.unsplash.com/photo-1529333166437-7750a6dd5a70?auto=format&fit=crop&w=1920&q=80'
      alt='Group of diverse teenagers laughing and connecting outdoors'
      width='1920'
      height='600'
      class='absolute inset-0 w-full h-full object-cover'
      loading='eager'
      fetchpriority='high'
    />
    <div
      class='absolute inset-0 bg-gradient-to-br from-brand-blue-dark/85 via-brand-blue/80 to-brand-blue-light/75'
    >
    </div>
    <div class='relative h-full flex items-center'>
      <div class='max-w-5xl mx-auto px-6 text-center text-white'>
        <span
          class='inline-block text-brand-gold font-semibold tracking-widest uppercase text-sm mb-4'
        >
          Premium Program
        </span>
        <h1 class='text-4xl md:text-5xl lg:text-7xl font-display italic mb-6'>
          Strong Mind Teens
        </h1>
        <p class='text-xl md:text-2xl text-white/80 max-w-3xl mx-auto mb-4'>
          Adolescent Coaching Program
        </p>
        <p class='text-lg text-white/60 max-w-2xl mx-auto mb-10'>
          A coaching program designed specifically to address the real and
          current struggles adolescents face today. Structured, practical
          coaching adapted to the adolescent's language and emotional stage.
          This is not a space to simply talk — it is guided support with
          direction.
        </p>
        <a
          href='tel:8136092034'
          class='inline-flex items-center px-8 py-4 bg-brand-gold text-white font-semibold rounded-full hover:bg-brand-gold-dark transition-all duration-300 shadow-lg hover:shadow-xl'
        >
          Call Now to Start — 813-609-2034
        </a>
      </div>
    </div>
  </section>

  <!-- Core Issues -->
  <section class='py-20 md:py-28 bg-white'>
    <div class='max-w-5xl mx-auto px-6'>
      <div class='text-center mb-16'>
        <span
          class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
          aria-hidden='true'></span>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-4'
        >
          Core Issues Addressed
        </h2>
        <p class='text-lg text-brand-blue/60'>
          What teens live with and don't know how to express
        </p>
      </div>
      <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
        {
          coreIssues.map((issue, i) => (
            <div class='flex items-start gap-4 p-6 bg-brand-cream rounded-xl'>
              <span class='flex-shrink-0 w-10 h-10 rounded-full bg-brand-blue text-white flex items-center justify-center text-sm font-semibold'>
                {String(i + 1).padStart(2, "0")}
              </span>
              <p class='text-brand-blue/80 text-lg'>{issue}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- What the Program Helps Adolescents To -->
  <section class='py-20 md:py-28 bg-brand-cream'>
    <div class='max-w-5xl mx-auto px-6'>
      <div class='text-center mb-16'>
        <span
          class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
          aria-hidden='true'></span>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-4'
        >
          What the Program Helps Adolescents To
        </h2>
      </div>
      <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
        {
          outcomes.map((outcome, i) => (
            <div class='bg-white rounded-2xl p-8 shadow-sm border border-gray-100'>
              <span class='block text-3xl font-display text-brand-gold mb-4'>
                {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class='text-xl font-display text-brand-blue mb-3'>
                {outcome.title}
              </h3>
              <p class='text-brand-blue/60'>{outcome.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How the 6-Week Program Works -->
  <section class='py-20 md:py-28 bg-white'>
    <div class='max-w-5xl mx-auto px-6'>
      <div class='text-center mb-16'>
        <span
          class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
          aria-hidden='true'></span>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-4'
        >
          How the 6-Week Program Works
        </h2>
        <p class='text-lg text-brand-blue/60 max-w-2xl mx-auto'>
          A comprehensive, step-by-step approach designed to create lasting
          change in adolescent well-being
        </p>
      </div>
      <div class='space-y-8'>
        {
          programSteps.map((step) => (
            <div class='flex gap-6 md:gap-8 items-start'>
              <div class='flex-shrink-0 w-14 h-14 rounded-2xl bg-brand-blue text-white flex items-center justify-center text-xl font-bold'>
                {step.step}
              </div>
              <div class='flex-1 pb-8 border-b border-gray-100 last:border-0'>
                <span class='text-sm text-brand-gold font-semibold uppercase tracking-wider'>
                  {step.subtitle}
                </span>
                <h3 class='text-xl md:text-2xl font-display text-brand-blue mt-1 mb-3'>
                  {step.title}
                </h3>
                <p class='text-brand-blue/70 text-lg'>{step.description}</p>
              </div>
