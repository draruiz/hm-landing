---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Get Started", url: `${siteUrl}/get-started` },
    {
      name: "Appointment Request",
      url: `${siteUrl}/get-started/appointment-request`,
    },
  ]),
];
---

<Layout
  title='Request an Appointment — Schedule Your Visit'
  description='Schedule your appointment with Healthy Mind Specialists in Tampa, FL. Complete our simple form and we will be in touch as soon as possible.'
  schema={schemas}
>
  <!-- HERO -->
  <section
    class='relative bg-brand-blue min-h-[60vh] overflow-hidden'
    aria-label='Appointment Request hero'
  >
    <!-- Background image -->
    <img
      src='/images/contact-hero.jpg'
      alt='Calm and welcoming therapy setting at Healthy Mind Specialists'
      width='1920'
      height='1280'
      loading='eager'
      fetchpriority='high'
      class='absolute inset-0 w-full h-full object-cover'
    />
    <div class='absolute inset-0 bg-brand-blue/75' aria-hidden='true'></div>

    <!-- Subtle grid lines -->
    <div class='absolute inset-0 pointer-events-none z-0' aria-hidden='true'>
      <div
        class='absolute left-[25%] top-0 bottom-0 w-px bg-brand-white/[0.03]'
      >
      </div>
      <div
        class='absolute left-[50%] top-0 bottom-0 w-px bg-brand-white/[0.03]'
      >
      </div>
      <div
        class='absolute left-[75%] top-0 bottom-0 w-px bg-brand-white/[0.03]'
      >
      </div>
    </div>

    <div
      class='relative z-10 max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20 flex flex-col justify-center min-h-[60vh] py-32 lg:py-40'
    >
      <div class='hero-label opacity-0 mb-8'>
        <span
          class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-gold'
        >
          Get Started
        </span>
        <div class='w-12 h-px bg-brand-gold/40 mt-3'></div>
      </div>

      <h1
        class='hero-title opacity-0 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display font-extrabold text-brand-white leading-[0.95] tracking-[-0.03em] max-w-3xl'
      >
        Request an<br />Appointment
      </h1>

      <div class='hero-divider w-0 h-px bg-brand-gold/50 mt-8 mb-8'></div>

      <p
        class='hero-desc opacity-0 text-brand-white/60 text-base md:text-lg font-light leading-relaxed max-w-lg'
      >
        Complete the form below and we'll be in touch as soon as possible to
        confirm your visit.
      </p>
    </div>
  </section>

  <!-- CONTACT INFO STRIP -->
  <section
    class='relative bg-brand-cream border-b border-brand-charcoal/10'
    aria-label='Contact details'
  >
    <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
      <div
        class='grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-brand-charcoal/10'
      >
        <!-- Phone -->
        <a
          href='tel:8136092034'
          class='group flex items-center gap-4 py-6 md:py-8 md:pr-8'
        >
          <svg
            class='w-4 h-4 text-brand-gold flex-shrink-0'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='1.5'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z'
            ></path>
          </svg>
          <div>
            <span
              class='font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted block'
              >Phone</span
            >
            <span
              class='text-sm text-brand-charcoal font-medium group-hover:text-brand-gold transition-colors duration-300'
              >(813) 609-2034</span
            >
          </div>
        </a>
        <!-- Email -->
        <a
          href='mailto:info@healthymindspecialists.com'
          class='group flex items-center gap-4 py-6 md:py-8 md:px-8'
        >
          <svg
            class='w-4 h-4 text-brand-gold flex-shrink-0'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='1.5'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75'
            ></path>
          </svg>
          <div>
            <span
              class='font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted block'
              >Email</span
            >
            <span
              class='text-sm text-brand-charcoal font-medium group-hover:text-brand-gold transition-colors duration-300'
              >info@healthymindspecialists.com</span
            >
          </div>
        </a>
        <!-- Address -->
        <a
          href='https://maps.google.com/?q=11906+Boyette+Rd,+Riverview,+FL+33569'
          target='_blank'
          rel='noopener noreferrer'
          class='group flex items-center gap-4 py-6 md:py-8 md:pl-8'
        >
          <svg
            class='w-4 h-4 text-brand-gold flex-shrink-0'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='1.5'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M15 10.5a3 3 0 11-6 0 3 3 0 016 0z'></path>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z'
            ></path>
          </svg>
          <div>
            <span
              class='font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted block'
              >Location</span
            >
            <span
              class='text-sm text-brand-charcoal font-medium group-hover:text-brand-gold transition-colors duration-300'
              >11906 Boyette Rd, Riverview, FL</span
            >
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section
    class='relative bg-brand-white py-24 md:py-36'
    aria-labelledby='appointment-form-heading'
  >
    <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
      <div class='grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24'>
        <!-- Left: Section info -->
        <div data-animate>
          <span
            class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'
          >
            Schedule a Visit
          </span>
          <h2
            id='appointment-form-heading'
            class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em] mb-8'
          >
            Let's get you<br />started.
          </h2>
          <div class='w-10 h-px bg-brand-charcoal/15 mb-8'></div>
          <p
            class='text-brand-charcoal/60 text-base md:text-lg font-light leading-relaxed mb-8'
          >
            Fill out the form and our team will reach out within 24 hours to
            confirm your appointment. You can also reach us directly by phone or
            email.
          </p>

          <!-- Quick contact -->
          <div class='space-y-4'>
            <a
              href='tel:8136092034'
              class='group inline-flex items-center gap-2 text-sm font-semibold tracking-[0.1em] uppercase text-brand-charcoal hover:text-brand-gold transition-colors duration-300'
            >
              <span>Call (813) 609-2034</span>
              <svg
                class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
              </svg>
            </a>
          </div>

          <!-- Security note -->
          <div class='mt-12 pt-8 border-t border-brand-charcoal/10'>
            <p
              class='flex items-center gap-3 text-xs font-mono tracking-[0.1em] uppercase text-brand-muted'
            >
              <svg
                class='w-4 h-4 text-brand-gold'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='1.5'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z'
                ></path>
              </svg>
              Encrypted & HIPAA Compliant
            </p>
          </div>
        </div>

        <!-- Right: Form -->
        <div data-animate>
          <form id='contact-form' class='space-y-6' novalidate>
            <!-- Name + Email -->
            <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
              <div class='form-field'>
                <label
                  for='name'
                  class='block font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted mb-3'
                >
                  Name <span class='text-brand-gold' aria-hidden='true'>*</span>
                </label>
                <input
                  type='text'
                  id='name'
                  name='name'
                  required
                  autocomplete='name'
                  placeholder='Your full name'
                  class='w-full px-0 py-3 bg-transparent border-0 border-b border-brand-charcoal/15 text-brand-charcoal text-sm font-light placeholder:text-brand-charcoal/30 focus:outline-none focus:border-brand-gold transition-colors duration-300'
                />
              </div>
              <div class='form-field'>
                <label
                  for='email'
                  class='block font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted mb-3'
                >
                  Email <span class='text-brand-gold' aria-hidden='true'>*</span
                  >
                </label>
                <input
                  type='email'
                  id='email'
                  name='email'
                  required
                  autocomplete='email'
                  placeholder='you@example.com'
                  class='w-full px-0 py-3 bg-transparent border-0 border-b border-brand-charcoal/15 text-brand-charcoal text-sm font-light placeholder:text-brand-charcoal/30 focus:outline-none focus:border-brand-gold transition-colors duration-300'
                />
              </div>
            </div>

            <!-- Phone -->
            <div class='form-field'>
              <label
                for='phone'
                class='block font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted mb-3'
              >
                Phone
              </label>
              <input
                type='tel'
                id='phone'
                name='phone'
                autocomplete='tel'
                placeholder='(555) 000-0000'
                class='w-full px-0 py-3 bg-transparent border-0 border-b border-brand-charcoal/15 text-brand-charcoal text-sm font-light placeholder:text-brand-charcoal/30 focus:outline-none focus:border-brand-gold transition-colors duration-300'
              />
            </div>

            <!-- Date + Time -->
            <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
              <div class='form-field'>
                <label
                  for='preferredDate'
                  class='block font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted mb-3'
                >
                  Preferred Date
                </label>
                <input
                  type='date'
                  id='preferredDate'
                  name='preferredDate'
                  class='w-full px-0 py-3 bg-transparent border-0 border-b border-brand-charcoal/15 text-brand-charcoal text-sm font-light placeholder:text-brand-charcoal/30 focus:outline-none focus:border-brand-gold transition-colors duration-300'
                />
              </div>
              <div class='form-field'>
                <label
                  for='time'
                  class='block font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted mb-3'
                >
                  Preferred Time
                </label>
                <select
                  id='time'
                  name='time'
                  class='w-full px-0 py-3 bg-transparent border-0 border-b border-brand-charcoal/15 text-brand-charcoal text-sm font-light focus:outline-none focus:border-brand-gold transition-colors duration-300 appearance-none cursor-pointer'
                >
                  <option value=''>Select a time</option>
                  <option value='8:00 AM'>8:00 AM</option>
                  <option value='9:00 AM'>9:00 AM</option>
                  <option value='10:00 AM'>10:00 AM</option>
                  <option value='11:00 AM'>11:00 AM</option>
                  <option value='12:00 PM'>12:00 PM</option>
                  <option value='1:00 PM'>1:00 PM</option>
                  <option value='2:00 PM'>2:00 PM</option>
                  <option value='3:00 PM'>3:00 PM</option>
                  <option value='4:00 PM'>4:00 PM</option>
                  <option value='5:00 PM'>5:00 PM</option>
                  <option value='6:00 PM'>6:00 PM</option>
                  <option value='7:00 PM'>7:00 PM</option>
                  <option value='8:00 PM'>8:00 PM</option>
                </select>
              </div>
            </div>

            <!-- Message -->
            <div class='form-field'>
              <label
                for='comment'
                class='block font-mono text-[10px] tracking-[0.2em] uppercase text-brand-muted mb-3'
              >
                Comment or Message
              </label>
              <textarea
                id='comment'
                name='comment'
                rows='4'
                placeholder='Tell us how we can help you...'
                class='w-full px-0 py-3 bg-transparent border-0 border-b border-brand-charcoal/15 text-brand-charcoal text-sm font-light placeholder:text-brand-charcoal/30 focus:outline-none focus:border-brand-gold transition-colors duration-300 resize-none'
              ></textarea>
            </div>

            <!-- HIPAA Consent -->
            <div class='form-field pt-2'>
              <label class='flex items-start gap-3 cursor-pointer group'>
                <input
                  type='checkbox'
                  id='hipaaConsent'
                  name='hipaaConsent'
                  required
                  class='mt-0.5 w-4 h-4 border-brand-charcoal/20 text-brand-gold focus:ring-brand-gold/30 accent-brand-gold cursor-pointer flex-shrink-0'
                />
                <span
                  class='text-xs text-brand-charcoal/50 leading-relaxed group-hover:text-brand-charcoal/70 transition-colors duration-300'
                >
                  I have read and agree to the
                  <a
                    href='/legal/hipaa-consent'
                    target='_blank'
                    rel='noopener noreferrer'
                    class='text-brand-charcoal font-medium hover:text-brand-gold transition-colors duration-300'
                  >
                    HIPAA Notice of Privacy Practices
                  </a>
                  and consent to the collection and use of my information as described.
                  <span class='text-brand-gold' aria-hidden='true'>*</span>
                </span>
              </label>
              <p id='hipaa-error' class='hidden mt-2 text-xs text-red-500 pl-7'>
                You must agree to the HIPAA consent before submitting.
              </p>
            </div>

            <!-- Submit -->
            <div class='pt-4'>
              <button
                type='submit'
                id='submit-btn'
                class='group inline-flex items-center gap-3 px-8 py-4 text-sm font-semibold tracking-[0.15em] uppercase bg-brand-gold text-brand-blue transition-all duration-500 hover:bg-brand-gold-light disabled:opacity-50 disabled:cursor-not-allowed'
              >
                <span id='btn-text'>Request Appointment</span>
                <svg
                  id='btn-arrow'
                  class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
                </svg>
                <svg
                  id='btn-spinner'
                  class='hidden w-4 h-4 animate-spin'
                  viewBox='0 0 24 24'
                  fill='none'
                >
                  <circle
                    class='opacity-25'
                    cx='12'
                    cy='12'
                    r='10'
                    stroke='currentColor'
                    stroke-width='4'></circle>
                  <path
                    class='opacity-75'
                    fill='currentColor'
                    d='M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z'
                  ></path>
                </svg>
              </button>
            </div>
          </form>

          <!-- Success message (hidden) -->
          <div id='success-message' class='hidden'>
            <div class='py-16'>
              <div class='w-10 h-px bg-brand-gold mb-8'></div>
              <h3
                class='text-3xl md:text-4xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em] mb-4'
              >
                Request Sent.
              </h3>
              <p
                class='text-brand-charcoal/60 text-base font-light leading-relaxed max-w-sm'
              >
                Thank you for reaching out. Our team will get back to you within
                24 hours to confirm your appointment.
              </p>
              <a
                href='/'
                class='group inline-flex items-center gap-2 mt-8 text-sm font-semibold tracking-[0.1em] uppercase text-brand-charcoal hover:text-brand-gold transition-colors duration-300'
              >
                <span>Back to Home</span>
                <svg
                  class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Error message (hidden) -->
          <div id='error-message' class='hidden mt-6'>
            <div class='border-l-2 border-red-500 pl-4 py-2'>
              <p class='text-sm text-brand-charcoal/70 font-light'>
                Something went wrong. Please try again or call us at
                <a
                  href='tel:8136092034'
                  class='font-medium text-brand-charcoal hover:text-brand-gold transition-colors'
                  >(813) 609-2034</a
                >.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import gsap from "gsap";

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (!prefersReduced) {
    // Hero entrance
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.fromTo(
      ".hero-label",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      0.2,
    );

    tl.fromTo(
      ".hero-title",
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 1 },
      0.4,
    );

    tl.to(
      ".hero-divider",
      { width: "60px", duration: 0.8, ease: "power2.inOut" },
      1.0,
    );

    tl.fromTo(
      ".hero-desc",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      1.1,
    );

    // Scroll reveal for sections
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
          }
        });
      },
      { threshold: 0.15 },
    );
    document
      .querySelectorAll("[data-animate]")
      .forEach((el) => observer.observe(el));
  } else {
    document
      .querySelectorAll<HTMLElement>(
        ".hero-label, .hero-title, .hero-divider, .hero-desc",
      )
      .forEach((el) => {
        el.style.opacity = "1";
        el.style.transform = "none";
      });
    const divider = document.querySelector<HTMLElement>(".hero-divider");
    if (divider) divider.style.width = "60px";
  }

  // FORM SUBMISSION LOGIC
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text")!;
  const btnArrow = document.getElementById("btn-arrow")!;
  const btnSpinner = document.getElementById("btn-spinner")!;
  const successMessage = document.getElementById("success-message")!;
  const errorMessage = document.getElementById("error-message")!;
  const hipaaError = document.getElementById("hipaa-error")!;
  const hipaaCheckbox = document.getElementById(
    "hipaaConsent",
  ) as HTMLInputElement;

  const API_BASE = import.meta.env.PUBLIC_HM_CMS_URL;

  hipaaCheckbox.addEventListener("change", () => {
    if (hipaaCheckbox.checked) {
      hipaaError.classList.add("hidden");
    }
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!hipaaCheckbox.checked) {
      hipaaError.classList.remove("hidden");
      hipaaCheckbox.focus();
      if (!prefersReduced) {
        gsap.fromTo(
          hipaaError,
          { x: -6 },
          { x: 0, duration: 0.4, ease: "elastic.out(1, 0.3)" },
        );
      }
      return;
    }

    const formData = new FormData(form);
    const payload = {
      name: (formData.get("name") as string).trim(),
      email: (formData.get("email") as string).trim(),
      phone: (formData.get("phone") as string).trim() || "",
      preferredDate: (formData.get("preferredDate") as string) || "",
      time: (formData.get("time") as string) || "",
      comment: (formData.get("comment") as string).trim() || "",
      hipaaConsent: true,
    };

    if (!payload.name || !payload.email) {
      return;
    }

    submitBtn.disabled = true;
    btnText.textContent = "Sending...";
    btnArrow.classList.add("hidden");
    btnSpinner.classList.remove("hidden");
    errorMessage.classList.add("hidden");

    try {
      const response = await fetch(`${API_BASE}/forms/contact`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`Server responded with ${response.status}`);
      }

      if (!prefersReduced) {
        gsap.to(form, {
          opacity: 0,
          y: -20,
          duration: 0.4,
          ease: "power2.in",
          onComplete: () => {
            form.classList.add("hidden");
            successMessage.classList.remove("hidden");
            gsap.fromTo(
              successMessage,
              { opacity: 0, y: 20 },
              { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" },
            );
          },
        });
      } else {
        form.classList.add("hidden");
        successMessage.classList.remove("hidden");
      }
    } catch {
      errorMessage.classList.remove("hidden");
      if (!prefersReduced) {
        gsap.fromTo(
          errorMessage,
          { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" },
        );
      }

      submitBtn.disabled = false;
      btnText.textContent = "Request Appointment";
      btnArrow.classList.remove("hidden");
      btnSpinner.classList.add("hidden");
    }
  });
</script>
