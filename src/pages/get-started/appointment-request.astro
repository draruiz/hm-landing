---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Get Started", url: `${siteUrl}/get-started` },
    {
      name: "Appointment Request",
      url: `${siteUrl}/get-started/appointment-request`,
    },
  ]),
];
---

<Layout
  title='Request an Appointment — Schedule Your Visit'
  description='Schedule your appointment with Healthy Mind Specialists in Tampa, FL. Complete our simple form and we will be in touch as soon as possible.'
  schema={schemas}
>
  <!-- HERO BANNER -->
  <section
    class='relative bg-brand-blue py-24 md:py-32 lg:py-40 overflow-hidden'
    aria-label='Appointment Request hero'
  >
    <img
      src='/images/contact-hero.jpg'
      alt='Calm and welcoming therapy setting at Healthy Mind Specialists'
      width='1920'
      height='1280'
      loading='eager'
      fetchpriority='high'
      class='absolute inset-0 w-full h-full object-cover'
    />
    <div class='absolute inset-0 bg-brand-blue/70' aria-hidden='true'></div>
    <div
      class='absolute inset-0 opacity-[0.06] pointer-events-none'
      aria-hidden='true'
    >
      <div
        class='absolute -top-32 -left-32 w-[600px] h-[600px] bg-brand-gold rounded-full blur-[140px]'
      >
      </div>
      <div
        class='absolute -bottom-40 -right-20 w-[500px] h-[500px] bg-brand-gold-light rounded-full blur-[120px]'
      >
      </div>
    </div>
    <div
      class='absolute inset-0 opacity-[0.03]'
      style='background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;'
      aria-hidden='true'
    >
    </div>

    <div class='relative z-10 max-w-4xl mx-auto px-6 text-center'>
      <div
        class='hero-ornament flex items-center justify-center gap-3 mb-6 opacity-0'
        aria-hidden='true'
      >
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
        <span class='block w-2.5 h-2.5 rounded-full border border-brand-gold'
        ></span>
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
      </div>

      <h1
        class='hero-title text-4xl md:text-5xl lg:text-6xl font-display italic text-white leading-tight opacity-0'
      >
        Appointment <span class='text-brand-gold-light'>Request</span>
      </h1>

      <p
        class='hero-subtitle mt-5 text-white/65 text-base md:text-lg lg:text-xl max-w-2xl mx-auto font-sans leading-relaxed opacity-0'
      >
        Please complete the form below to schedule an appointment. We will try
        our best to accommodate your request and will be in touch as soon as
        possible.
      </p>
    </div>
  </section>

  <!-- CONTACT INFO RIBBON -->
  <section
    class='relative -mt-8 z-20 max-w-5xl mx-auto px-6'
    aria-label='Contact details'
  >
    <div
      class='contact-ribbon opacity-0 translate-y-6 bg-white rounded-2xl shadow-2xl shadow-brand-blue/8 border border-brand-gold/10 px-8 py-7 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-4'
    >
      <!-- Phone -->
      <a
        href='tel:8136092034'
        class='group flex items-center gap-4 justify-center md:justify-start'
      >
        <span
          class='flex-shrink-0 w-12 h-12 rounded-xl bg-brand-blue/5 flex items-center justify-center group-hover:bg-brand-gold/10 transition-colors duration-300'
        >
          <svg
            class='w-5 h-5 text-brand-blue group-hover:text-brand-gold transition-colors duration-300'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='1.8'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z'
            ></path>
          </svg>
        </span>
        <div>
          <p
            class='text-xs uppercase tracking-widest text-brand-blue/40 font-semibold'
          >
            Phone
          </p>
          <p
            class='text-brand-blue font-medium group-hover:text-brand-gold transition-colors duration-300'
          >
            (813) 609-2034
          </p>
        </div>
      </a>
      <!-- Email -->
      <a
        href='mailto:info@healthymindspecialists.com'
        class='group flex items-center gap-4 justify-center'
      >
        <span
          class='flex-shrink-0 w-12 h-12 rounded-xl bg-brand-blue/5 flex items-center justify-center group-hover:bg-brand-gold/10 transition-colors duration-300'
        >
          <svg
            class='w-5 h-5 text-brand-blue group-hover:text-brand-gold transition-colors duration-300'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='1.8'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75'
            ></path>
          </svg>
        </span>
        <div>
          <p
            class='text-xs uppercase tracking-widest text-brand-blue/40 font-semibold'
          >
            Email
          </p>
          <p
            class='text-brand-blue font-medium group-hover:text-brand-gold transition-colors duration-300'
          >
            info@healthymindspecialists.com
          </p>
        </div>
      </a>
      <!-- Address -->
      <a
        href='https://maps.google.com/?q=11906+Boyette+Rd,+Riverview,+FL+33569'
        target='_blank'
        rel='noopener noreferrer'
        class='group flex items-center gap-4 justify-center md:justify-end'
      >
        <span
          class='flex-shrink-0 w-12 h-12 rounded-xl bg-brand-blue/5 flex items-center justify-center group-hover:bg-brand-gold/10 transition-colors duration-300'
        >
          <svg
            class='w-5 h-5 text-brand-blue group-hover:text-brand-gold transition-colors duration-300'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='1.8'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M15 10.5a3 3 0 11-6 0 3 3 0 016 0z'></path>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z'
            ></path>
          </svg>
        </span>
        <div>
          <p
            class='text-xs uppercase tracking-widest text-brand-blue/40 font-semibold'
          >
            Location
          </p>
          <p
            class='text-brand-blue font-medium group-hover:text-brand-gold transition-colors duration-300'
          >
            11906 Boyette Rd, Riverview, FL
          </p>
        </div>
      </a>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section
    class='py-20 md:py-28 lg:py-32 bg-white'
    aria-labelledby='appointment-form-heading'
  >
    <div class='max-w-3xl mx-auto px-6'>
      <!-- Section heading -->
      <div class='form-container opacity-0 translate-y-8'>
        <div class='mb-10 text-center'>
          <p
            class='text-xs uppercase tracking-[0.2em] text-brand-gold font-semibold mb-3'
          >
            Schedule a Visit
          </p>
          <h2
            id='appointment-form-heading'
            class='text-3xl md:text-4xl font-display italic text-brand-blue leading-tight'
          >
            Request an <span class='text-brand-gold'>Appointment</span>
          </h2>
          <div
            class='w-12 h-[2px] bg-brand-gold mt-5 mx-auto'
            aria-hidden='true'
          >
          </div>
        </div>

        <form id='contact-form' class='space-y-6' novalidate>
          <!-- Row 1: Name + Email -->
          <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
            <div class='form-field'>
              <label
                for='name'
                class='block text-sm font-medium text-brand-blue/70 mb-2'
              >
                Name <span class='text-red-400' aria-hidden='true'>*</span>
              </label>
              <input
                type='text'
                id='name'
                name='name'
                required
                autocomplete='name'
                placeholder='Your full name'
                class='w-full px-4 py-3.5 bg-brand-cream/50 border border-brand-blue/10 rounded-xl text-brand-blue placeholder:text-brand-blue/30 focus:outline-none focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 transition-all duration-300'
              />
            </div>
            <div class='form-field'>
              <label
                for='email'
                class='block text-sm font-medium text-brand-blue/70 mb-2'
              >
                Email <span class='text-red-400' aria-hidden='true'>*</span>
              </label>
              <input
                type='email'
                id='email'
                name='email'
                required
                autocomplete='email'
                placeholder='you@example.com'
                class='w-full px-4 py-3.5 bg-brand-cream/50 border border-brand-blue/10 rounded-xl text-brand-blue placeholder:text-brand-blue/30 focus:outline-none focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 transition-all duration-300'
              />
            </div>
          </div>

          <!-- Row 2: Phone -->
          <div class='form-field'>
            <label
              for='phone'
              class='block text-sm font-medium text-brand-blue/70 mb-2'
            >
              Phone
            </label>
            <input
              type='tel'
              id='phone'
              name='phone'
              autocomplete='tel'
              placeholder='(555) 000-0000'
              class='w-full px-4 py-3.5 bg-brand-cream/50 border border-brand-blue/10 rounded-xl text-brand-blue placeholder:text-brand-blue/30 focus:outline-none focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 transition-all duration-300'
            />
          </div>

          <!-- Row 3: Date + Time -->
          <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
            <div class='form-field'>
              <label
                for='preferredDate'
                class='block text-sm font-medium text-brand-blue/70 mb-2'
              >
                Preferred Date
              </label>
              <input
                type='date'
                id='preferredDate'
                name='preferredDate'
                class='w-full px-4 py-3.5 bg-brand-cream/50 border border-brand-blue/10 rounded-xl text-brand-blue placeholder:text-brand-blue/30 focus:outline-none focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 transition-all duration-300'
              />
            </div>
            <div class='form-field'>
              <label
                for='time'
                class='block text-sm font-medium text-brand-blue/70 mb-2'
              >
                Preferred Time
              </label>
              <select
                id='time'
                name='time'
                class='w-full px-4 py-3.5 bg-brand-cream/50 border border-brand-blue/10 rounded-xl text-brand-blue focus:outline-none focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 transition-all duration-300 appearance-none'
              >
                <option value=''>Select a time</option>
                <option value='8:00 AM'>8:00 AM</option>
                <option value='9:00 AM'>9:00 AM</option>
                <option value='10:00 AM'>10:00 AM</option>
                <option value='11:00 AM'>11:00 AM</option>
                <option value='12:00 PM'>12:00 PM</option>
                <option value='1:00 PM'>1:00 PM</option>
                <option value='2:00 PM'>2:00 PM</option>
                <option value='3:00 PM'>3:00 PM</option>
                <option value='4:00 PM'>4:00 PM</option>
                <option value='5:00 PM'>5:00 PM</option>
                <option value='6:00 PM'>6:00 PM</option>
                <option value='7:00 PM'>7:00 PM</option>
                <option value='8:00 PM'>8:00 PM</option>
              </select>
            </div>
          </div>

          <!-- Row 4: Message -->
          <div class='form-field'>
            <label
              for='comment'
              class='block text-sm font-medium text-brand-blue/70 mb-2'
            >
              Comment or Message
            </label>
            <textarea
              id='comment'
              name='comment'
              rows='5'
              placeholder='Tell us how we can help you...'
              class='w-full px-4 py-3.5 bg-brand-cream/50 border border-brand-blue/10 rounded-xl text-brand-blue placeholder:text-brand-blue/30 focus:outline-none focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 transition-all duration-300 resize-none'
            ></textarea>
          </div>

          <!-- HIPAA Consent Checkbox -->
          <div class='form-field'>
            <label class='flex items-start gap-3 cursor-pointer group'>
              <input
                type='checkbox'
                id='hipaaConsent'
                name='hipaaConsent'
                required
                class='mt-1 w-5 h-5 rounded border-brand-blue/20 text-brand-gold focus:ring-brand-gold/30 accent-brand-gold cursor-pointer flex-shrink-0'
              />
              <span
                class='text-sm text-brand-blue/60 leading-relaxed group-hover:text-brand-blue/80 transition-colors duration-300'
              >
                I have read and agree to the
                <a
                  href='/legal/hipaa-consent'
                  target='_blank'
                  rel='noopener noreferrer'
                  class='text-brand-blue font-medium underline decoration-brand-gold/40 underline-offset-2 hover:decoration-brand-gold hover:text-brand-gold transition-colors duration-300'
                >
                  HIPAA Notice of Privacy Practices
                </a>
                and consent to the collection and use of my information as described.
                <span class='text-red-400' aria-hidden='true'>*</span>
              </span>
            </label>
            <p id='hipaa-error' class='hidden mt-2 text-sm text-red-500 pl-8'>
              You must agree to the HIPAA consent before submitting.
            </p>
          </div>

          <!-- Submit Button -->
          <div class='pt-2'>
            <button
              type='submit'
              id='submit-btn'
              class='group relative w-full sm:w-auto inline-flex items-center justify-center gap-3 px-10 py-4 bg-brand-blue text-white font-semibold tracking-wide rounded-xl overflow-hidden transition-all duration-500 hover:shadow-xl hover:shadow-brand-blue/20 hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0 disabled:hover:shadow-none'
            >
              <span
                class='absolute inset-0 bg-brand-gold/0 group-hover:bg-brand-gold transition-all duration-500 group-disabled:bg-transparent'
                aria-hidden='true'></span>
              <span class='relative flex items-center gap-2'>
                <span id='btn-text'>Request Appointment</span>
                <svg
                  id='btn-arrow'
                  class='w-5 h-5 transition-transform duration-300 group-hover:translate-x-1'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
                </svg>
                <svg
                  id='btn-spinner'
                  class='hidden w-5 h-5 animate-spin'
                  viewBox='0 0 24 24'
                  fill='none'
                >
                  <circle
                    class='opacity-25'
                    cx='12'
                    cy='12'
                    r='10'
                    stroke='currentColor'
                    stroke-width='4'></circle>
                  <path
                    class='opacity-75'
                    fill='currentColor'
                    d='M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z'
                  ></path>
                </svg>
              </span>
            </button>
          </div>

          <!-- Security note -->
          <p class='flex items-center gap-2 text-xs text-brand-blue/40 pt-1'>
            <svg
              class='w-4 h-4 text-green-500'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z'
              ></path>
            </svg>
            Your information is encrypted and secure.
          </p>
        </form>

        <!-- Success message (hidden) -->
        <div id='success-message' class='hidden'>
          <div class='text-center py-16'>
            <div
              class='w-20 h-20 rounded-full bg-green-50 flex items-center justify-center mx-auto mb-6'
            >
              <svg
                class='w-10 h-10 text-green-500'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                ></path>
              </svg>
            </div>
            <h3 class='text-2xl font-display italic text-brand-blue mb-3'>
              Request Sent!
            </h3>
            <p class='text-brand-blue/60 max-w-sm mx-auto'>
              Thank you for reaching out. Our team will get back to you within
              24 hours to confirm your appointment.
            </p>
          </div>
        </div>

        <!-- Error message (hidden) -->
        <div id='error-message' class='hidden mt-4'>
          <div
            class='bg-red-50 border border-red-100 rounded-xl p-4 flex items-start gap-3'
          >
            <svg
              class='w-5 h-5 text-red-500 flex-shrink-0 mt-0.5'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z'
              ></path>
            </svg>
            <p class='text-sm text-red-700'>
              Something went wrong. Please try again or call us at <a
                href='tel:8136092034'
                class='font-semibold underline'>(813) 609-2034</a
              >.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (!prefersReduced) {
    const heroTl = gsap.timeline({
      defaults: { ease: "power3.out", duration: 0.9 },
    });

    gsap.set([".hero-ornament", ".hero-title", ".hero-subtitle"], { y: 30 });

    heroTl
      .to(".hero-ornament", { opacity: 1, y: 0, duration: 0.6 })
      .to(".hero-title", { opacity: 1, y: 0 }, "-=0.4")
      .to(".hero-subtitle", { opacity: 1, y: 0, duration: 0.7 }, "-=0.5");

    gsap.to(".contact-ribbon", {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".contact-ribbon",
        start: "top 90%",
        once: true,
      },
    });

    gsap.to(".form-container", {
      opacity: 1,
      y: 0,
      duration: 0.9,
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".form-container",
        start: "top 85%",
        once: true,
      },
    });

    ScrollTrigger.create({
      trigger: ".form-container",
      start: "top 80%",
      once: true,
      onEnter: () => {
        gsap.from(".form-field", {
          y: 20,
          opacity: 0,
          stagger: 0.08,
          duration: 0.6,
          ease: "power2.out",
          delay: 0.3,
        });
      },
    });

    document
      .querySelectorAll<
        HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
      >("#contact-form input, #contact-form textarea, #contact-form select")
      .forEach((el) => {
        el.addEventListener("focus", () => {
          gsap.to(el, { scale: 1.015, duration: 0.25, ease: "power2.out" });
        });
        el.addEventListener("blur", () => {
          gsap.to(el, { scale: 1, duration: 0.2, ease: "power2.inOut" });
        });
      });
  }

  // FORM SUBMISSION LOGIC
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text")!;
  const btnArrow = document.getElementById("btn-arrow")!;
  const btnSpinner = document.getElementById("btn-spinner")!;
  const successMessage = document.getElementById("success-message")!;
  const errorMessage = document.getElementById("error-message")!;
  const hipaaError = document.getElementById("hipaa-error")!;
  const hipaaCheckbox = document.getElementById(
    "hipaaConsent",
  ) as HTMLInputElement;

  const API_BASE = import.meta.env.PUBLIC_HM_CMS_URL;

  hipaaCheckbox.addEventListener("change", () => {
    if (hipaaCheckbox.checked) {
      hipaaError.classList.add("hidden");
    }
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!hipaaCheckbox.checked) {
      hipaaError.classList.remove("hidden");
      hipaaCheckbox.focus();
      if (!prefersReduced) {
        gsap.fromTo(
          hipaaError,
          { x: -6 },
          { x: 0, duration: 0.4, ease: "elastic.out(1, 0.3)" },
        );
      }
      return;
    }

    const formData = new FormData(form);
    const payload = {
      name: (formData.get("name") as string).trim(),
      email: (formData.get("email") as string).trim(),
      phone: (formData.get("phone") as string).trim() || "",
      preferredDate: (formData.get("preferredDate") as string) || "",
      time: (formData.get("time") as string) || "",
      comment: (formData.get("comment") as string).trim() || "",
      hipaaConsent: true,
    };

    if (!payload.name || !payload.email) {
      return;
    }

    submitBtn.disabled = true;
    btnText.textContent = "Sending...";
    btnArrow.classList.add("hidden");
    btnSpinner.classList.remove("hidden");
    errorMessage.classList.add("hidden");

    try {
      const response = await fetch(`${API_BASE}/forms/contact`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`Server responded with ${response.status}`);
      }

      if (!prefersReduced) {
        gsap.to(form, {
          opacity: 0,
          y: -20,
          duration: 0.4,
          ease: "power2.in",
          onComplete: () => {
            form.classList.add("hidden");
            successMessage.classList.remove("hidden");
            gsap.from(successMessage, {
              opacity: 0,
              scale: 0.9,
              y: 20,
              duration: 0.6,
              ease: "back.out(1.4)",
            });
          },
        });
      } else {
        form.classList.add("hidden");
        successMessage.classList.remove("hidden");
      }
    } catch {
      errorMessage.classList.remove("hidden");
      if (!prefersReduced) {
        gsap.from(errorMessage, {
          opacity: 0,
          y: 10,
          duration: 0.4,
          ease: "power2.out",
        });
      }

      submitBtn.disabled = false;
      btnText.textContent = "Request Appointment";
      btnArrow.classList.remove("hidden");
      btnSpinner.classList.add("hidden");
    }
  });
</script>
