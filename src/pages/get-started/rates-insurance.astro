---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Get Started", url: `${siteUrl}/get-started` },
    {
      name: "Rates & Insurance",
      url: `${siteUrl}/get-started/rates-insurance`,
    },
  ]),
];
---

<Layout
  title='Rates & Insurance — Therapy Session Costs'
  description='View our therapy session rates, accepted insurance plans, payment options, and cancellation policy at Healthy Mind Specialists in Tampa, FL.'
  schema={schemas}
>
  <!-- HERO BANNER -->
  <section
    class='relative bg-brand-blue py-24 md:py-32 lg:py-40 overflow-hidden'
    aria-label='Rates and Insurance hero'
  >
    <img
      src='/images/contact-hero.jpg'
      alt='Welcoming office environment at Healthy Mind Specialists'
      width='1920'
      height='1280'
      loading='eager'
      fetchpriority='high'
      class='absolute inset-0 w-full h-full object-cover'
    />
    <div class='absolute inset-0 bg-brand-blue/70' aria-hidden='true'></div>
    <div
      class='absolute inset-0 opacity-[0.06] pointer-events-none'
      aria-hidden='true'
    >
      <div
        class='absolute -top-32 -left-32 w-[600px] h-[600px] bg-brand-gold rounded-full blur-[140px]'
      >
      </div>
      <div
        class='absolute -bottom-40 -right-20 w-[500px] h-[500px] bg-brand-gold-light rounded-full blur-[120px]'
      >
      </div>
    </div>
    <div
      class='absolute inset-0 opacity-[0.03]'
      style='background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;'
      aria-hidden='true'
    >
    </div>

    <div class='relative z-10 max-w-4xl mx-auto px-6 text-center'>
      <div
        class='hero-ornament flex items-center justify-center gap-3 mb-6 opacity-0'
        aria-hidden='true'
      >
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
        <span class='block w-2.5 h-2.5 rounded-full border border-brand-gold'
        ></span>
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
      </div>

      <h1
        class='hero-title text-4xl md:text-5xl lg:text-6xl font-display italic text-white leading-tight opacity-0'
      >
        Rates & <span class='text-brand-gold-light'>Insurance</span>
      </h1>

      <p
        class='hero-subtitle mt-5 text-white/65 text-base md:text-lg lg:text-xl max-w-2xl mx-auto font-sans leading-relaxed opacity-0'
      >
        Transparent pricing and flexible payment options to make mental health
        care accessible for you.
      </p>
    </div>
  </section>

  <!-- CONTENT SECTION -->
  <section
    class='py-20 md:py-28 lg:py-32 bg-white'
    aria-labelledby='rates-heading'
  >
    <div class='max-w-4xl mx-auto px-6'>
      <!-- Rates -->
      <div class='content-block mb-16'>
        <p
          class='text-xs uppercase tracking-[0.2em] text-brand-gold font-semibold mb-3'
        >
          Pricing
        </p>
        <h2
          id='rates-heading'
          class='text-3xl md:text-4xl font-display italic text-brand-blue leading-tight'
        >
          Session <span class='text-brand-gold'>Rates</span>
        </h2>
        <div class='w-12 h-[2px] bg-brand-gold mt-5' aria-hidden='true'></div>
      </div>

      <div class='grid grid-cols-1 md:grid-cols-2 gap-6 mb-16'>
        <!-- Psychologist -->
        <div
          class='rate-card bg-brand-cream/40 rounded-2xl p-8 border border-brand-gold/10 hover:border-brand-gold/30 hover:shadow-lg hover:shadow-brand-gold/5 transition-all duration-300'
        >
          <h3 class='font-display text-xl text-brand-blue mb-4'>
            Individual Therapy with a Psychologist
          </h3>
          <ul class='space-y-3'>
            <li class='flex items-center justify-between text-brand-blue/70'>
              <span>First Session</span>
              <span class='font-semibold text-brand-blue'>$250</span>
            </li>
            <li class='flex items-center justify-between text-brand-blue/70'>
              <span>Subsequent Sessions</span>
              <span class='font-semibold text-brand-blue'>$225</span>
            </li>
          </ul>
        </div>

        <!-- LMHC -->
        <div
          class='rate-card bg-brand-cream/40 rounded-2xl p-8 border border-brand-gold/10 hover:border-brand-gold/30 hover:shadow-lg hover:shadow-brand-gold/5 transition-all duration-300'
        >
          <h3 class='font-display text-xl text-brand-blue mb-4'>
            Individual Therapy with a LMHC
          </h3>
          <ul class='space-y-3'>
            <li class='flex items-center justify-between text-brand-blue/70'>
              <span>First Session</span>
              <span class='font-semibold text-brand-blue'>$200</span>
            </li>
            <li class='flex items-center justify-between text-brand-blue/70'>
              <span>Subsequent Sessions</span>
              <span class='font-semibold text-brand-blue'>$175</span>
            </li>
          </ul>
        </div>

        <!-- Evaluations -->
        <div
          class='rate-card bg-brand-cream/40 rounded-2xl p-8 border border-brand-gold/10 hover:border-brand-gold/30 hover:shadow-lg hover:shadow-brand-gold/5 transition-all duration-300'
        >
          <h3 class='font-display text-xl text-brand-blue mb-4'>
            Psychological Evaluations
          </h3>
          <p class='text-brand-blue/70'>
            <span class='font-semibold text-brand-blue'>$400 – $4,000</span>
          </p>
          <p class='text-sm text-brand-blue/50 mt-2 leading-relaxed'>
            Costs vary depending on the complexity of testing, including the
            number of assessment measures used and the time it takes to
            administer, score, and complete the write-up of the report.
          </p>
        </div>

        <!-- Life Coaching -->
        <div
          class='rate-card bg-brand-cream/40 rounded-2xl p-8 border border-brand-gold/10 hover:border-brand-gold/30 hover:shadow-lg hover:shadow-brand-gold/5 transition-all duration-300'
        >
          <h3 class='font-display text-xl text-brand-blue mb-4'>
            Life Coaching Sessions
          </h3>
          <ul class='space-y-3'>
            <li class='flex items-center justify-between text-brand-blue/70'>
              <span>Per Session</span>
              <span class='font-semibold text-brand-blue'>$100</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Payment -->
      <div class='content-block mb-16'>
        <h2
          class='text-2xl md:text-3xl font-display italic text-brand-blue leading-tight mb-4'
        >
          <span class='text-brand-gold'>Payment</span> Options
        </h2>
        <div class='w-12 h-[2px] bg-brand-gold mb-6' aria-hidden='true'></div>
        <p class='text-brand-blue/60 leading-relaxed text-lg'>
          We accept cash, checks, and all major credit cards as forms of
          payment.
        </p>
      </div>

      <!-- Insurance -->
      <div class='content-block mb-16'>
        <h2
          class='text-2xl md:text-3xl font-display italic text-brand-blue leading-tight mb-4'
        >
          <span class='text-brand-gold'>Insurance</span> Information
        </h2>
        <div class='w-12 h-[2px] bg-brand-gold mb-6' aria-hidden='true'></div>
        <p class='text-brand-blue/60 leading-relaxed text-lg mb-6'>
          We currently accept <strong class='text-brand-blue'>Aetna</strong>,
          <strong class='text-brand-blue'>United Healthcare</strong>,
          <strong class='text-brand-blue'>Oscar Health</strong>, and
          <strong class='text-brand-blue'>Oxford</strong>.
        </p>
        <p class='text-brand-blue/60 leading-relaxed mb-6'>
          If you have another insurance provider or an employee benefit plan, it
          is still possible for services to be covered in full or in part.
          Please contact your provider to verify how your plan compensates you
          for psychotherapy services.
        </p>
        <p class='text-brand-blue/60 leading-relaxed mb-4'>
          We recommend asking these questions to your insurance provider to help
          determine your benefits:
        </p>
        <ul class='space-y-3 text-brand-blue/60 leading-relaxed pl-1'>
          <li class='flex items-start gap-3'>
            <span
              class='block w-2 h-2 rounded-full bg-brand-gold flex-shrink-0 mt-2'
            ></span>
            <span
              >Does my health insurance plan include mental health benefits? If
              so, does it reimburse for out-of-network providers?</span
            >
          </li>
          <li class='flex items-start gap-3'>
            <span
              class='block w-2 h-2 rounded-full bg-brand-gold flex-shrink-0 mt-2'
            ></span>
            <span
              >Do I have a deductible? If so, what is it and have I met it yet?</span
            >
          </li>
          <li class='flex items-start gap-3'>
            <span
              class='block w-2 h-2 rounded-full bg-brand-gold flex-shrink-0 mt-2'
            ></span>
            <span
              >Does my plan limit how many sessions per calendar year I can
              have? If so, what is the limit?</span
            >
          </li>
          <li class='flex items-start gap-3'>
            <span
              class='block w-2 h-2 rounded-full bg-brand-gold flex-shrink-0 mt-2'
            ></span>
            <span
              >Do I need written approval from my primary care physician in
              order for services to be covered?</span
            >
          </li>
        </ul>
      </div>

      <!-- Cancellation Policy -->
      <div class='content-block mb-16'>
        <h2
          class='text-2xl md:text-3xl font-display italic text-brand-blue leading-tight mb-4'
        >
          Cancellation <span class='text-brand-gold'>Policy</span>
        </h2>
        <div class='w-12 h-[2px] bg-brand-gold mb-6' aria-hidden='true'></div>
        <p class='text-brand-blue/60 leading-relaxed text-lg'>
          If you are unable to attend a session, please make sure you cancel at
          least 24 hours beforehand. There is a
          <strong class='text-brand-blue'>$125 charge</strong> for appointments canceled
          with less than 24 hours' notice.
        </p>
      </div>

      <!-- CTA -->
      <div
        class='bg-brand-cream/60 rounded-2xl p-10 border border-brand-gold/10 text-center'
      >
        <h2
          class='text-2xl md:text-3xl font-display italic text-brand-blue leading-tight mb-4'
        >
          Any Other <span class='text-brand-gold'>Questions?</span>
        </h2>
        <p class='text-brand-blue/60 leading-relaxed mb-8 max-w-xl mx-auto'>
          Please contact us with any additional questions you may have. We look
          forward to hearing from you!
        </p>
        <a
          href='/contact'
          class='inline-flex items-center gap-3 px-10 py-4 bg-brand-blue text-white font-semibold tracking-wide rounded-xl transition-all duration-500 hover:shadow-xl hover:shadow-brand-blue/20 hover:-translate-y-0.5 hover:bg-brand-gold'
        >
          Contact Us
          <svg
            class='w-5 h-5 transition-transform duration-300 group-hover:translate-x-1'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='2'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (!prefersReduced) {
    const heroTl = gsap.timeline({
      defaults: { ease: "power3.out", duration: 0.9 },
    });

    gsap.set([".hero-ornament", ".hero-title", ".hero-subtitle"], { y: 30 });

    heroTl
      .to(".hero-ornament", { opacity: 1, y: 0, duration: 0.6 })
      .to(".hero-title", { opacity: 1, y: 0 }, "-=0.4")
      .to(".hero-subtitle", { opacity: 1, y: 0, duration: 0.7 }, "-=0.5");

    ScrollTrigger.batch(".rate-card", {
      start: "top 90%",
      once: true,
      onEnter: (batch) => {
        gsap.fromTo(
          batch,
          { y: 20, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            stagger: 0.12,
            duration: 0.6,
            ease: "power2.out",
          },
        );
      },
    });

    ScrollTrigger.batch(".content-block", {
      start: "top 90%",
      once: true,
      onEnter: (batch) => {
        gsap.fromTo(
          batch,
          { y: 20, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            stagger: 0.15,
            duration: 0.7,
            ease: "power2.out",
          },
        );
      },
    });
  }
</script>
