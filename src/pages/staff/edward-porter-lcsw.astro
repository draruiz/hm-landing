---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";
const staffName = "Edward Porter, LCSW";
const staffRole = "Licensed Clinical Social Worker";
const staffSlug = "edward-porter-lcsw";
const bannerImage =
  "https://brightervisionclients.com/resize/63bd841c407b4bb641b23b5b/attachments/d5d772f4-b484-4320-b7d7-9946dd7e3dba?top=0.0000&left=0.0000&bottom=1.0000&right=1.0000";
const tagline =
  "Helping you navigate life's challenges with compassion, insight, and practical support.";
const profileImage =
  "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/4d62b896-9a42-4628-4cff-d32dfb4bca00/public";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "About Us", url: `${siteUrl}/about` },
    { name: staffName, url: `${siteUrl}/staff/${staffSlug}` },
  ]),
];
---

<Layout
  title={staffName}
  description={`Meet ${staffName}, ${staffRole} at Healthy Mind Specialists in Tampa, FL. Specializing in anxiety, depression, relationship concerns, stress, and major life transitions.`}
  schema={schemas}
>
  <!-- Hero Banner -->
  <section class='relative h-[420px] md:h-[500px] overflow-hidden'>
    <img
      src={bannerImage}
      alt={`Portrait of ${staffName}, ${staffRole} at Healthy Mind Specialists`}
      width='1920'
      height='600'
      class='absolute inset-0 w-full h-full object-cover'
      loading='eager'
    />
    <div
      class='absolute inset-0 bg-gradient-to-r from-brand-blue/80 to-brand-blue/40'
    >
    </div>
    <div class='relative h-full flex items-center'>
      <div class='max-w-4xl mx-auto px-6 text-white'>
        <h1 class='text-4xl md:text-5xl lg:text-6xl font-display italic mb-4'>
          {staffName}
        </h1>
        <p class='text-xl md:text-2xl text-white/80 max-w-2xl'>
          {staffRole}
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class='py-20 md:py-28'>
    <div class='max-w-4xl mx-auto px-6'>
      <!-- Profile + Tagline -->
      <div class='mb-12 md:flex md:items-start md:gap-10'>
        <img
          src={profileImage}
          alt={`${staffName}, ${staffRole}`}
          width='280'
          height='280'
          class='w-48 h-48 md:w-64 md:h-64 rounded-2xl object-cover shadow-lg mb-6 md:mb-0 mx-auto md:mx-0 flex-shrink-0'
          loading='lazy'
        />
        <div>
          <p
            class='text-2xl md:text-3xl font-display italic text-brand-blue/80'
          >
            {tagline}
          </p>
          <span class='block w-16 h-[2px] bg-brand-gold mt-6'></span>
        </div>
      </div>

      <!-- Bio Content -->
      <div class='prose prose-lg max-w-none text-brand-blue/80 space-y-6'>
        <p>
          Reaching out for therapy can feel like a big step, especially when
          life feels overwhelming or uncertain. If you are navigating anxiety,
          depression, relationship concerns, stress, or major life transitions,
          therapy can offer a supportive space to pause, reflect, and begin
          making sense of what you are carrying.
        </p>
        <p>
          I work with adolescents and adults who are feeling stuck, emotionally
          drained, or caught in patterns that no longer serve them. My goal is
          to provide a nonjudgmental, compassionate environment where you can
          feel heard and understood while gaining insight into your experiences
          and learning practical tools to create meaningful change.
        </p>
        <p>
          My approach is collaborative and individualized. I believe therapy
          works best when it honors the whole person, not just the symptoms. I
          integrate evidence-based approaches such as cognitive behavioral
          therapy, psychodynamic therapy, mindfulness-based practices, and
          logotherapy, tailoring our work to your unique history, values, and
          goals.
        </p>
        <p>
          Therapy is not about fixing you. It is about understanding yourself
          more deeply, building self-awareness, and strengthening your ability
          to navigate life with intention and clarity. Whether you are feeling
          overwhelmed, seeking balance, or hoping to reconnect with yourself in
          a more grounded way, I will work alongside you to support growth,
          resilience, and healing.
        </p>
        <p>
          You do not have to navigate this alone. When you are ready, I am here
          to help you take that next step.
        </p>
      </div>

      <!-- CTA -->
      <div class='mt-16 text-center'>
        <a
          href='/contact'
          class='inline-flex items-center px-8 py-4 bg-brand-blue text-white font-semibold rounded-full hover:bg-brand-blue-light transition-all duration-300 shadow-lg hover:shadow-xl'
        >
          Schedule a Consultation
        </a>
      </div>
    </div>
  </section>
</Layout>
