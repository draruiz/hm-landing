---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Our Services", url: `${siteUrl}/#services` },
    { name: "Integrative Care", url: `${siteUrl}/services/integrative-care` },
  ]),
];
---

<Layout
  title='Integrative Care'
  description='An integrative approach to psychological care addressing mental, emotional, physical, social, and spiritual needs tailored to you.'
  schema={schemas}
>
  <!-- Hero Banner -->
  <section class='relative h-[420px] md:h-[500px] overflow-hidden'>
    <img
      src='https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?w=1920&h=600&fit=crop&q=80'
      alt='Sunlit green leaves representing integrative holistic care at Healthy Mind Specialists'
      width='1920'
      height='600'
      class='absolute inset-0 w-full h-full object-cover'
      loading='eager'
    />
    <div
      class='absolute inset-0 bg-gradient-to-r from-brand-blue/80 to-brand-blue/40'
    >
    </div>
    <div class='relative h-full flex items-center'>
      <div class='max-w-4xl mx-auto px-6 text-white'>
        <h1 class='text-4xl md:text-5xl lg:text-6xl font-display italic mb-4'>
          Integrative Care
        </h1>
        <p class='text-xl md:text-2xl text-white/80 max-w-2xl'>
          A holistic approach to your mental health — personalized to who you
          are.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class='py-20 md:py-28'>
    <div class='max-w-4xl mx-auto px-6'>
      <!-- Why Integrative -->
      <div class='mb-16'>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-6'
        >
          Why Integrative Psychological Services?
        </h2>
        <div class='space-y-5 text-lg text-brand-blue/70 leading-relaxed'>
          <p>
            An integrative approach considers all aspects of a person's health
            and lifestyle that can influence treatment outcomes. This includes
            not only mental and emotional concerns, but also biological,
            physical, social, behavioral, and spiritual needs.
          </p>
          <p>
            Therapy focuses on identifying and tailoring treatment approaches to
            the unique needs of the individual. There is not one therapeutic
            approach that can be effective or appropriate for all individuals
            and the challenges they face.
          </p>
        </div>
      </div>

      <!-- Image break -->
      <div class='mb-16 rounded-2xl overflow-hidden shadow-lg'>
        <img
          src='https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1200&h=500&fit=crop&q=80'
          alt='Person meditating in nature representing holistic integrative mental health care'
          width='1200'
          height='500'
          loading='lazy'
          class='w-full h-[300px] md:h-[400px] object-cover'
        />
      </div>

      <!-- What We Offer -->
      <div class='mb-16'>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-6'
        >
          What Our Integrative Approach Includes
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
          {
            [
              {
                title: "Evidence-Based Therapies",
                desc: "Cognitive behavioral therapy, EMDR, and other proven modalities tailored to your needs.",
              },
              {
                title: "Mind-Body Connection",
                desc: "Addressing physical health factors that impact mental well-being and vice versa.",
              },
              {
                title: "Social & Relational Health",
                desc: "Improving relationships, communication, and social connections as part of healing.",
              },
              {
                title: "Behavioral Strategies",
                desc: "Practical tools and coping skills you can apply in your daily life right away.",
              },
              {
                title: "Spiritual Wellness",
                desc: "Honoring your beliefs and values as an integral part of the therapeutic process.",
              },
              {
                title: "Personalized Treatment",
                desc: "No cookie-cutter approaches — every plan is designed specifically for you.",
              },
            ].map((item) => (
              <div class='bg-brand-cream/50 rounded-xl p-6 border border-brand-blue/5'>
                <h3 class='text-lg font-display text-brand-blue mb-2'>
                  {item.title}
                </h3>
                <p class='text-brand-blue/60 text-sm leading-relaxed'>
                  {item.desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- CTA -->
      <div
        class='text-center bg-brand-cream/60 rounded-2xl p-10 md:p-14 border border-brand-blue/5'
      >
        <h2
          class='text-2xl md:text-3xl font-display italic text-brand-blue mb-4'
        >
          Ready to Get Started?
        </h2>
        <p class='text-brand-blue/60 mb-8 max-w-xl mx-auto'>
          Let's get started with an individualized approach to helping you live
          the life you desire.
        </p>
        <a
          href='/contact'
          class='inline-flex items-center px-8 py-4 text-base font-semibold rounded-full border-2 border-brand-blue text-brand-blue hover:bg-brand-blue hover:text-white transition-all duration-300'
        >
          Contact Us
          <svg
            class='w-5 h-5 ml-2'
            fill='none'
            viewBox='0 0 24 24'
            stroke-width='2'
            stroke='currentColor'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
