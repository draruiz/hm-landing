---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Our Services", url: `${siteUrl}/#services` },
    {
      name: "Online ADHD Evaluations",
      url: `${siteUrl}/services/online-adhd-evaluations`,
    },
  ]),
];

const packages = [
  {
    name: "ADHD Snapshot",
    price: "$295",
    tagline: "Quick and self-guided.",
    description: "A streamlined screener for straightforward cases.",
    items: [
      "Asynchronous process completed independently",
      "Screening tools for attention, cognition, and mood",
      "Compiled assessment results with brief diagnostic summary (if criteria are clearly met)",
      "No live interview or feedback session",
      "Optional upgrade to Abbreviated, Standard, or Comprehensive Evaluation (full fee credited)",
    ],
    bestFor:
      "Clarity around attention-related concerns when no documentation is required.",
    accent: "brand-gold/10",
  },
  {
    name: "Abbreviated ADHD Evaluation",
    price: "$595",
    tagline: "Efficient, clinically reviewed documentation.",
    description:
      "For those needing concise documentation and clinical confirmation.",
    items: [
      "Brief live diagnostic interview",
      "Screening tools for attention, cognition, and mood",
      "Diagnostic letter (1–2 pages) with diagnosis if supported",
      "General treatment or accommodation recommendations if appropriate",
      "Optional upgrade to Standard or Comprehensive Evaluation (full fee credited)",
    ],
    bestFor:
      "Medication support, short-form documentation, or diagnostic clarity with a live clinician.",
    accent: "brand-teal/10",
  },
  {
    name: "Standard ADHD Evaluation",
    price: "$1,295",
    tagline: "Full psychological evaluation.",
    description:
      "A full psychological evaluation with functional insight and formal documentation.",
    featured: true,
    items: [
      "Live diagnostic interview and intake screening",
      "Measures of attention, executive functioning, mood, personality, and adaptive functioning",
      "One-on-one feedback session",
      "Comprehensive psychological report (4–6 pages) with clinical rationale and recommendations",
      "Optional upgrade to Comprehensive Evaluation (full fee credited)",
    ],
    bestFor:
      "Academic or workplace accommodations, FMLA, and coordinated treatment planning.",
    accent: "brand-blue/10",
  },
  {
    name: "Comprehensive ADHD Evaluation",
    price: "$1,600",
    tagline: "In-depth diagnostic clarity.",
    description: "For more complex cases and broader differential diagnosis.",
    items: [
      "All components of the Standard Evaluation",
      "Additional screening measures for possible comorbidities (e.g., autism traits, OCD patterns, trauma-related features)",
      "Extended interpretation and customized recommendations in final report",
    ],
    addOns: [
      "Expanded ASD Battery",
      "Expanded OCD Battery",
      "Expanded Symptom Measures for trauma, emotional dysregulation, or complex presentations",
    ],
    bestFor:
      "Clients with multi-domain symptoms or documentation needs requiring a more in-depth clinical analysis.",
    accent: "brand-gold/10",
  },
];

const setsUsApart = [
  {
    title: "Clinical Oversight",
    text: "Every step of the process is guided by a psychologist. From intake to diagnosis, your results are professionally reviewed and signed.",
    icon: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
  },
  {
    title: "Validated Assessment Tools",
    text: "We use evidence-based measures to evaluate attention, executive functioning, mood, personality, and adaptive behavior.",
    icon: "M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z",
  },
  {
    title: "Flexible, Tiered Options",
    text: "Whether you're looking for a brief screener or full documentation, we offer four levels of assessment to meet your needs and budget.",
    icon: "M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z",
  },
  {
    title: "Fully Online. Fully Ethical.",
    text: "Our process is convenient, secure, and HIPAA-compliant — with the same integrity you'd expect in a clinical office.",
    icon: "M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z",
  },
];
---

<Layout
  title='Online ADHD Evaluations'
  description='Comprehensive online ADHD evaluations led by licensed psychologists. Four tiers from screener to full evaluation — convenient, secure, and HIPAA-compliant.'
  schema={schemas}
>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO — Clean title section                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='relative overflow-hidden bg-brand-blue' id='adhd-hero'>
    <!-- Background image -->
    <img
      src='https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1920&h=1080&fit=crop&q=80'
      alt=''
      width='1920'
      height='1080'
      class='absolute inset-0 w-full h-full object-cover'
      loading='eager'
      fetchpriority='high'
      aria-hidden='true'
    />
    <div class='absolute inset-0 bg-brand-blue/70'></div>
    <!-- Ambient glow -->
    <div
      class='absolute inset-0 opacity-[0.06] pointer-events-none'
      aria-hidden='true'
    >
      <div
        class='absolute -top-32 -left-32 w-[600px] h-[600px] bg-brand-gold rounded-full blur-[140px]'
      >
      </div>
      <div
        class='absolute -bottom-40 -right-20 w-[500px] h-[500px] bg-brand-teal rounded-full blur-[120px]'
      >
      </div>
    </div>
    <!-- Grid overlay -->
    <div
      class='absolute inset-0 opacity-[0.03]'
      style='background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;'
      aria-hidden='true'
    >
    </div>

    <div
      class='relative z-10 max-w-5xl mx-auto px-6 pt-36 pb-24 md:pt-44 md:pb-32 text-center'
    >
      <!-- Gold ornament -->
      <div
        class='hero-ornament flex items-center justify-center gap-3 mb-6'
        aria-hidden='true'
      >
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
        <span class='block w-2.5 h-2.5 rounded-full border border-brand-gold'
        ></span>
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
      </div>

      <h1
        class='hero-title text-4xl md:text-6xl lg:text-7xl font-display italic text-white leading-tight'
      >
        Online ADHD<br />
        <span class='text-brand-gold-light'>Evaluations</span>
      </h1>

      <p
        class='hero-subtitle mt-6 text-white/65 text-lg md:text-xl lg:text-2xl max-w-3xl mx-auto font-sans leading-relaxed'
      >
        Backed by licensed psychologists — convenient, secure, and
        HIPAA-compliant.
      </p>

      <div class='hero-cta mt-10'>
        <a
          href='/contact'
          class='inline-flex items-center px-8 py-4 text-base font-semibold rounded-full bg-brand-gold text-brand-blue hover:bg-brand-gold-light transition-all duration-300'
        >
          Get Started Today
          <svg
            class='w-5 h-5 ml-2'
            fill='none'
            viewBox='0 0 24 24'
            stroke-width='2'
            stroke='currentColor'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- INTRO — Split image + text                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='py-24 md:py-36 overflow-hidden'>
    <div class='max-w-7xl mx-auto px-6'>
      <div class='grid lg:grid-cols-2 gap-12 lg:gap-20 items-center'>
        <!-- Image -->
        <div class='reveal-left relative'>
          <div class='rounded-3xl overflow-hidden shadow-2xl'>
            <img
              src='https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&h=1000&fit=crop&q=80'
              alt='Person working on a laptop during an online ADHD evaluation from a comfortable home setting'
              width='800'
              height='1000'
              loading='lazy'
              class='w-full h-[400px] md:h-[550px] object-cover'
            />
          </div>
          <div
            class='absolute -bottom-6 -right-6 w-48 h-48 bg-brand-teal/15 rounded-3xl -z-10'
            aria-hidden='true'
          >
          </div>
          <div
            class='absolute -top-6 -left-6 w-32 h-32 border-2 border-brand-gold/20 rounded-3xl -z-10'
            aria-hidden='true'
          >
          </div>
        </div>

        <!-- Text -->
        <div class='reveal-right'>
          <span
            class='inline-block text-sm font-semibold text-brand-gold uppercase tracking-widest mb-4'
            >By Licensed Psychologists</span
          >
          <h2
            class='text-3xl md:text-4xl lg:text-5xl font-display italic text-brand-blue mb-6 leading-tight'
          >
            Online ADHD Evaluations
          </h2>
          <div class='space-y-5 text-lg text-brand-blue/70 leading-relaxed'>
            <p>
              If you're struggling with focus, mental overwhelm, or feeling like
              you're constantly falling short despite working hard, you're not
              alone. We offer comprehensive ADHD assessments designed for adults
              who want answers, without sacrificing quality for convenience.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- REAL EVALUATION — Alternating layout                       -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='py-24 md:py-36 bg-brand-cream/40 overflow-hidden'>
    <div class='max-w-7xl mx-auto px-6'>
      <div class='grid lg:grid-cols-2 gap-12 lg:gap-20 items-center'>
        <!-- Text -->
        <div class='reveal-left order-2 lg:order-1'>
          <span
            class='inline-block text-sm font-semibold text-brand-gold uppercase tracking-widest mb-4'
            >Clinical Standards</span
          >
          <h2
            class='text-3xl md:text-4xl lg:text-5xl font-display italic text-brand-blue mb-6 leading-tight'
          >
            A Real Evaluation,<br />Not Just a Quiz
          </h2>
          <div class='space-y-5 text-lg text-brand-blue/70 leading-relaxed'>
            <p>
              Unlike automated platforms that rely solely on questionnaires, our
              process is led and reviewed by licensed psychologists. Whether
              you're seeking a diagnosis for personal insight, medication,
              accommodations, or documentation, we provide a tailored experience
              that meets clinical and professional standards.
            </p>
          </div>
        </div>

        <!-- Image -->
        <div class='reveal-right order-1 lg:order-2 relative'>
          <div class='rounded-3xl overflow-hidden shadow-2xl'>
            <img
              src='https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800&h=1000&fit=crop&q=80'
              alt='Clinical professional reviewing ADHD evaluation results with precision and care'
              width='800'
              height='1000'
              loading='lazy'
              class='w-full h-[400px] md:h-[550px] object-cover'
            />
          </div>
          <div
            class='absolute -bottom-6 -left-6 w-48 h-48 bg-brand-gold/10 rounded-3xl -z-10'
            aria-hidden='true'
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- WHAT SETS US APART — Floating cards with icons              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='py-24 md:py-36 overflow-hidden'>
    <div class='max-w-7xl mx-auto px-6'>
      <div class='text-center mb-16 md:mb-20'>
        <span
          class='inline-block text-sm font-semibold text-brand-gold uppercase tracking-widest mb-4'
          >Our Difference</span
        >
        <h2
          class='text-3xl md:text-4xl lg:text-5xl font-display italic text-brand-blue leading-tight'
        >
          What Sets Us Apart
        </h2>
      </div>

      <div class='grid sm:grid-cols-2 lg:grid-cols-4 gap-8'>
        {
          setsUsApart.map((item, i) => (
            <div
              class={`apart-card group bg-white rounded-2xl p-6 border border-brand-blue/5 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 ${i % 2 === 1 ? "sm:translate-y-6" : ""}`}
            >
              <div class='w-14 h-14 rounded-2xl bg-brand-gold/10 flex items-center justify-center mb-5 group-hover:bg-brand-gold/20 transition-colors'>
                <svg
                  class='w-7 h-7 text-brand-gold'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d={item.icon}
                  />
                </svg>
              </div>
              <h3 class='text-lg font-semibold text-brand-blue mb-2 group-hover:text-brand-gold transition-colors'>
                {item.title}
              </h3>
              <p class='text-brand-blue/70 text-sm leading-relaxed'>
                {item.text}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- WHAT YOU RECEIVE — With image                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='py-24 md:py-36 bg-brand-cream/40 overflow-hidden'>
    <div class='max-w-7xl mx-auto px-6'>
      <div class='grid lg:grid-cols-2 gap-12 lg:gap-20 items-center'>
        <!-- Image -->
        <div class='reveal-left relative'>
          <div class='rounded-3xl overflow-hidden shadow-2xl'>
            <img
              src='https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&h=1000&fit=crop&q=80'
              alt='Detailed psychological report and clinical documentation for ADHD evaluation'
              width='800'
              height='1000'
              loading='lazy'
              class='w-full h-[400px] md:h-[550px] object-cover'
            />
          </div>
          <div
            class='absolute -bottom-6 -right-6 w-48 h-48 bg-brand-teal/15 rounded-3xl -z-10'
            aria-hidden='true'
          >
          </div>
        </div>

        <!-- Text -->
        <div class='reveal-right'>
          <span
            class='inline-block text-sm font-semibold text-brand-gold uppercase tracking-widest mb-4'
            >Your Results</span
          >
          <h2
            class='text-3xl md:text-4xl lg:text-5xl font-display italic text-brand-blue mb-8 leading-tight'
          >
            What You Will Receive
          </h2>
          <ul class='space-y-5'>
            {
              [
                "A structured, online assessment process guided by real clinicians",
                "Normed tools that assess symptoms across multiple domains",
                "Screening for conditions that may resemble ADHD (e.g., anxiety, autism traits, OCD)",
                "A diagnostic letter or full psychological report — depending on your selected evaluation tier",
                "Personalized feedback and practical recommendations",
                "Optional referrals for psychiatric medication or therapy",
              ].map((item) => (
                <li class='flex items-start gap-4 text-brand-blue/70'>
                  <div class='w-6 h-6 rounded-full bg-brand-gold/15 flex items-center justify-center shrink-0 mt-0.5'>
                    <svg
                      class='w-3.5 h-3.5 text-brand-gold'
                      fill='none'
                      viewBox='0 0 24 24'
                      stroke-width='2.5'
                      stroke='currentColor'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        d='M4.5 12.75l6 6 9-13.5'
                      />
                    </svg>
                  </div>
                  <span class='leading-relaxed'>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- FULL-WIDTH IMAGE BREAK + QUOTE                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='relative h-[50vh] md:h-[60vh] overflow-hidden parallax-image'>
    <img
      src='https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1920&h=900&fit=crop&q=80'
      alt='Serene morning landscape representing clarity and focus after ADHD evaluation'
      width='1920'
      height='900'
      loading='lazy'
      class='absolute inset-0 w-full h-full object-cover'
    />
    <div class='absolute inset-0 bg-brand-blue/55'></div>
    <div
      class='relative h-full flex items-center justify-center text-center px-6'
    >
      <div class='reveal-up max-w-4xl'>
        <p
          class='text-sm font-semibold text-brand-gold uppercase tracking-widest mb-6'
        >
          Four Levels of Assessment
        </p>
        <p
          class='text-2xl md:text-3xl lg:text-4xl font-display italic text-white leading-snug'
        >
          From a quick screener to a full psychological evaluation — choose the
          level of depth that fits your needs.
        </p>
        <p class='text-white/60 text-base md:text-lg mt-6 max-w-2xl mx-auto'>
          All packages include a written intake screening and are reviewed by a
          licensed psychologist. Upgrade within 30 days with full credit.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- PACKAGES — Premium pricing cards                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='py-24 md:py-36 overflow-hidden'>
    <div class='max-w-7xl mx-auto px-6'>
      <div class='text-center mb-16 md:mb-20'>
        <span
          class='inline-block text-sm font-semibold text-brand-gold uppercase tracking-widest mb-4'
          >Packages</span
        >
        <h2
          class='text-3xl md:text-4xl lg:text-5xl font-display italic text-brand-blue leading-tight'
        >
          ADHD Evaluation Packages
        </h2>
      </div>

      <div class='grid md:grid-cols-2 gap-8'>
        {
          packages.map((pkg) => (
            <div
              class={`pkg-card group bg-white rounded-2xl overflow-hidden shadow-sm border hover:shadow-xl transition-all duration-500 flex flex-col ${pkg.featured ? "border-brand-gold/40 ring-2 ring-brand-gold/20" : "border-brand-blue/5"}`}
            >
              {/* Featured badge */}
              {pkg.featured && (
                <div class='bg-brand-gold text-brand-blue text-xs font-bold uppercase tracking-widest text-center py-2'>
                  Most Popular
                </div>
              )}

              <div class='p-8 flex flex-col flex-1'>
                <div class='mb-6'>
                  <p class='text-sm font-semibold text-brand-gold uppercase tracking-wide mb-1'>
                    {pkg.tagline}
                  </p>
                  <h3 class='text-xl md:text-2xl font-display italic text-brand-blue'>
                    {pkg.name}
                  </h3>
                  <div class='flex items-baseline gap-2 mt-3'>
                    <p class='text-4xl font-bold text-brand-blue'>
                      {pkg.price}
                    </p>
                  </div>
                  <p class='text-brand-blue/60 mt-2 text-sm'>
                    {pkg.description}
                  </p>
                </div>

                <div class='h-[1px] bg-brand-blue/10 mb-6' />

                <ul class='space-y-3 mb-6 flex-1'>
                  {pkg.items.map((item) => (
                    <li class='flex items-start gap-3 text-brand-blue/70 text-sm'>
                      <div class='w-5 h-5 rounded-full bg-brand-gold/15 flex items-center justify-center shrink-0 mt-0.5'>
                        <svg
                          class='w-3 h-3 text-brand-gold'
                          fill='none'
                          viewBox='0 0 24 24'
                          stroke-width='2.5'
                          stroke='currentColor'
                        >
                          <path
                            stroke-linecap='round'
                            stroke-linejoin='round'
                            d='M4.5 12.75l6 6 9-13.5'
                          />
                        </svg>
                      </div>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>

                {pkg.addOns && (
                  <div class='mb-6 pt-4 border-t border-brand-blue/10'>
                    <p class='text-sm font-semibold text-brand-blue mb-3'>
                      Optional Add-Ons:
                    </p>
                    <ul class='space-y-2'>
                      {pkg.addOns.map((addon) => (
                        <li class='flex items-start gap-2 text-brand-blue/60 text-sm'>
                          <span class='text-brand-gold font-bold mt-0.5'>
                            +
                          </span>
                          <span>{addon}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div class='bg-brand-cream/60 rounded-xl p-4 mt-auto'>
                  <p class='text-sm text-brand-blue/70'>
                    <span class='font-semibold text-brand-blue'>
                      Best for:{" "}
                    </span>
                    {pkg.bestFor}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <p
        class='text-center text-brand-blue/60 mt-12 max-w-3xl mx-auto text-sm leading-relaxed'
      >
        All evaluations are conducted remotely, include a written intake
        screening, and are reviewed and signed by a licensed psychologist. You
        can upgrade to a higher tier within 30 days and receive full credit
        toward the new evaluation.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CTA — Immersive final section                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='relative py-32 md:py-44 overflow-hidden'>
    <img
      src='https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1920&h=800&fit=crop&q=80'
      alt='Mountain landscape at dawn representing clarity and new beginnings after ADHD evaluation'
      width='1920'
      height='800'
      loading='lazy'
      class='absolute inset-0 w-full h-full object-cover'
    />
    <div class='absolute inset-0 bg-brand-blue/75'></div>
