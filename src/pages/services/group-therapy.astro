---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Our Services", url: `${siteUrl}/#services` },
    { name: "Group Therapy", url: `${siteUrl}/services/group-therapy` },
  ]),
];
---

<Layout
  title='Group Therapy'
  description='Therapist-guided group therapy sessions for anxiety, grief, and more — find connection, support, and growth through shared experiences.'
  schema={schemas}
>
  <!-- Hero Banner -->
  <section class='relative h-[420px] md:h-[500px] overflow-hidden'>
    <img
      src='https://images.unsplash.com/photo-1473116763249-2faaef81ccda?w=1920&h=600&fit=crop&q=80'
      alt='Sandy beach and gentle waves representing group therapy connection and community'
      width='1920'
      height='600'
      class='absolute inset-0 w-full h-full object-cover'
      loading='eager'
    />
    <div
      class='absolute inset-0 bg-gradient-to-r from-brand-blue/80 to-brand-blue/40'
    >
    </div>
    <div class='relative h-full flex items-center'>
      <div class='max-w-4xl mx-auto px-6 text-white'>
        <h1 class='text-4xl md:text-5xl lg:text-6xl font-display italic mb-4'>
          Group Therapy
        </h1>
        <p class='text-xl md:text-2xl text-white/80 max-w-2xl'>
          Healing together — find strength in shared experiences.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class='py-20 md:py-28'>
    <div class='max-w-4xl mx-auto px-6'>
      <!-- Intro -->
      <div class='mb-16'>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-6'
        >
          Is Group Therapy Right for You?
        </h2>
        <div class='space-y-5 text-lg text-brand-blue/70 leading-relaxed'>
          <p>
            Are you having a difficult time handling the struggles in your life?
            Could you use a non-judgmental ear to listen, somebody who really
            understands what you're going through? Do you wish you had more of a
            sense of community in your life, instead of feeling alone?
          </p>
          <p>
            If you answered "yes" to any of these questions, then group therapy
            could be the solution you've been seeking. Group therapy differs
            from individual therapy by holding therapeutic sessions in a group
            setting run by a therapist instead of in a private one-on-one
            setting. In these group sessions, patients share their thoughts and
            experiences with the whole group, allowing them to support one
            another while being supported by a group of people who understand
            what they're going through.
          </p>
          <p>
            If you've been feeling hopeless or alone lately, or struggling with
            a problem in your life that feels unsurmountable, group therapy
            could help you improve your everyday life. Group therapy helps you
            find a sense of community with others who are going through similar
            things while giving you access to valuable therapy that can truly
            help you feel better.
          </p>
        </div>
      </div>

      <!-- Signs section -->
      <div class='mb-16'>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-6'
        >
          Signs Group Therapy Could Help
        </h2>
        <div
          class='bg-brand-cream/50 rounded-2xl p-8 md:p-10 border border-brand-blue/5'
        >
          <ul class='space-y-4'>
            {
              [
                "You keep worrying about the same problem over and over",
                "You wish you could trust someone with your secret struggle",
                "You want to stop feeling so alone in what you're going through",
                "You're interested in therapy, but want to try something lower pressure than individual therapy",
                "You wish you felt more understood by others",
                "You're looking for expert help improving your life",
              ].map((item) => (
                <li class='flex items-start gap-3 text-brand-blue/70'>
                  <svg
                    class='w-5 h-5 text-brand-gold mt-1 shrink-0'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke-width='2'
                    stroke='currentColor'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d='M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                    />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Image break -->
      <div class='mb-16 rounded-2xl overflow-hidden shadow-lg'>
        <img
          src='https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1200&h=500&fit=crop&q=80'
          alt='Group of people connecting and supporting each other in a therapeutic environment'
          width='1200'
          height='500'
          loading='lazy'
          class='w-full h-[300px] md:h-[400px] object-cover'
        />
      </div>

      <!-- Current Groups -->
      <div class='mb-16'>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-6'
        >
          Current Groups
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-6'>
          {
            [
              {
                title: "Pet Grief",
                desc: "Let us help you find meaning after the death of your pet.",
              },
              {
                title: "Anxiety & Panic Attacks",
                desc: "If you are struggling with anxiety and/or panic attacks, we can help.",
              },
              {
                title: "Health Anxiety",
                desc: "Always worried about your health? You may be dealing with anxiety. Let us help.",
              },
            ].map((group) => (
              <div class='bg-brand-cream/50 rounded-xl p-6 border border-brand-blue/5'>
                <h3 class='text-lg font-display text-brand-blue mb-2'>
                  {group.title}
                </h3>
                <p class='text-brand-blue/60 text-sm leading-relaxed'>
                  {group.desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Why group therapy -->
      <div class='mb-16'>
        <h2
          class='text-3xl md:text-4xl font-display italic text-brand-blue mb-6'
        >
          Why Group Therapy Works
        </h2>
        <div class='space-y-5 text-lg text-brand-blue/70 leading-relaxed'>
          <p>
            Group therapy's effectiveness lies in its ability to help you find
            connections with other people and their experiences. These
            therapist-guided sessions will help you learn more about yourself
            and how to improve the way you feel while feeling support from
            others who understand your experience.
          </p>
          <p>
            If you're looking for help in improving your everyday life — or for
            a more community-oriented therapy experience — you would be a great
            fit for our group therapy services.
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div
        class='text-center bg-brand-cream/60 rounded-2xl p-10 md:p-14 border border-brand-blue/5'
      >
        <h2
          class='text-2xl md:text-3xl font-display italic text-brand-blue mb-4'
        >
          Ready to Join a Group?
        </h2>
        <p class='text-brand-blue/60 mb-8 max-w-xl mx-auto'>
          Reach out today for an assessment for group therapy or to schedule
          your first appointment.
        </p>
        <a
          href='/contact'
          class='inline-flex items-center px-8 py-4 text-base font-semibold rounded-full border-2 border-brand-blue text-brand-blue hover:bg-brand-blue hover:text-white transition-all duration-300'
        >
          Contact Us
          <svg
            class='w-5 h-5 ml-2'
            fill='none'
            viewBox='0 0 24 24'
            stroke-width='2'
            stroke='currentColor'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
