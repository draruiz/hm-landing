---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Resources", url: `${siteUrl}/resources` },
    {
      name: "Mental Health Links",
      url: `${siteUrl}/resources/mental-health-links`,
    },
  ]),
];

const categories = [
