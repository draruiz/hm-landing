---
import Layout from "../../layouts/Layout.astro";
import { breadcrumbSchema } from "../../utils/seo";

const siteUrl = "https://healthymindspecialists.com";

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: siteUrl },
    { name: "Resources", url: `${siteUrl}/resources` },
    {
      name: "Physical Health Links",
      url: `${siteUrl}/resources/physical-health-links`,
    },
  ]),
];

const categories = [
  {
    title: "Medications & Health Supplements",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    links: [
      {
        name: "Medical Encyclopedia",
        url: "https://medlineplus.gov/encyclopedia.html",
      },
      {
        name: "Medication — Internet Mental Health",
        url: "https://www.mentalhealth.com/home/medications.html",
      },
      { name: "Medications — PDR", url: "https://www.pdr.net/" },
      {
        name: "Medline — Drug Information",
        url: "https://www.nlm.nih.gov/medlineplus/druginformation.html",
      },
      {
        name: "Multivitamins & Supplements",
        url: "https://ods.od.nih.gov/Health_information/Vitamin_and_Mineral_Supplement_Fact_Sheets.aspx",
      },
      { name: "The People's Pharmacy", url: "https://peoplespharmacy.com/" },
    ],
  },
  {
    title: "Women's Health",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
    links: [
      { name: "Healthy Women", url: "https://healthywomen.org/" },
      { name: "WomenHeart", url: "https://womenheart.org/" },
      {
        name: "Office on Women's Health",
        url: "https://womenshealth.gov/",
      },
      {
        name: "Power Surge: Support for Women",
        url: "https://power-surge.co/",
      },
    ],
  },
  {
    title: "Fitness",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    links: [{ name: "ACE Fitness", url: "https://acefitness.org/" }],
  },
  {
    title: "General Health",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>`,
    links: [
      { name: "WebMD", url: "https://webmd.com/" },
      {
        name: "National Center for Biotechnology Information",
        url: "https://ncbi.nlm.nih.gov/",
      },
      {
        name: "Your Disease Risk — Siteman Cancer Center",
        url: "https://siteman.wustl.edu/prevention/ydr/",
      },
      { name: "Mayo Clinic", url: "https://mayoclinic.com/" },
      {
        name: "Duke Integrative Medicine",
        url: "https://dukeintegrativemedicine.org/",
      },
    ],
  },
  {
    title: "Conditions",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75" /></svg>`,
    links: [
      {
        name: "American Cancer Society",
        url: "https://cancer.org/",
      },
      {
        name: "National Cancer Institute",
        url: "https://cancer.gov/",
      },
      {
        name: "Chronic Fatigue Syndrome — CDC",
        url: "https://www.cdc.gov/cfs/",
      },
    ],
  },
];
---

<Layout
  title='Physical Health Links — Wellness Resources'
  description="Explore curated physical health resources including medications, fitness, women's health, and general wellness links from Healthy Mind Specialists."
  schema={schemas}
>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO BANNER                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section
    class='relative bg-brand-blue py-24 md:py-32 lg:py-40 overflow-hidden'
  >
    <!-- Background image -->
    <img
      src='https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1920&h=1080&fit=crop&q=80'
      alt='Person stretching outdoors in nature representing physical health and wellness'
      width='1920'
      height='1080'
      loading='eager'
      fetchpriority='high'
      class='absolute inset-0 w-full h-full object-cover'
    />
    <!-- Dark overlay for text readability -->
    <div class='absolute inset-0 bg-brand-blue/70' aria-hidden='true'></div>
    <!-- Ambient glow -->
    <div
      class='absolute inset-0 opacity-[0.06] pointer-events-none'
      aria-hidden='true'
    >
      <div
        class='absolute -top-24 -left-24 w-[500px] h-[500px] bg-brand-gold rounded-full blur-[120px]'
      >
      </div>
      <div
        class='absolute -bottom-32 -right-16 w-[400px] h-[400px] bg-brand-gold-light rounded-full blur-[100px]'
      >
      </div>
    </div>
    <div class='relative z-10 max-w-4xl mx-auto px-6 text-center'>
      <div
        class='flex items-center justify-center gap-3 mb-6'
        aria-hidden='true'
      >
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
        <span class='block w-2 h-2 rounded-full border border-brand-gold'
        ></span>
        <span class='block w-10 h-[1.5px] bg-brand-gold'></span>
      </div>
      <h1
        class='text-3xl md:text-5xl font-display italic text-white leading-tight'
      >
        Physical Health <span class='text-brand-gold-light'>Links</span>
      </h1>
      <p
        class='mt-4 text-white/70 text-base md:text-lg max-w-2xl mx-auto font-sans'
      >
        The following resources support overall well-being and physical health.
        They are intended to complement, not replace, professional medical
        advice.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- RESOURCE CATEGORIES                                        -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='max-w-6xl mx-auto px-6 py-16 md:py-24'>
    <div class='grid grid-cols-1 md:grid-cols-2 gap-8'>
      {
        categories.map((category) => (
          <div class='bg-white rounded-2xl border border-brand-gold/10 shadow-lg shadow-brand-blue/5 p-8 hover:shadow-xl hover:border-brand-gold/20 transition-all duration-300'>
            <div class='flex items-center gap-3 mb-6'>
              <span class='flex-shrink-0 w-11 h-11 rounded-xl bg-brand-blue/5 flex items-center justify-center text-brand-blue'>
                <Fragment set:html={category.icon} />
              </span>
              <h2 class='font-display text-xl text-brand-blue'>
                {category.title}
              </h2>
            </div>
            <ul class='space-y-3'>
              {category.links.map((link) => (
                <li>
                  <a
                    href={link.url}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='group flex items-center gap-2 text-brand-blue/70 hover:text-brand-gold transition-colors duration-200 font-sans text-[15px]'
                  >
                    <svg
                      class='w-4 h-4 flex-shrink-0 text-brand-gold/50 group-hover:text-brand-gold transition-colors duration-200'
                      fill='none'
                      viewBox='0 0 24 24'
                      stroke='currentColor'
                      stroke-width='2'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        d='M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25'
                      />
                    </svg>
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CTA — CONTACT                                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class='bg-brand-cream py-16 md:py-24'>
    <div class='max-w-3xl mx-auto px-6 text-center'>
      <div
        class='flex items-center justify-center gap-3 mb-6'
        aria-hidden='true'
      >
        <span class='block w-8 h-[1.5px] bg-brand-gold'></span>
        <span class='block w-2 h-2 rounded-full border border-brand-gold'
        ></span>
        <span class='block w-8 h-[1.5px] bg-brand-gold'></span>
      </div>
      <h2 class='font-display text-2xl md:text-3xl text-brand-blue italic'>
        Need Personalized Guidance?
      </h2>
      <p
        class='mt-4 text-brand-blue/60 font-sans text-base md:text-lg max-w-xl mx-auto leading-relaxed'
      >
        If you have questions about how physical health relates to your mental
        well-being, our team is here to help. Reach out to schedule a
        consultation.
      </p>
      <a
        href='/contact'
        class='inline-flex items-center gap-2 mt-8 px-8 py-3.5 bg-brand-blue text-white font-semibold rounded-full hover:bg-brand-blue-light transition-colors duration-300 shadow-lg shadow-brand-blue/20'
      >
        Contact Us
        <svg
          class='w-4 h-4'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          stroke-width='2'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
        </svg>
      </a>
    </div>
  </section>
</Layout>
