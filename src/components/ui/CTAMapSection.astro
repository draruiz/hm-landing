---
/**
 * CTA + Location section — luxurious call-to-action paired with
 * an embedded Google Maps view of the clinic address.
 */
export interface Props {
  ctaText?: string;
  ctaHref?: string;
  phone?: string;
  address?: string;
  mapQuery?: string;
}

const {
  ctaText = "Start Your Journey",
  ctaHref = "https://healthymindspecialists.com",
  phone = "(813) 609-2034",
  address = "11906 Boyette Rd, Riverview, FL 33569",
  mapQuery = "11906+Boyette+Rd,+Riverview,+FL+33569",
} = Astro.props;
---

<section class='relative overflow-hidden' aria-labelledby='cta-heading'>
  <!-- ─── CTA Band ─── -->
  <div class='relative bg-brand-blue py-20 md:py-28 overflow-hidden'>
    <!-- Decorative gold gradient streak -->
    <div class='absolute inset-0 opacity-[0.07]' aria-hidden='true'>
      <div
        class='absolute -top-24 -left-24 w-[500px] h-[500px] bg-brand-gold rounded-full blur-[120px]'
      >
      </div>
      <div
        class='absolute -bottom-32 -right-32 w-[400px] h-[400px] bg-brand-gold-light rounded-full blur-[100px]'
      >
      </div>
    </div>

    <!-- Subtle grid pattern overlay -->
    <div
      class='absolute inset-0 opacity-[0.03]'
      style='background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;'
      aria-hidden='true'
    >
    </div>

    <div class='relative z-10 max-w-5xl mx-auto px-6 cta-content'>
      <div
        class='flex flex-col lg:flex-row items-center justify-between gap-10 lg:gap-16'
      >
        <!-- Text side -->
        <div
          class='text-center lg:text-left flex-1 space-y-5 opacity-0 translate-y-6 cta-item'
          style='--cta-delay: 0ms'
        >
          <!-- Gold ornament -->
          <div
            class='flex items-center justify-center lg:justify-start gap-3 mb-2'
            aria-hidden='true'
          >
            <span class='block w-8 h-[1.5px] bg-brand-gold'></span>
            <span class='block w-2 h-2 rounded-full border border-brand-gold'
            ></span>
            <span class='block w-8 h-[1.5px] bg-brand-gold'></span>
          </div>

          <h2
            id='cta-heading'
            class='text-3xl md:text-4xl lg:text-5xl font-display italic text-white leading-tight'
          >
            Let's connect and<br class='hidden md:block' />
            <span class='text-brand-gold-light'>get started</span>
          </h2>
          <p
            class='text-base md:text-lg text-white/70 max-w-md mx-auto lg:mx-0 font-sans leading-relaxed'
          >
            Take the first step toward a healthier mind. We're here to walk
            alongside you on your journey.
          </p>
        </div>

        <!-- CTA button side -->
        <div
          class='flex-shrink-0 opacity-0 translate-y-6 cta-item'
          style='--cta-delay: 200ms'
        >
          <a
            href={ctaHref}
            class='group relative inline-flex items-center gap-3 px-10 py-4 text-base md:text-lg font-semibold tracking-wide transition-all duration-500'
          >
            <!-- Border frame -->
            <span
              class='absolute inset-0 border-2 border-brand-gold/60 rounded-sm transition-all duration-500 group-hover:border-brand-gold group-hover:scale-[1.03]'
              aria-hidden='true'></span>
            <!-- Fill on hover -->
            <span
              class='absolute inset-0 bg-brand-gold/0 group-hover:bg-brand-gold/10 rounded-sm transition-all duration-500'
              aria-hidden='true'></span>
            <span
              class='relative text-white group-hover:text-brand-gold-light transition-colors duration-300'
            >
              {ctaText}
            </span>
            <!-- Arrow -->
            <svg
              class='relative w-5 h-5 text-brand-gold transition-transform duration-300 group-hover:translate-x-1'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── Map + Address Card ─── -->
  <div class='relative'>
    <!-- Map iframe -->
    <div class='w-full h-[400px] md:h-[480px] lg:h-[520px] cta-map opacity-0'>
      <iframe
        title='Healthy Mind Specialists location'
        class='w-full h-full grayscale-[30%] contrast-[1.05]'
        loading='lazy'
        referrerpolicy='no-referrer-when-downgrade'
        src={`https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=${mapQuery}&zoom=14&maptype=roadmap`}
        allowfullscreen></iframe>
    </div>

    <!-- Floating address card -->
    <div
      class='absolute top-6 left-6 md:top-10 md:left-10 lg:top-14 lg:left-14 z-10 cta-card opacity-0 -translate-x-4'
    >
      <div
        class='bg-white/95 backdrop-blur-xl shadow-2xl rounded-2xl p-6 md:p-8 max-w-xs border border-brand-gold/10'
      >
        <!-- Gold accent bar -->
        <div class='w-10 h-[2px] bg-brand-gold mb-5' aria-hidden='true'></div>

        <h3
          class='font-display text-xl md:text-2xl text-brand-blue mb-3 leading-snug'
        >
          Visit Our Office
        </h3>

        <address
          class='not-italic space-y-3 text-brand-blue/70 text-sm md:text-base font-sans'
        >
          <!-- Address -->
          <div class='flex items-start gap-3'>
            <svg
              class='w-5 h-5 text-brand-gold mt-0.5 flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.5'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M15 10.5a3 3 0 11-6 0 3 3 0 016 0z'></path>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z'
              ></path>
            </svg>
            <span>{address}</span>
          </div>

          <!-- Phone -->
          <div class='flex items-center gap-3'>
            <svg
              class='w-5 h-5 text-brand-gold flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.5'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z'
              ></path>
            </svg>
            <a
              href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
              class='hover:text-brand-gold transition-colors duration-300'
            >
              {phone}
            </a>
          </div>
        </address>

        <!-- Directions link -->
        <a
          href={`https://www.google.com/maps/dir/?api=1&destination=${mapQuery}`}
          target='_blank'
          rel='noopener noreferrer'
          class='inline-flex items-center gap-2 mt-5 text-sm font-semibold text-brand-blue hover:text-brand-gold transition-colors duration-300 group/dir'
        >
          Get Directions
          <svg
            class='w-4 h-4 transition-transform duration-300 group-hover/dir:translate-x-0.5'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='2'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25'></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-item {
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--cta-delay, 0ms);
  }

  .cta-map {
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 200ms;
  }

  .cta-card {
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 500ms;
  }

  .cta-visible .cta-item,
  .cta-visible .cta-map,
  .cta-visible .cta-card {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>

<script>
  const section = document.querySelector("[aria-labelledby='cta-heading']");
  if (section) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add("cta-visible");
          observer.unobserve(section);
        }
      },
      { threshold: 0.15 },
    );
    observer.observe(section);
  }
</script>
