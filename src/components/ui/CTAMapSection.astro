---
/**
 * CTA + Map Section — Clean split with map embed and contact info.
 * Agency-grade minimal approach.
 */
---

<section class='relative bg-brand-white' aria-label='Location'>
  <div class='grid grid-cols-1 lg:grid-cols-2'>
    <!-- Left: Contact info -->
    <div class='flex flex-col justify-center px-6 sm:px-10 md:px-16 lg:px-20 py-20 md:py-28' data-animate>
      <span class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'>
        09 — Visit Us
      </span>
      <h2 class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em] mb-8'>
        Come say hello.
      </h2>
      <div class='w-10 h-px bg-brand-charcoal/15 mb-8'></div>

      <address class='not-italic space-y-4 text-brand-charcoal/60 font-light'>
        <p class='flex items-start gap-3'>
          <svg class='w-4 h-4 text-brand-gold flex-shrink-0 mt-1' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='1.5'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M15 10.5a3 3 0 11-6 0 3 3 0 016 0z' />
            <path stroke-linecap='round' stroke-linejoin='round' d='M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z' />
          </svg>
          <span>11906 Boyette Rd<br />Riverview, FL 33569</span>
        </p>
        <p class='flex items-center gap-3'>
          <svg class='w-4 h-4 text-brand-gold flex-shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='1.5'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z' />
          </svg>
          <a href='tel:8136092034' class='hover:text-brand-gold transition-colors'>813-609-2034</a>
        </p>
        <p class='flex items-center gap-3'>
          <svg class='w-4 h-4 text-brand-gold flex-shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='1.5'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z' />
          </svg>
          <span>Mon – Fri, 8AM – 9PM</span>
        </p>
      </address>

      <a
        href='https://maps.google.com/?q=11906+Boyette+Rd+Riverview+FL+33569'
        target='_blank'
        rel='noopener noreferrer'
        class='group inline-flex items-center gap-2 mt-8 text-sm font-semibold tracking-[0.1em] uppercase text-brand-charcoal hover:text-brand-gold transition-colors duration-300'
      >
        <span>Get Directions</span>
        <svg
          class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          stroke-width='2'
        >
          <path stroke-linecap='round' stroke-linejoin='round' d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
        </svg>
      </a>
    </div>

    <!-- Right: Map -->
    <div class='relative min-h-[400px] lg:min-h-0 bg-brand-gray-light'>
      <iframe
        src='https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3527.5!2d-82.3076!3d27.8551!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88c2cee8a6a7f4e5%3A0x6dcf7b3e9f7e0a1!2s11906%20Boyette%20Rd%2C%20Riverview%2C%20FL%2033569!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus'
        class='absolute inset-0 w-full h-full border-0 grayscale contrast-125'
        allowfullscreen
        loading='lazy'
        referrerpolicy='no-referrer-when-downgrade'
        title='Healthy Mind Specialists office location'
      ></iframe>
    </div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("is-visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("section[aria-label='Location'] [data-animate]").forEach((el) => obs.observe(el));
</script>
