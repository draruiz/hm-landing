---
/**
 * Programs & Workshops Section — Featured programs with editorial layout.
 */
const programs = [
  {
    label: "Teen Program",
    title: "Strong Mind Teens",
    description: "A specialized program designed to help adolescents build resilience, emotional regulation, and confidence during their most formative years.",
    href: "/programs/strong-mind-teens",
  },
  {
    label: "Community",
    title: "Workshops & Groups",
    description: "Interactive workshops and group experiences focused on skill-building, psychoeducation, and community connection.",
    href: "/programs/workshops",
  },
];
---

<section class='relative bg-brand-white py-24 md:py-36' aria-label='Programs'>
  <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
    <!-- Header -->
    <div class='mb-16 md:mb-24' data-animate>
      <span class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'>
        07 — Programs
      </span>
      <h2 class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em] max-w-2xl'>
        Beyond therapy.<br />Building communities.
      </h2>
    </div>

    <!-- Programs -->
    <div class='grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16'>
      {
        programs.map((prog) => (
          <div class='group' data-animate>
            <span class='font-mono text-[10px] tracking-[0.3em] uppercase text-brand-gold block mb-4'>
              {prog.label}
            </span>
            <h3 class='text-2xl md:text-3xl font-display font-bold text-brand-charcoal mb-4 group-hover:text-brand-gold transition-colors duration-300'>
              {prog.title}
            </h3>
            <div class='w-8 h-px bg-brand-charcoal/15 mb-5'></div>
            <p class='text-brand-charcoal/50 text-sm font-light leading-relaxed mb-8'>
              {prog.description}
            </p>
            <a
              href={prog.href}
              class='group/link inline-flex items-center gap-2 text-sm font-semibold tracking-[0.1em] uppercase text-brand-charcoal hover:text-brand-gold transition-colors duration-300'
            >
              <span>Explore program</span>
              <svg
                class='w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path stroke-linecap='round' stroke-linejoin='round' d='M17 8l4 4m0 0l-4 4m4-4H3' />
              </svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("is-visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("section[aria-label='Programs'] [data-animate]").forEach((el) => obs.observe(el));
</script>
