---
/**
 * Brutalist-Elegant Hero — Split-screen massive typography + confined video
 * accent shape + horizontal marquee strip. Inspired by Awwwards design agencies.
 */
export interface Props {
  heading: string;
  subheading?: string;
  ctaText: string;
  ctaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  videoSrc: string;
  posterSrc?: string;
}

const {
  heading,
  subheading = "Integrative Psychological Services",
  ctaText,
  ctaHref,
  secondaryCtaText,
  secondaryCtaHref,
  videoSrc,
  posterSrc = "/images/hero-poster.jpg",
} = Astro.props;

const headingWords = heading.split(" ");

const marqueeItems = [
  "Individual Therapy",
  "Couples Counseling",
  "EMDR",
  "Psychological Evaluations",
  "ADHD Assessments",
  "Group Therapy",
  "Life Coaching",
  "Integrative Care",
];
---

<section
  id='hero'
  class='relative min-h-screen bg-brand-blue overflow-hidden'
  aria-label='Welcome hero'
>
  <!-- Grid: Text Left + Video Right -->
  <div class='relative z-10 grid grid-cols-1 lg:grid-cols-2 min-h-screen'>
    <!-- Left: Typography -->
    <div
      class='flex flex-col justify-center px-6 sm:px-10 md:px-16 lg:px-20 xl:px-28 py-32 lg:py-20'
    >
      <div class='hero-label opacity-0 mb-8 md:mb-12'>
        <span
          class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-gold'
        >
          {subheading}
        </span>
        <div class='w-12 h-px bg-brand-gold/40 mt-3'></div>
      </div>

      <h1 class='sr-only'>{heading}</h1>

      <div class='hero-title-wrap mb-10 md:mb-14' aria-hidden='true'>
        <p
          class='text-[2rem] sm:text-4xl md:text-5xl lg:text-4xl xl:text-6xl font-display font-extrabold text-brand-white leading-[0.95] tracking-[-0.03em]'
        >
          {
            headingWords.map((word) => (
              <span class='hero-word inline-block overflow-hidden mr-[0.25em]'>
                <span class='hero-word-inner inline-block translate-y-full opacity-0'>
                  {word}
                </span>
              </span>
            ))
          }
        </p>
      </div>

      <div class='hero-divider w-0 h-px bg-brand-gold/50 mb-8 md:mb-10'></div>

      <p
        class='hero-desc opacity-0 text-brand-white/60 text-base md:text-lg font-light leading-relaxed max-w-md mb-10 md:mb-14'
      >
        Compassionate, evidence-based mental health care. We meet you where you
        are so you can get where you want to be.
      </p>

      <div
        class='hero-cta flex flex-col sm:flex-row items-start gap-4 opacity-0'
      >
        <a
          href={ctaHref}
          class='group inline-flex items-center gap-3 px-8 py-4 text-sm font-semibold tracking-[0.15em] uppercase bg-brand-gold text-brand-blue transition-all duration-500 hover:bg-brand-gold-light'
        >
          <span>{ctaText}</span>
          <svg
            class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='2'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
          </svg>
        </a>
        {
          secondaryCtaText && secondaryCtaHref && (
            <a
              href={secondaryCtaHref}
              class='group inline-flex items-center gap-3 px-8 py-4 text-sm font-medium tracking-[0.15em] uppercase text-brand-white/70 border border-brand-white/15 transition-all duration-500 hover:text-brand-white hover:border-brand-white/40'
            >
              <span>{secondaryCtaText}</span>
              <svg
                class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M17 8l4 4m0 0l-4 4m4-4H3'
                />
              </svg>
            </a>
          )
        }
      </div>
    </div>

    <!-- Right: Video accent -->
    <div
      class='hero-media relative hidden lg:flex items-center justify-center p-10 xl:p-16'
    >
      <div
        class='hero-frame absolute inset-10 xl:inset-16 border border-brand-gold/20 opacity-0'
      >
      </div>

      <div
        class='hero-video-wrap relative w-full aspect-[3/4] max-h-[75vh] overflow-hidden opacity-0'
      >
        <video
          class='hero-video absolute inset-0 w-full h-full object-cover scale-110'
          autoplay
          muted
          loop
          playsinline
          preload='metadata'
          poster={posterSrc}
          aria-hidden='true'
        >
          <source src={videoSrc} type='video/mp4' />
        </video>
        <div class='absolute inset-0 bg-brand-blue/30 mix-blend-multiply'></div>
        <div class='absolute bottom-6 left-6 right-6'>
          <span
            class='font-mono text-[10px] tracking-[0.2em] uppercase text-brand-white/50'
          >
            Tampa, FL — Est. 2015
          </span>
        </div>
      </div>

      <div
        class='absolute -right-2 top-1/2 -translate-y-1/2 -rotate-90 origin-center'
      >
        <span
          class='font-mono text-[10px] tracking-[0.4em] uppercase text-brand-white/20'
        >
          Healthy Mind Specialists
        </span>
      </div>
    </div>
  </div>

  <!-- Mobile video -->
  <div class='lg:hidden relative mx-6 mb-10 -mt-10'>
    <div
      class='hero-video-mobile relative aspect-video overflow-hidden opacity-0'
    >
      <video
        class='absolute inset-0 w-full h-full object-cover'
        autoplay
        muted
        loop
        playsinline
        preload='metadata'
        poster={posterSrc}
        aria-hidden='true'
      >
        <source src={videoSrc} type='video/mp4' />
      </video>
      <div class='absolute inset-0 bg-brand-blue/30 mix-blend-multiply'></div>
    </div>
  </div>

  <!-- Marquee strip -->
  <div
    class='relative z-10 border-t border-brand-white/10 bg-brand-blue-dark/50 backdrop-blur-sm overflow-hidden'
  >
    <div class='marquee-track flex items-center whitespace-nowrap py-4'>
      {
        [...marqueeItems, ...marqueeItems].map((item) => (
          <span class='inline-flex items-center gap-6 mx-6'>
            <span class='font-display text-sm md:text-base font-medium text-brand-white/50 uppercase tracking-[0.1em]'>
              {item}
            </span>
            <span class='block w-1.5 h-1.5 rounded-full bg-brand-gold/40' />
          </span>
        ))
      }
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class='scroll-indicator absolute bottom-20 lg:bottom-8 left-6 sm:left-10 md:left-16 lg:left-20 flex items-center gap-3 opacity-0 z-10'
  >
    <div
      class='w-5 h-9 rounded-full border border-brand-white/25 flex items-start justify-center pt-1.5'
    >
      <span class='scroll-dot block w-1 h-1 rounded-full bg-brand-gold'></span>
    </div>
    <span
      class='font-mono text-[10px] tracking-[0.3em] uppercase text-brand-white/30'
    >
      Scroll
    </span>
  </div>

  <!-- Background grid lines -->
  <div class='absolute inset-0 pointer-events-none z-0' aria-hidden='true'>
    <div class='absolute left-[25%] top-0 bottom-0 w-px bg-brand-white/[0.03]'>
    </div>
    <div class='absolute left-[50%] top-0 bottom-0 w-px bg-brand-white/[0.03]'>
    </div>
    <div class='absolute left-[75%] top-0 bottom-0 w-px bg-brand-white/[0.03]'>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReduced) {
      document
        .querySelectorAll<HTMLElement>(
          ".hero-word-inner, .hero-label, .hero-divider, .hero-desc, .hero-cta, .scroll-indicator, .hero-video-wrap, .hero-video-mobile, .hero-frame",
        )
        .forEach((el) => {
          el.style.opacity = "1";
          el.style.transform = "none";
        });
      const divider = document.querySelector<HTMLElement>(".hero-divider");
      if (divider) divider.style.width = "60px";
      return;
    }

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.fromTo(
      ".hero-label",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      0.2,
    );

    tl.to(
      ".hero-word-inner",
      { y: 0, opacity: 1, duration: 1, stagger: 0.06, ease: "power4.out" },
      0.4,
    );

    tl.to(
      ".hero-divider",
      { width: "60px", duration: 0.8, ease: "power2.inOut" },
      1.0,
    );

    tl.fromTo(
      ".hero-desc",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      1.1,
    );

    tl.fromTo(
      ".hero-cta",
      { y: 15, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7 },
      1.3,
    );

    tl.fromTo(
      ".hero-video-wrap",
      { scale: 1.05, opacity: 0 },
      { scale: 1, opacity: 1, duration: 1.2, ease: "power2.out" },
      0.5,
    );

    tl.fromTo(
      ".hero-frame",
      { opacity: 0, scale: 1.02 },
      { opacity: 1, scale: 1, duration: 1, ease: "power2.out" },
      0.7,
    );

    tl.fromTo(
      ".hero-video-mobile",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.8 },
      1.0,
    );

    tl.to(".hero-video", { scale: 1, duration: 8, ease: "power1.out" }, 0);

    tl.fromTo(
      ".scroll-indicator",
      { opacity: 0 },
      { opacity: 1, duration: 0.6 },
      2.0,
    );

    gsap.to(".scroll-dot", {
      y: 14,
      duration: 1.5,
      repeat: -1,
      yoyo: true,
      ease: "power1.inOut",
    });
  });
</script>

<style>
  .hero-word-inner {
    will-change: transform, opacity;
  }
</style>
