---
/**
 * Welcome section — empathetic intro with staggered reveal questions.
 * Positioned immediately after the hero on the homepage.
 */
const questions = [
  "Are you constantly stressed and feeling on edge?",
  "Does it seem like you are losing control and always feeling uncertain of what the future holds?",
  "Are you struggling with intrusive thoughts and the inability to focus?",
  "Have you tried to solve the problems in your life on your own and realized you need help from someone else?",
];
---

<section
  class='relative py-24 md:py-36 bg-brand-cream overflow-hidden'
  aria-labelledby='welcome-heading'
>
  <!-- Decorative watercolor blobs -->
  <div
    class='absolute top-0 left-0 w-72 h-72 bg-brand-teal/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2'
    aria-hidden='true'
  >
  </div>
  <div
    class='absolute bottom-0 right-0 w-96 h-96 bg-brand-gold/8 rounded-full blur-3xl translate-x-1/3 translate-y-1/3'
    aria-hidden='true'
  >
  </div>

  <div class='relative max-w-4xl mx-auto px-6 text-center'>
    <!-- Heading with decorative line above -->
    <div class='inline-flex flex-col items-center mb-14'>
      <span class='block w-12 h-[2px] bg-brand-gold mb-6' aria-hidden='true'
      ></span>
      <h2
        id='welcome-heading'
        class='text-4xl md:text-5xl lg:text-6xl font-display italic text-brand-blue leading-tight'
      >
        Welcome. We can help.
      </h2>
    </div>

    <!-- Empathetic questions with stagger animation -->
    <div class='space-y-6 mb-16 welcome-questions'>
      {
        questions.map((q, i) => (
          <p
            class='text-lg md:text-xl text-brand-blue/80 leading-relaxed max-w-2xl mx-auto opacity-0 translate-y-4 welcome-q'
            style={`--delay: ${i * 150}ms`}
          >
            {q}
          </p>
        ))
      }
    </div>

    <!-- Motivational divider -->
    <div class='relative flex items-center justify-center my-12'>
      <span
        class='absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-blue/20 to-transparent'
        aria-hidden='true'></span>
    </div>

    <p
      class='text-2xl md:text-3xl lg:text-4xl font-display italic text-brand-blue leading-snug max-w-3xl mx-auto opacity-0 translate-y-4 welcome-q'
      style='--delay: 700ms'
    >
      Change begins at the end of your comfort zone.
    </p>

    <div class='relative flex items-center justify-center mt-12 mb-2'>
      <span
        class='absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-gold/40 to-transparent'
        aria-hidden='true'></span>
    </div>
  </div>
</section>

<style>
  /* Intersection Observer triggers .is-visible which starts the animation */
  .welcome-q {
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--delay, 0ms);
  }

  .is-visible .welcome-q {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document
    .querySelector(".welcome-questions")
    ?.closest("section");
  if (section) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add("is-visible");
          observer.disconnect();
        }
      },
      { threshold: 0.2 },
    );
    observer.observe(section);
  }
</script>
