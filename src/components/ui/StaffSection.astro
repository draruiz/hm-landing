---

<section id='team' class='relative bg-brand-cream py-24 md:py-36 overflow-hidden' aria-label='Our Team'>
  <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
    <!-- Header -->
    <div class='flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-20'>
      <div data-animate>
        <span class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'>
          08 — Team
        </span>
        <h2 class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em]'>
          The people behind<br />the practice.
        </h2>
      </div>
      <div class='max-w-sm' data-animate>
        <p class='text-brand-charcoal/50 text-sm font-light leading-relaxed'>
          A multidisciplinary team of licensed psychologists, therapists, and
          counselors dedicated to your wellbeing.
        </p>
      </div>
    </div>
  </div>

  <!-- Horizontal scroll container -->
  <div class='staff-scroll overflow-x-auto pb-6 scrollbar-hide' data-animate>
    <div class='flex gap-4 md:gap-6 px-6 sm:px-10 md:px-16 lg:px-20' style='width: max-content;'>
      {
        staff.map((member, i) => (
          <a
            href={member.href}
            class='group flex-shrink-0 w-64 md:w-72'
          >
            <!-- Photo card -->
            <div class='relative aspect-[3/4] bg-brand-blue overflow-hidden mb-4'>
              <img
                src={member.image}
                alt={`${member.name} — ${member.title}`}
                width='288'
                height='384'
                class='absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-105'
                loading='lazy'
                decoding='async'
              />
              <!-- Bottom gradient overlay for text legibility -->
              <div class='absolute inset-0 bg-gradient-to-t from-brand-blue/70 via-brand-blue/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500' />
              <!-- Number badge -->
              <span class='absolute top-4 left-4 font-mono text-[10px] tracking-[0.2em] text-brand-white/50 bg-brand-blue/40 backdrop-blur-sm px-2 py-1'>
                {String(i + 1).padStart(2, "0")}
              </span>
              <!-- Hover name overlay -->
              <div class='absolute bottom-0 left-0 right-0 p-5 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500'>
                <span class='font-mono text-[10px] tracking-[0.15em] uppercase text-brand-gold'>
                  View profile →
                </span>
              </div>
            </div>
            <h3 class='text-base font-display font-bold text-brand-charcoal group-hover:text-brand-gold transition-colors duration-300'>
              {member.name}
            </h3>
            <p class='text-xs font-mono tracking-[0.05em] text-brand-muted mt-1'>
              {member.title}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("is-visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("#team [data-animate]").forEach((el) => obs.observe(el));
</script>
