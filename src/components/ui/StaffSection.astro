---
/**
 * Meet Our Staff — horizontal scrolling carousel showcasing all team members
 * with real photos, roles, and short bios. Drag-to-scroll + snap on mobile.
 */
const staff = [
  {
    name: "Dr. Maria A. Ruiz, PsyD",
    role: "Licensed Clinical Psychologist",
    bio: "Life can bring moments that force us to pause and reconsider who we are. Dr. Ruiz helps you uncover patterns, understand your emotions, and create meaningful change.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/aee50b9f-80b8-451e-f614-898548535100/public",
    imageAlt: "Dr. Maria A. Ruiz, Licensed Clinical Psychologist",
    href: "/staff/dr-maria-a-ruiz-psyd",
  },
  {
    name: "Dr. Asia Wardlaw, PsyD",
    role: "Director of Diagnostic Services",
    bio: "Specializing in psychological and neuropsychological assessment for children, adolescents, and adults — uncovering the 'why' and providing a clear path forward.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/6e817f35-0729-4415-e9cc-106de5df9400/public",
    imageAlt: "Dr. Asia Wardlaw, Director of Diagnostic Services",
    href: "/staff/dr-asia-wardlaw-psyd",
  },
  {
    name: "Dr. Grissel M. Lloyd, PsyD",
    role: "Licensed Clinical Psychologist",
    bio: "Therapy offers something rare and powerful — an objective space where you can be fully seen and heard, free from judgment or fear.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/f2f396df-4594-4d5f-4390-c7cbc0e09b00/public",
    imageAlt: "Dr. Grissel M. Lloyd, Licensed Clinical Psychologist",
    href: "/staff/dr-grissel-m-lloyd-psyd",
  },
  {
    name: "Dr. Sonia Javani, PsyD",
    role: "Director of Practicum & Internship Training",
    bio: "Passionate about creating a reflective, authentic space where developing clinicians can grow with confidence, curiosity, and purpose.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/37569d14-63fe-4060-0043-9e9c1baaed00/public",
    imageAlt: "Dr. Sonia Javani, Director of Practicum and Internship Training",
    href: "/staff/dr-sonia-javani-psyd",
  },
  {
    name: "Kiyomi Taylor, LMHC",
    role: "Licensed Mental Health Counselor",
    bio: "Life can be chaotic and challenging. Sometimes we hit roadblocks and need someone to come alongside us for support, insight, and practical tools for healing.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/8a32b006-f77d-4ff5-13ad-9a4c2158eb00/public",
    imageAlt: "Kiyomi Taylor, Licensed Mental Health Counselor",
    href: "/staff/kiyomi-taylor-lmhc",
  },
  {
    name: "Chloe Johnson, LMHC",
    role: "Licensed Mental Health Counselor",
    bio: "Everyone deserves a space where they feel heard, valued, and empowered to grow. Dedicated to fostering a journey of healing and transformation.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/ca480842-0849-4ea3-bd0f-403dd430ad00/public",
    imageAlt: "Chloe Johnson, Licensed Mental Health Counselor",
    href: "/staff/chloe-johnson-lmhc",
  },
  {
    name: "Edward Porter, LCSW",
    role: "Licensed Clinical Social Worker",
    bio: "If you're navigating anxiety, depression, or major life transitions, therapy can offer a supportive space to pause, reflect, and begin making sense of what you're carrying.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/4d62b896-9a42-4628-4cff-d32dfb4bca00/public",
    imageAlt: "Edward Porter, Licensed Clinical Social Worker",
    href: "/staff/edward-porter-lcsw",
  },
  {
    name: "Lori Smith, LMHC",
    role: "Licensed Mental Health Counselor",
    bio: "Walking alongside you as you navigate life's challenges and move toward greater clarity, confidence, and peace of mind.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/c5514d94-2e9a-49bf-d22e-5a1faf6d7b00/public",
    imageAlt: "Lori Smith, Licensed Mental Health Counselor",
    href: "/staff/lori-smith-lmhc",
  },
  {
    name: "Morgan Adams, MSW",
    role: "Life & Mindfulness Coach",
    bio: "When stress or difficult experiences begin to take over, having the right support can make a meaningful difference — regaining grounding, clarity, and confidence.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/b13d28c3-98c3-4dbd-7ba7-d16aefbad700/public",
    imageAlt: "Morgan Adams, Life & Mindfulness Coach",
    href: "/staff/morgan-adams-msw",
  },
  {
    name: "Traci Adams, CLC",
    role: "Certified Life Coach",
    bio: "Life doesn't always follow a straight path. Sometimes we need support to move forward with clarity, confidence, and renewed purpose.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/96c2a220-7c97-4a54-5bed-de73b398c600/public",
