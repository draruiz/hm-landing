    href: "/staff/traci-adams-clc",
  },
  {
    name: "Terika Brewer, MA",
    role: "Operations Manager",
    bio: "Over 15 years of experience in the mental health field, ensuring the day-to-day efficiency and long-term sustainability of the practice.",
    image:
      "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/59e6bfdb-7439-4ca4-89a9-1eeccb23ad00/public",
    imageAlt: "Terika Brewer, Operations Manager",
    href: "/staff/terika-brewer-ma",
  },
];

const accentColors = [
  "from-brand-teal via-brand-teal-light to-brand-gold/40",
  "from-brand-gold via-brand-gold-light to-brand-teal/40",
  "from-brand-blue-light via-brand-teal to-brand-gold/40",
];

const ringColors = [
  "conic-gradient(from 0deg, #b8d8d8, #c5a55a, #b8d8d8)",
  "conic-gradient(from 120deg, #c5a55a, #b8d8d8, #c5a55a)",
  "conic-gradient(from 240deg, #2a5a8c, #b8d8d8, #c5a55a, #2a5a8c)",
];
---

<section
  class='relative py-28 md:py-40 bg-white overflow-hidden'
  aria-labelledby='staff-heading'
>
  <!-- Decorative background elements -->
  <div
    class='absolute top-20 left-0 w-[500px] h-[500px] bg-brand-teal/[0.04] rounded-full blur-3xl -translate-x-1/2'
    aria-hidden='true'
  >
  </div>
  <div
    class='absolute bottom-0 right-0 w-[600px] h-[600px] bg-brand-gold/[0.03] rounded-full blur-3xl translate-x-1/3 translate-y-1/4'
    aria-hidden='true'
  >
  </div>

  <!-- Floating decorative dots -->
  <div
    class='absolute top-32 right-[15%] w-2 h-2 rounded-full bg-brand-gold/30 staff-float'
    style='--float-duration: 6s; --float-delay: 0s'
    aria-hidden='true'
  >
  </div>
  <div
    class='absolute top-48 left-[10%] w-3 h-3 rounded-full bg-brand-teal/20 staff-float'
    style='--float-duration: 8s; --float-delay: 1s'
    aria-hidden='true'
  >
  </div>
  <div
    class='absolute bottom-40 right-[20%] w-2.5 h-2.5 rounded-full bg-brand-blue/10 staff-float'
    style='--float-duration: 7s; --float-delay: 2s'
    aria-hidden='true'
  >
  </div>

  <div class='relative'>
    <!-- Section header -->
    <div class='text-center mb-20 md:mb-28 px-6'>
      <span
        class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
        aria-hidden='true'></span>
      <h2
        id='staff-heading'
        class='text-4xl md:text-5xl lg:text-6xl font-display italic text-brand-blue mb-4'
      >
        Meet Our Staff
      </h2>
      <p class='text-lg text-brand-blue/60 max-w-xl mx-auto'>
        Compassionate professionals dedicated to helping you thrive — every step
        of the way.
      </p>
    </div>

    <!-- Scroll controls -->
    <div class='hidden md:flex justify-end gap-3 max-w-7xl mx-auto px-6 mb-8'>
      <button
        class='staff-scroll-btn staff-scroll-left w-11 h-11 rounded-full border-2 border-brand-blue/20 text-brand-blue/40 flex items-center justify-center hover:border-brand-gold hover:text-brand-gold hover:bg-brand-gold/5 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed'
        aria-label='Scroll staff left'
        disabled
      >
        <svg
          class='w-4 h-4'
          fill='none'
          viewBox='0 0 24 24'
          stroke-width='2.5'
          stroke='currentColor'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18'></path>
        </svg>
      </button>
      <button
        class='staff-scroll-btn staff-scroll-right w-11 h-11 rounded-full border-2 border-brand-blue/20 text-brand-blue/40 flex items-center justify-center hover:border-brand-gold hover:text-brand-gold hover:bg-brand-gold/5 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed'
        aria-label='Scroll staff right'
      >
        <svg
          class='w-4 h-4'
          fill='none'
          viewBox='0 0 24 24'
          stroke-width='2.5'
          stroke='currentColor'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
        </svg>
      </button>
    </div>

    <!-- Staff horizontal scroll -->
    <div
      class='staff-scroll-container overflow-x-auto pt-20 md:pt-24 pb-8 scroll-smooth'
      role='region'
      aria-label='Staff members carousel'
      tabindex='0'
    >
      <div
        class='staff-grid flex gap-6 lg:gap-8 px-6 md:px-[max(1.5rem,calc((100vw-80rem)/2+1.5rem))]'
      >
        {
          staff.map((member, i) => (
            <article
              class='group relative flex-shrink-0 w-[300px] md:w-[340px] opacity-0 translate-y-10 staff-card'
              style={`--card-delay: ${i * 100}ms`}
            >
              <div class='staff-card-inner relative bg-white/60 backdrop-blur-lg border border-white/60 rounded-3xl p-6 pt-24 md:pt-28 text-center shadow-[0_4px_30px_-8px_rgba(27,58,92,0.08)] hover:shadow-[0_24px_64px_-16px_rgba(27,58,92,0.16)] transition-all duration-700 ease-out hover:-translate-y-2 h-full flex flex-col'>
                {/* Gradient accent top edge */}
                <div
                  class={`absolute top-0 left-6 right-6 h-[3px] rounded-full bg-gradient-to-r ${accentColors[i % 3]} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}
                  aria-hidden='true'
                />

                {/* Photo container */}
                <div class='absolute left-1/2 -translate-x-1/2 -top-14 md:-top-16'>
                  <div
                    class='staff-ring absolute -inset-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-[2px]'
                    style={`background: ${ringColors[i % 3]}`}
                    aria-hidden='true'
                  />
                  <div class='relative w-28 h-28 md:w-32 md:h-32 rounded-full overflow-hidden border-4 border-white shadow-lg group-hover:shadow-xl transition-shadow duration-500'>
                    <img
                      src={member.image}
                      alt={member.imageAlt}
                      width='128'
                      height='128'
                      loading='lazy'
                      class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out'
                    />
                  </div>
                </div>

                {/* Content */}
                <div class='mt-2 flex flex-col flex-1'>
                  <h3 class='text-lg md:text-xl font-display text-brand-blue mb-1 group-hover:text-brand-blue-light transition-colors duration-300'>
                    {member.name}
                  </h3>
                  <span class='block text-xs font-medium text-brand-gold tracking-wide uppercase mb-3'>
                    {member.role}
                  </span>

                  <span
                    class='block w-8 h-[1.5px] bg-brand-gold/40 mx-auto mb-3 group-hover:w-12 transition-all duration-500'
                    aria-hidden='true'
                  />

                  <p class='text-brand-blue/60 text-sm leading-relaxed mb-5 flex-1'>
                    {member.bio}
                  </p>

                  <a
                    href={member.href}
                    class='inline-flex items-center justify-center gap-2 px-5 py-2 text-sm font-semibold rounded-full border-2 border-brand-blue/20 text-brand-blue hover:border-brand-gold hover:text-brand-gold hover:bg-brand-gold/5 transition-all duration-300 group/btn mt-auto'
                    aria-label={`Learn more about ${member.name}`}
                  >
                    Learn More
                    <svg
                      class='w-3.5 h-3.5 opacity-0 -translate-x-2 group-hover/btn:opacity-100 group-hover/btn:translate-x-0 transition-all duration-300'
                      fill='none'
                      viewBox='0 0 24 24'
                      stroke-width='2.5'
                      stroke='currentColor'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'
                      />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Scroll progress dots -->
    <div class='flex justify-center gap-2 mt-6 staff-dots' aria-hidden='true'>
      {
        staff.map((_, i) => (
          <button
            class={`staff-dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? "bg-brand-gold w-6" : "bg-brand-blue/20"}`}
            data-index={i}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Staggered entrance animation */
  .staff-card {
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--card-delay, 0ms);
  }

  .staff-visible .staff-card {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hide scrollbar but keep functionality */
  .staff-scroll-container {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .staff-scroll-container::-webkit-scrollbar {
    display: none;
  }

  /* Snap scrolling on touch devices */
  @media (pointer: coarse) {
    .staff-scroll-container {
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .staff-card {
      scroll-snap-align: center;
    }
  }

  /* Animated spinning gradient ring */
  .staff-ring {
    animation: ring-spin 4s linear infinite paused;
  }

  .group:hover .staff-ring {
    animation-play-state: running;
  }

  @keyframes ring-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Floating decorative dots */
  .staff-float {
    animation: staff-float-y var(--float-duration, 6s) ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
  }

  @keyframes staff-float-y {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-18px);
    }
  }

  /* 3D tilt perspective on hover */
  .staff-card-inner {
    transform-style: preserve-3d;
    perspective: 800px;
  }

  .staff-card-inner.tilting {
    transition: none;
  }

  /* Drag cursor */
  .staff-scroll-container.dragging {
    cursor: grabbing;
    user-select: none;
  }
  .staff-scroll-container:not(.dragging) {
    cursor: grab;
  }
</style>

<script>
  // Intersection Observer for reveal
  const staffGrid = document.querySelector(".staff-grid");
  if (staffGrid) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          staffGrid.classList.add("staff-visible");
          observer.disconnect();
        }
      },
      { threshold: 0.1 },
    );
    observer.observe(staffGrid);
  }

  // Scroll container logic
  const scrollContainer = document.querySelector<HTMLElement>(
    ".staff-scroll-container",
  );
  const scrollLeft =
    document.querySelector<HTMLButtonElement>(".staff-scroll-left");
  const scrollRight = document.querySelector<HTMLButtonElement>(
    ".staff-scroll-right",
  );
  const dots = document.querySelectorAll<HTMLButtonElement>(".staff-dot");

  if (scrollContainer) {
    const cardWidth = 356; // card width + gap

    // Arrow buttons
    scrollLeft?.addEventListener("click", () => {
      scrollContainer.scrollBy({ left: -cardWidth, behavior: "smooth" });
    });
    scrollRight?.addEventListener("click", () => {
      scrollContainer.scrollBy({ left: cardWidth, behavior: "smooth" });
    });

    // Update button states + dots on scroll
    const updateControls = () => {
      const { scrollLeft: sl, scrollWidth, clientWidth } = scrollContainer;
      if (scrollLeft) scrollLeft.disabled = sl <= 10;
      if (scrollRight)
        scrollRight.disabled = sl + clientWidth >= scrollWidth - 10;

      // Update dots
      const cards = scrollContainer.querySelectorAll(".staff-card");
      const containerRect = scrollContainer.getBoundingClientRect();
      const containerCenter = containerRect.left + containerRect.width / 2;

      let closestIdx = 0;
      let closestDist = Infinity;
      cards.forEach((card, idx) => {
        const cardRect = card.getBoundingClientRect();
        const cardCenter = cardRect.left + cardRect.width / 2;
        const dist = Math.abs(cardCenter - containerCenter);
        if (dist < closestDist) {
          closestDist = dist;
          closestIdx = idx;
        }
      });

      dots.forEach((dot, idx) => {
        if (idx === closestIdx) {
          dot.classList.add("bg-brand-gold", "w-6");
          dot.classList.remove("bg-brand-blue/20");
        } else {
          dot.classList.remove("bg-brand-gold", "w-6");
          dot.classList.add("bg-brand-blue/20");
        }
      });
    };

    scrollContainer.addEventListener("scroll", updateControls, {
      passive: true,
    });
    updateControls();

    // Dot click navigation
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const idx = Number(dot.dataset.index);
        const cards = scrollContainer.querySelectorAll(".staff-card");
        if (cards[idx]) {
          cards[idx].scrollIntoView({
            behavior: "smooth",
            block: "nearest",
            inline: "center",
          });
        }
      });
    });

    // Desktop drag-to-scroll
    if (window.matchMedia("(pointer: fine)").matches) {
      let isDown = false;
      let startX = 0;
      let scrollStart = 0;

      scrollContainer.addEventListener("mousedown", (e) => {
        isDown = true;
        scrollContainer.classList.add("dragging");
        startX = e.pageX - scrollContainer.offsetLeft;
        scrollStart = scrollContainer.scrollLeft;
      });

      scrollContainer.addEventListener("mouseleave", () => {
        isDown = false;
        scrollContainer.classList.remove("dragging");
      });

      scrollContainer.addEventListener("mouseup", () => {
        isDown = false;
        scrollContainer.classList.remove("dragging");
      });

      scrollContainer.addEventListener("mousemove", (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - scrollContainer.offsetLeft;
        const walk = (x - startX) * 1.5;
        scrollContainer.scrollLeft = scrollStart - walk;
      });
    }
  }

  // 3D tilt effect on desktop
  if (window.matchMedia("(pointer: fine)").matches) {
    document
      .querySelectorAll<HTMLElement>(".staff-card-inner")
      .forEach((card) => {
        card.addEventListener("mousemove", (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = ((y - centerY) / centerY) * -5;
          const rotateY = ((x - centerX) / centerX) * 5;
          card.classList.add("tilting");
          card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
        });

        card.addEventListener("mouseleave", () => {
          card.classList.remove("tilting");
          card.style.transform = "";
        });
      });
  }
</script>
