---
/**
 * Meet Our Staff — immersive card carousel with 3D tilt, animated gradient rings,
 * and staggered scroll reveal. Awwwards-level micro-interactions.
 */
const staff = [
  {
    name: "Dr. Maria A. Ruiz, PsyD",
    role: "Licensed Psychologist",
    bio: "Helping you uncover patterns, understand your emotions, and create meaningful change.",
    image:
      "https://images.unsplash.com/photo-1594824476967-48c8b964f07d?w=400&h=400&fit=crop&q=80&crop=faces",
    imageAlt:
      "Portrait of Dr. Maria A. Ruiz, licensed psychologist at Healthy Mind Specialists",
    href: "/staff/maria-ruiz",
    accent: "from-brand-teal via-brand-teal-light to-brand-gold/40",
    ring: "conic-gradient(from 0deg, #b8d8d8, #c5a55a, #b8d8d8)",
  },
  {
    name: "Kiyomi Taylor, LMHC",
    role: "Licensed Mental Health Counselor",
    bio: "Offering support, insight, and practical tools for healing from trauma, stress, and self-doubt.",
    image:
      "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&h=400&fit=crop&q=80&crop=faces",
    imageAlt:
      "Portrait of Kiyomi Taylor, licensed mental health counselor at Healthy Mind Specialists",
    href: "/staff/kiyomi-taylor",
    accent: "from-brand-gold via-brand-gold-light to-brand-teal/40",
    ring: "conic-gradient(from 120deg, #c5a55a, #b8d8d8, #c5a55a)",
  },
  {
    name: "Dr. Asia Wardlaw, PsyD",
    role: "Licensed Psychologist",
    bio: "Specializing in psychological testing that reveals answers, supports planning, and builds long-term understanding.",
    image:
      "https://images.unsplash.com/photo-1580894732444-8ecded7900cd?w=400&h=400&fit=crop&q=80&crop=faces",
    imageAlt:
      "Portrait of Dr. Asia Wardlaw, licensed psychologist at Healthy Mind Specialists",
    href: "/staff/asia-wardlaw",
    accent: "from-brand-blue-light via-brand-teal to-brand-gold/40",
    ring: "conic-gradient(from 240deg, #2a5a8c, #b8d8d8, #c5a55a, #2a5a8c)",
  },
];
---

<section
  class='relative py-28 md:py-40 bg-white overflow-hidden'
  aria-labelledby='staff-heading'
>
  <!-- Decorative background elements -->
  <div
    class='absolute top-20 left-0 w-[500px] h-[500px] bg-brand-teal/[0.04] rounded-full blur-3xl -translate-x-1/2'
    aria-hidden='true'
  >
  </div>
  <div
    class='absolute bottom-0 right-0 w-[600px] h-[600px] bg-brand-gold/[0.03] rounded-full blur-3xl translate-x-1/3 translate-y-1/4'
    aria-hidden='true'
  >
  </div>

  <!-- Floating decorative dots -->
  <div
    class='absolute top-32 right-[15%] w-2 h-2 rounded-full bg-brand-gold/30 staff-float'
    style='--float-duration: 6s; --float-delay: 0s'
    aria-hidden='true'
  >
  </div>
  <div
    class='absolute top-48 left-[10%] w-3 h-3 rounded-full bg-brand-teal/20 staff-float'
    style='--float-duration: 8s; --float-delay: 1s'
    aria-hidden='true'
  >
  </div>
  <div
    class='absolute bottom-40 right-[20%] w-2.5 h-2.5 rounded-full bg-brand-blue/10 staff-float'
    style='--float-duration: 7s; --float-delay: 2s'
    aria-hidden='true'
  >
  </div>

  <div class='relative max-w-7xl mx-auto px-6'>
    <!-- Section header -->
    <div class='text-center mb-20 md:mb-28'>
      <span
        class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
        aria-hidden='true'></span>
      <h2
        id='staff-heading'
        class='text-4xl md:text-5xl lg:text-6xl font-display italic text-brand-blue mb-4'
      >
        Meet Our Staff
      </h2>
      <p class='text-lg text-brand-blue/60 max-w-xl mx-auto'>
        Compassionate professionals dedicated to helping you thrive — every step
        of the way.
      </p>
    </div>

    <!-- Staff cards -->
    <div class='staff-grid grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12'>
      {
        staff.map((member, i) => (
          <article
            class='group relative opacity-0 translate-y-10 staff-card'
            style={`--card-delay: ${i * 150}ms`}
          >
            {/* Card with glassmorphism + 3D tilt via CSS */}
            <div class='staff-card-inner relative bg-white/60 backdrop-blur-lg border border-white/60 rounded-3xl p-8 pt-28 md:pt-32 text-center shadow-[0_4px_30px_-8px_rgba(27,58,92,0.08)] hover:shadow-[0_24px_64px_-16px_rgba(27,58,92,0.16)] transition-all duration-700 ease-out hover:-translate-y-2'>
              {/* Gradient accent top edge */}
              <div
                class={`absolute top-0 left-6 right-6 h-[3px] rounded-full bg-gradient-to-r ${member.accent} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}
                aria-hidden='true'
              />

              {/* Photo container — floats above the card */}
              <div class='absolute left-1/2 -translate-x-1/2 -top-16 md:-top-20'>
                {/* Animated gradient ring */}
                <div
                  class='staff-ring absolute -inset-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-[2px]'
                  style={`background: ${member.ring}`}
                  aria-hidden='true'
                />

                {/* Image wrapper */}
                <div class='relative w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-white shadow-lg group-hover:shadow-xl transition-shadow duration-500'>
                  <img
                    src={member.image}
                    alt={member.imageAlt}
                    width='160'
                    height='160'
                    loading='lazy'
                    class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out'
                  />
                </div>
              </div>

              {/* Content */}
              <div class='mt-4'>
                <h3 class='text-xl md:text-2xl font-display text-brand-blue mb-1 group-hover:text-brand-blue-light transition-colors duration-300'>
                  {member.name}
                </h3>
                <span class='block text-sm font-medium text-brand-gold tracking-wide uppercase mb-4'>
                  {member.role}
                </span>

                {/* Decorative divider */}
                <span
                  class='block w-8 h-[1.5px] bg-brand-gold/40 mx-auto mb-4 group-hover:w-12 transition-all duration-500'
                  aria-hidden='true'
                />

                <p class='text-brand-blue/60 text-sm md:text-base leading-relaxed mb-6'>
                  {member.bio}
                </p>

                {/* CTA button */}
                <a
                  href={member.href}
                  class='inline-flex items-center gap-2 px-6 py-2.5 text-sm font-semibold rounded-full border-2 border-brand-blue/20 text-brand-blue hover:border-brand-gold hover:text-brand-gold hover:bg-brand-gold/5 transition-all duration-300 group/btn'
                  aria-label={`Read more about ${member.name}`}
                >
                  Read More
                  <svg
                    class='w-3.5 h-3.5 opacity-0 -translate-x-2 group-hover/btn:opacity-100 group-hover/btn:translate-x-0 transition-all duration-300'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke-width='2.5'
                    stroke='currentColor'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'
                    />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class='text-center mt-16 md:mt-20 opacity-0 translate-y-6 staff-cta'>
      <a
        href='/staff'
        class='inline-flex items-center gap-2 px-8 py-3.5 text-base font-semibold rounded-full border-2 border-brand-blue text-brand-blue hover:bg-brand-blue hover:text-white transition-all duration-300'
      >
        View all team members
        <svg
          class='w-4 h-4'
          fill='none'
          viewBox='0 0 24 24'
          stroke-width='2'
          stroke='currentColor'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Staggered entrance animation */
  .staff-card {
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--card-delay, 0ms);
  }

  .staff-cta {
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 500ms;
  }

  .staff-visible .staff-card,
  .staff-visible .staff-cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* Animated spinning gradient ring */
  .staff-ring {
    animation: ring-spin 4s linear infinite paused;
  }

  .group:hover .staff-ring {
    animation-play-state: running;
  }

  @keyframes ring-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Floating decorative dots */
  .staff-float {
    animation: staff-float-y var(--float-duration, 6s) ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
  }

  @keyframes staff-float-y {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-18px);
    }
  }

  /* 3D tilt perspective on hover — subtle */
  .staff-card-inner {
    transform-style: preserve-3d;
    perspective: 800px;
  }

  /* Smooth card tilt powered by JS below */
  .staff-card-inner.tilting {
    transition: none;
  }
</style>

<script>
  // Intersection Observer for reveal
  const staffGrid = document.querySelector(".staff-grid");
  if (staffGrid) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          staffGrid.classList.add("staff-visible");
          observer.disconnect();
        }
      },
      { threshold: 0.12 },
    );
    observer.observe(staffGrid);
  }

  // 3D tilt effect on desktop
  if (window.matchMedia("(pointer: fine)").matches) {
    document
      .querySelectorAll<HTMLElement>(".staff-card-inner")
      .forEach((card) => {
        card.addEventListener("mousemove", (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = ((y - centerY) / centerY) * -5;
          const rotateY = ((x - centerX) / centerX) * 5;
          card.classList.add("tilting");
          card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
        });

        card.addEventListener("mouseleave", () => {
          card.classList.remove("tilting");
          card.style.transform = "";
        });
      });
  }
</script>
