---
/**
 * What We Treat — Horizontal scrolling tags with bold typographic statement.
 * Brutalist-elegant, no tabs. Clean and scannable.
 */
const conditions = [
  { name: "Anxiety Disorders", detail: "Generalized anxiety, social anxiety, panic disorder, phobias" },
  { name: "Depression", detail: "Major depression, persistent depressive disorder, seasonal affective" },
  { name: "Trauma & PTSD", detail: "Complex trauma, acute stress, childhood trauma, combat-related" },
  { name: "ADHD", detail: "Inattentive, hyperactive-impulsive, combined type — children through adults" },
  { name: "OCD", detail: "Obsessions, compulsions, hoarding, body-focused repetitive behaviors" },
  { name: "Bipolar Disorder", detail: "Bipolar I & II, cyclothymia, mood stabilization support" },
  { name: "Personality Disorders", detail: "Borderline, narcissistic, avoidant — with compassion and structure" },
  { name: "Grief & Loss", detail: "Bereavement, complicated grief, anticipatory grief, ambiguous loss" },
  { name: "Relationship Issues", detail: "Communication, boundaries, codependency, attachment patterns" },
  { name: "Substance Use", detail: "Dual diagnosis support, recovery maintenance, harm reduction approach" },
];
---

<section id='what-we-treat' class='relative bg-brand-cream py-24 md:py-36 overflow-hidden' aria-label='What We Treat'>
  <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
    <!-- Header -->
    <div class='flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24'>
      <div data-animate>
        <span class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'>
          05 — Conditions
        </span>
        <h2 class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em]'>
          Whatever you're<br />facing — we treat it.
        </h2>
      </div>
      <div class='max-w-sm' data-animate>
        <p class='text-brand-charcoal/50 text-sm font-light leading-relaxed'>
          Our team has expertise across a wide spectrum of mental health conditions.
          This is a partial list — if you don't see your concern, reach out.
        </p>
      </div>
    </div>

    <!-- Conditions grid -->
    <div class='grid grid-cols-1 md:grid-cols-2 gap-px bg-brand-charcoal/10' data-animate>
      {
        conditions.map((cond, i) => (
          <div class='bg-brand-cream p-6 md:p-8 group hover:bg-brand-white transition-colors duration-400'>
            <div class='flex items-start justify-between gap-4'>
              <div>
                <span class='font-mono text-[10px] tracking-[0.2em] text-brand-muted block mb-2'>
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h3 class='text-lg md:text-xl font-display font-bold text-brand-charcoal group-hover:text-brand-gold transition-colors duration-300'>
                  {cond.name}
                </h3>
                <p class='mt-2 text-sm text-brand-charcoal/40 font-light leading-relaxed'>
                  {cond.detail}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class='mt-12 text-center' data-animate>
      <p class='text-brand-charcoal/40 text-sm font-light mb-4'>
        Don't see your concern listed?
      </p>
      <a
        href='/contact'
        class='group inline-flex items-center gap-2 text-sm font-semibold tracking-[0.1em] uppercase text-brand-charcoal hover:text-brand-gold transition-colors duration-300'
      >
        <span>Get in touch</span>
        <svg
          class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          stroke-width='2'
        >
          <path stroke-linecap='round' stroke-linejoin='round' d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("is-visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("#what-we-treat [data-animate]").forEach((el) => obs.observe(el));
</script>
