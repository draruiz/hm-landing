---
/**
 * What We Treat — immersive image grid with overlay text and parallax hover.
 * 3-column bento grid with varying heights for visual rhythm.
 */
const conditions = [
  {
    title: "Counseling for Anxiety",
    href: "/conditions/anxiety",
    description:
      "Learn to manage worry, panic, and restlessness with proven therapeutic techniques.",
    span: "md:col-span-1 md:row-span-2",
    gradient: "from-brand-blue/70 via-brand-blue/50 to-transparent",
  },
  {
    title: "Life Transitions",
    href: "/conditions/life-transitions",
    description:
      "Navigate change with confidence — career shifts, loss, relocation, and new chapters.",
    span: "md:col-span-1",
    gradient: "from-brand-blue/70 via-brand-blue/40 to-transparent",
  },
  {
    title: "Mindfulness & Wellness Coaching",
    href: "/services/mindfulness",
    description:
      "Build present-moment awareness and sustainable habits for lasting mental wellness.",
    span: "md:col-span-1",
    gradient: "from-brand-blue/70 via-brand-blue/40 to-transparent",
  },
  {
    title: "Obsessive Compulsive Disorder",
    href: "/conditions/ocd",
    description:
      "Evidence-based OCD treatment including ERP and cognitive behavioral therapy.",
    span: "md:col-span-1",
    gradient: "from-brand-blue-dark/70 via-brand-blue/40 to-transparent",
  },
  {
    title: "Social Anxiety Disorder",
    href: "/conditions/social-anxiety",
    description:
      "Overcome social fears and rebuild confidence in professional and personal settings.",
    span: "md:col-span-1",
    gradient: "from-brand-blue-dark/70 via-brand-blue/40 to-transparent",
  },
  {
    title: "Therapy for Self-Esteem",
    href: "/services/self-esteem",
    description:
      "Rediscover your self-worth and develop a compassionate inner dialogue.",
    span: "md:col-span-1 md:row-span-2",
    gradient: "from-brand-blue/70 via-brand-blue/50 to-transparent",
  },
];

/**
 * Free stock image backgrounds from Unsplash (replace with own assets later).
 */
const imageUrls = [
  "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&h=1000&fit=crop&q=80",
  "https://images.unsplash.com/photo-1505118380757-91f5f5632de0?w=800&h=600&fit=crop&q=80",
  "https://images.unsplash.com/photo-1508672019048-805c876b67e2?w=800&h=600&fit=crop&q=80",
  "https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=800&h=600&fit=crop&q=80",
  "https://images.unsplash.com/photo-1448375240586-882707db888b?w=800&h=600&fit=crop&q=80",
  "https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=800&h=1000&fit=crop&q=80",
];
---

<section
  class='relative py-28 md:py-36 bg-brand-cream overflow-hidden'
  aria-labelledby='treat-heading'
>
  <div class='max-w-7xl mx-auto px-6'>
    <!-- Section header -->
    <div class='text-center mb-16 md:mb-20'>
      <span
        class='block w-12 h-[2px] bg-brand-gold mx-auto mb-6'
        aria-hidden='true'></span>
      <h2
        id='treat-heading'
        class='text-4xl md:text-5xl lg:text-6xl font-display italic text-brand-blue mb-4'
      >
        What We Treat
      </h2>
      <p class='text-lg text-brand-blue/60 max-w-xl mx-auto'>
        Specialized treatment for the challenges that matter most to your mental
        health journey.
      </p>
    </div>

    <!-- Bento masonry grid -->
    <div
      class='grid grid-cols-1 md:grid-cols-3 md:grid-rows-[280px_280px] gap-4 md:gap-5 treat-grid'
    >
      {
        conditions.map((condition, i) => (
          <a
            href={condition.href}
            class={`group relative rounded-2xl overflow-hidden ${condition.span} opacity-0 translate-y-6 treat-card min-h-[220px] md:min-h-0`}
            style={`--card-delay: ${i * 100}ms`}
          >
            {/* Background — free stock images from Unsplash */}
            <img
              src={imageUrls[i]}
              alt=''
              class='absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105'
              loading='lazy'
              aria-hidden='true'
            />

            {/* Gradient overlay */}
            <div
              class={`absolute inset-0 bg-gradient-to-t ${condition.gradient} opacity-80 group-hover:opacity-90 transition-opacity duration-500`}
              aria-hidden='true'
            />

            {/* Content */}
            <div class='relative h-full flex flex-col justify-end p-6 md:p-8'>
              <h3 class='text-xl md:text-2xl font-display text-white mb-2 group-hover:text-brand-gold-light transition-colors duration-300'>
                {condition.title}
              </h3>
              <p class='text-white/70 text-sm leading-relaxed max-w-xs md:opacity-0 md:translate-y-3 md:group-hover:opacity-100 md:group-hover:translate-y-0 transition-all duration-500 ease-out'>
                {condition.description}
              </p>

              {/* Arrow indicator */}
              <div class='mt-4 flex items-center gap-2 text-brand-gold-light text-sm font-medium opacity-0 group-hover:opacity-100 translate-x-[-8px] group-hover:translate-x-0 transition-all duration-400'>
                <span>Learn more</span>
                <svg
                  class='w-4 h-4'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='2'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'
                  />
                </svg>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <!-- CTA -->
    <div class='text-center mt-14'>
      <a
        href='/conditions'
        class='inline-flex items-center gap-2 px-8 py-3.5 text-base font-semibold rounded-full border-2 border-brand-blue text-brand-blue hover:bg-brand-blue hover:text-white transition-all duration-300'
      >
        View all conditions we treat
        <svg
          class='w-4 h-4'
          fill='none'
          viewBox='0 0 24 24'
          stroke-width='2'
          stroke='currentColor'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .treat-card {
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--card-delay, 0ms);
  }

  .treat-visible .treat-card {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const grid = document.querySelector(".treat-grid");
  if (grid) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          grid.classList.add("treat-visible");
          observer.disconnect();
        }
      },
      { threshold: 0.1 },
    );
    observer.observe(grid);
  }
</script>
