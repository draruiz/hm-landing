---
/**
 * Services section — circular image cards with hover reveal and parallax feel.
 * Each service links to its dedicated page.
 */
const services = [
  {
    title: "Integrative Care",
    href: "/services/integrative-care",
    color: "from-emerald-400/30 to-teal-600/40",
    image: "https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?w=400&h=400&fit=crop&q=80",
    imageAlt: "Sunlit green leaves representing integrative holistic care",
    description: "A holistic approach considering all aspects of your health — mental, emotional, physical, social, and spiritual.",
  },
  {
    title: "Individual Therapy",
    href: "/services/individual-therapy",
    color: "from-blue-400/30 to-brand-blue/40",
    image: "https://images.unsplash.com/photo-1505118380757-91f5f5632de0?w=400&h=400&fit=crop&q=80",
    imageAlt: "Aerial view of turquoise ocean water representing individual therapy",
    description: "One-on-one sessions focused on personal growth, healing, and resilience with truly customized care.",
  },
  {
    title: "EMDR Therapy",
    href: "/services/emdr",
    color: "from-rose-300/30 to-pink-500/40",
    image: "https://images.unsplash.com/photo-1499209974431-9dddcece7f88?w=400&h=400&fit=crop&q=80",
    imageAlt: "Calm serene landscape representing EMDR therapy for trauma processing",
    description: "A proven integrative approach for processing trauma and overcoming distressing memories.",
  },
  {
    title: "Life Coaching",
    href: "/services/coaching",
    color: "from-amber-300/30 to-brand-gold/40",
    image: "https://images.unsplash.com/photo-1506784983877-45594efa4cbe?w=400&h=400&fit=crop&q=80",
    imageAlt: "Bright sunrise representing life coaching and personal transformation",
    description: "Action-oriented guidance to set meaningful goals, overcome obstacles, and design a fulfilling future.",
  },
  {
    title: "Supervision & Consultation",
    href: "/services/supervision-and-consultation",
    color: "from-violet-300/30 to-purple-500/40",
    image: "https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=400&h=400&fit=crop&q=80",
    imageAlt: "Professional setting representing clinical supervision and consultation services",
    description: "Professional supervision and consultation for individuals seeking licensure as mental health counselors or psychologists.",
  },
  {
    title: "Group Therapy",
    href: "/services/group-therapy",
    color: "from-cyan-300/30 to-teal-500/40",
    image: "https://images.unsplash.com/photo-1473116763249-2faaef81ccda?w=400&h=400&fit=crop&q=80",
    imageAlt: "Sandy beach and gentle waves representing group therapy connection",
    description: "Therapist-guided sessions that help you find connection, support, and growth through shared experiences.",
  },
];
---

<section id="services" class="relative py-28 md:py-36 bg-white overflow-hidden" aria-labelledby="services-heading">
  <!-- Subtle background accent -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-teal/5 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-20">
      <span class="block w-12 h-[2px] bg-brand-gold mx-auto mb-6" aria-hidden="true"></span>
      <h2
        id="services-heading"
        class="text-4xl md:text-5xl lg:text-6xl font-display italic text-brand-blue mb-4"
      >
        Services we provide
      </h2>
      <p class="text-lg text-brand-blue/60 max-w-xl mx-auto">
        Evidence-based psychological care designed to meet you where you are.
      </p>
    </div>

    <!-- Services grid: circular icons with hover expand -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-8 service-grid">
      {services.map((service, i) => (
        <a
          href={service.href}
          class="group flex flex-col items-center text-center opacity-0 translate-y-6 service-item"
          style={`--item-delay: ${i * 120}ms`}
        >
          <!-- Circle container -->
          <div class="relative mb-6">
            {/* Gradient ring on hover */}
            <div class={`absolute inset-0 rounded-full bg-gradient-to-br ${service.color} opacity-0 scale-110 group-hover:opacity-100 group-hover:scale-100 transition-all duration-500 blur-md`} aria-hidden="true"></div>

            <div class="relative w-32 h-32 md:w-36 md:h-36 rounded-full bg-brand-cream border-2 border-brand-blue/10 group-hover:border-brand-gold/40 flex items-center justify-center transition-all duration-500 group-hover:shadow-xl overflow-hidden">
              {/* Circular image */}
              <img
                src={service.image}
                alt={service.imageAlt}
                width="144"
                height="144"
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
            </div>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-display text-brand-blue mb-2 group-hover:text-brand-gold transition-colors duration-300">
            {service.title}
          </h3>

          <!-- Description — reveals on hover on desktop -->
          <p class="text-sm text-brand-blue/60 leading-relaxed max-w-[220px] md:opacity-0 md:max-h-0 md:overflow-hidden md:group-hover:opacity-100 md:group-hover:max-h-24 transition-all duration-500 ease-out">
            {service.description}
          </p>

          <!-- Subtle arrow indicator -->
          <span class="mt-3 inline-flex items-center text-brand-gold text-sm font-medium opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .service-item {
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--item-delay, 0ms);
  }

  .services-visible .service-item {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const grid = document.querySelector('.service-grid');
  if (grid) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          grid.classList.add('services-visible');
          observer.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    observer.observe(grid);
  }
</script>
