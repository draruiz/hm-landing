---
/**
 * Services Section — Creative agency style: numbered list with hover reveals,
 * asymmetric layout, bold typography. No cards — editorial list approach.
 */
const services = [
  {
    number: "01",
    title: "Individual Therapy",
    description: "One-on-one sessions tailored to your unique needs. We use evidence-based approaches including CBT, ACT, and psychodynamic therapy.",
    href: "/services/individual-therapy",
  },
  {
    number: "02",
    title: "EMDR Therapy",
    description: "Eye Movement Desensitization and Reprocessing — a proven treatment for trauma, PTSD, anxiety, and other distressing experiences.",
    href: "/services/emdr",
  },
  {
    number: "03",
    title: "Integrative Care",
    description: "A holistic approach combining traditional therapy with mind-body practices for comprehensive mental wellness.",
    href: "/services/integrative-care",
  },
  {
    number: "04",
    title: "Group Therapy",
    description: "Shared healing in a safe, structured environment. Connect with others who understand your journey.",
    href: "/services/group-therapy",
  },
  {
    number: "05",
    title: "Life Coaching",
    description: "Goal-oriented support to help you navigate transitions, build confidence, and create the life you envision.",
    href: "/services/coaching",
  },
  {
    number: "06",
    title: "Supervision & Consultation",
    description: "Professional guidance for emerging clinicians and organizations seeking expert psychology consultation.",
    href: "/services/supervision-and-consultation",
  },
];
---

<section id='services' class='relative bg-brand-cream py-24 md:py-36' aria-label='Our Services'>
  <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
    <!-- Section header -->
    <div class='flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24'>
      <div data-animate>
        <span class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'>
          02 — Services
        </span>
        <h2 class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em]'>
          What we<br />can do for you.
        </h2>
      </div>
      <div class='max-w-sm' data-animate>
        <p class='text-brand-charcoal/50 text-sm font-light leading-relaxed'>
          Our interdisciplinary team offers a range of therapeutic services designed to support your mental health journey at every stage.
        </p>
      </div>
    </div>

    <!-- Services list — editorial, numbered -->
    <div class='border-t border-brand-charcoal/10'>
      {
        services.map((service) => (
          <a
            href={service.href}
            class='service-row group flex flex-col md:flex-row md:items-center gap-4 md:gap-8 py-8 md:py-10 border-b border-brand-charcoal/10 transition-colors duration-300 hover:bg-brand-charcoal/[0.02] -mx-6 px-6 sm:-mx-10 sm:px-10 md:-mx-16 md:px-16 lg:-mx-20 lg:px-20'
            data-animate
          >
            <!-- Number -->
            <span class='font-mono text-[11px] tracking-[0.2em] text-brand-muted md:w-16 flex-shrink-0'>
              {service.number}
            </span>
            <!-- Title -->
            <h3 class='text-2xl md:text-3xl lg:text-4xl font-display font-bold text-brand-charcoal group-hover:text-brand-gold transition-colors duration-300 md:flex-1'>
              {service.title}
            </h3>
            <!-- Description (hidden on mobile, shows on hover line) -->
            <p class='text-sm text-brand-charcoal/50 font-light leading-relaxed md:max-w-xs md:text-right md:opacity-0 md:translate-x-4 md:group-hover:opacity-100 md:group-hover:translate-x-0 transition-all duration-500'>
              {service.description}
            </p>
            <!-- Arrow -->
            <svg
              class='hidden md:block w-5 h-5 text-brand-charcoal/20 group-hover:text-brand-gold group-hover:translate-x-1 transition-all duration-300 flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.5'
            >
              <path stroke-linecap='round' stroke-linejoin='round' d='M17 8l4 4m0 0l-4 4m4-4H3' />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("is-visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("#services [data-animate]").forEach((el) => obs.observe(el));
</script>
