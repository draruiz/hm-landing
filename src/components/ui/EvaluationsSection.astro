---
/**
 * Evaluations section — highlights the two evaluation services
 * with cards linking to their dedicated pages.
 */
const evaluations = [
  {
    title: "Comprehensive Psychological Evaluations",
    href: "/services/evaluations",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>`,
    description: "In-depth assessments to inform diagnosis, treatment planning, and personal growth. Our comprehensive evaluations cover cognitive, emotional, and behavioral functioning.",
  },
  {
    title: "Online ADHD Evaluations",
    href: "/services/online-adhd-evaluations",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" /></svg>`,
    description: "Convenient, remote ADHD evaluations from the comfort of your home. Get a thorough assessment and clear next steps — all online.",
  },
];
---

<section class="relative py-24 md:py-32 bg-brand-cream/40 overflow-hidden" aria-labelledby="evaluations-heading">
  <!-- Background accent -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-teal/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3" aria-hidden="true"></div>

  <div class="relative max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="block w-12 h-[2px] bg-brand-gold mx-auto mb-6" aria-hidden="true"></span>
      <h2
        id="evaluations-heading"
        class="text-4xl md:text-5xl font-display italic text-brand-blue mb-4"
      >
        Evaluations
      </h2>
      <p class="text-lg text-brand-blue/60 max-w-xl mx-auto">
        Professional psychological evaluations to help you understand yourself better and guide your path forward.
      </p>
    </div>

    <!-- Evaluation cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 evaluation-grid">
      {evaluations.map((evaluation, i) => (
        <a
          href={evaluation.href}
          class="group relative bg-white rounded-2xl p-8 md:p-10 border border-brand-blue/10 hover:border-brand-gold/30 shadow-sm hover:shadow-xl transition-all duration-500 opacity-0 translate-y-6 evaluation-item"
          style={`--item-delay: ${i * 150}ms`}
        >
          <!-- Icon -->
          <div class="text-brand-teal group-hover:text-brand-gold transition-colors duration-300 mb-6" set:html={evaluation.icon} />

          <!-- Title -->
          <h3 class="text-xl md:text-2xl font-display text-brand-blue mb-3 group-hover:text-brand-gold transition-colors duration-300">
            {evaluation.title}
          </h3>

          <!-- Description -->
          <p class="text-brand-blue/60 leading-relaxed mb-6">
            {evaluation.description}
          </p>

          <!-- Arrow link -->
          <span class="inline-flex items-center text-brand-gold text-sm font-medium group-hover:translate-x-1 transition-transform duration-300">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .evaluation-item {
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--item-delay, 0ms);
  }

  .evaluations-visible .evaluation-item {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const grid = document.querySelector('.evaluation-grid');
  if (grid) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          grid.classList.add('evaluations-visible');
          observer.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    observer.observe(grid);
  }
</script>
