---
/**
 * Evaluations Section — Two featured services with large imagery placeholders
 * and strong typography. Split panel layout.
 */
const evaluations = [
  {
    label: "Comprehensive",
    title: "Psychological Evaluations",
    description: "Thorough assessments that provide clarity, diagnostic insight, and a personalized roadmap for treatment. Our licensed psychologists utilize standardized instruments and clinical interviews.",
    href: "/services/evaluations",
    features: ["Full diagnostic battery", "Written report", "Feedback session", "Treatment recommendations"],
  },
  {
    label: "Online",
    title: "ADHD Evaluations",
    description: "Convenient, thorough ADHD evaluations conducted virtually. Get the answers and support you need from the comfort of your own space.",
    href: "/services/online-adhd-evaluations",
    features: ["Telehealth format", "Adult & adolescent", "Quick turnaround", "Insurance-friendly"],
  },
];
---

<section class='relative bg-brand-white py-24 md:py-36' aria-label='Evaluations'>
  <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
    <!-- Header -->
    <div class='mb-16 md:mb-24' data-animate>
      <span class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-muted block mb-4'>
        04 — Evaluations
      </span>
      <h2 class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-charcoal leading-[1.05] tracking-[-0.02em] max-w-2xl'>
        Clarity through expert assessment.
      </h2>
    </div>

    <!-- Two panels -->
    <div class='grid grid-cols-1 md:grid-cols-2 gap-px bg-brand-charcoal/10'>
      {
        evaluations.map((item) => (
          <div class='bg-brand-white p-8 md:p-12 lg:p-16 group' data-animate>
            <span class='font-mono text-[10px] tracking-[0.3em] uppercase text-brand-gold block mb-6'>
              {item.label}
            </span>
            <h3 class='text-2xl md:text-3xl font-display font-bold text-brand-charcoal leading-tight mb-6'>
              {item.title}
            </h3>
            <p class='text-brand-charcoal/50 text-sm font-light leading-relaxed mb-8'>
              {item.description}
            </p>
            <!-- Features list -->
            <ul class='space-y-2 mb-10'>
              {item.features.map((feat) => (
                <li class='flex items-center gap-3 text-sm text-brand-charcoal/60'>
                  <span class='block w-1 h-1 rounded-full bg-brand-gold flex-shrink-0' />
                  {feat}
                </li>
              ))}
            </ul>
            <a
              href={item.href}
              class='group/link inline-flex items-center gap-2 text-sm font-semibold tracking-[0.1em] uppercase text-brand-charcoal hover:text-brand-gold transition-colors duration-300'
            >
              <span>Learn more</span>
              <svg
                class='w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path stroke-linecap='round' stroke-linejoin='round' d='M17 8l4 4m0 0l-4 4m4-4H3' />
              </svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("is-visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("section[aria-label='Evaluations'] [data-animate]").forEach((el) => obs.observe(el));
</script>
