---
/**
 * Specialties Section — Full-width immersive panel with overlapping text.
 * Brutalist-elegant showcase of core specialties.
 */
const specialties = [
  "Anxiety & Depression",
  "Trauma & PTSD",
  "ADHD & Learning Differences",
  "Relationship Challenges",
  "Life Transitions",
  "Grief & Loss",
  "Self-Esteem & Identity",
  "Chronic Stress & Burnout",
];
---

<section class='relative bg-brand-blue py-24 md:py-36 overflow-hidden' aria-label='Our Specialties'>
  <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20'>
    <!-- Header -->
    <div class='flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24'>
      <div data-animate>
        <span class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-gold block mb-4'>
          03 — Specialties
        </span>
        <h2 class='text-3xl sm:text-4xl md:text-5xl font-display font-extrabold text-brand-white leading-[1.05] tracking-[-0.02em]'>
          Areas we<br />specialize in.
        </h2>
      </div>
      <div class='max-w-sm' data-animate>
        <p class='text-brand-white/40 text-sm font-light leading-relaxed'>
          Our clinicians bring deep expertise across a wide range of mental health
          challenges. We tailor every treatment plan to your unique needs.
        </p>
      </div>
    </div>

    <!-- Specialties grid — 2-col on mobile, 4-col on desktop -->
    <div class='grid grid-cols-2 md:grid-cols-4 gap-px bg-brand-white/10' data-animate>
      {
        specialties.map((item, i) => (
          <div class='bg-brand-blue p-6 md:p-8 lg:p-10 group hover:bg-brand-blue-light transition-colors duration-500'>
            <span class='font-mono text-[10px] tracking-[0.2em] text-brand-gold/50 block mb-4'>
              0{i + 1}
            </span>
            <h3 class='text-base md:text-lg font-display font-bold text-brand-white/80 group-hover:text-brand-gold transition-colors duration-300 leading-tight'>
              {item}
            </h3>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Decorative grid lines -->
  <div class='absolute inset-0 pointer-events-none' aria-hidden='true'>
    <div class='absolute left-[50%] top-0 bottom-0 w-px bg-brand-white/[0.03]'></div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("is-visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("section[aria-label='Our Specialties'] [data-animate]").forEach((el) => obs.observe(el));
</script>
