---
/**
 * Agency-grade Navbar — minimal, clean, fullscreen mobile overlay.
 * No top bar. Logo left, links center, CTA right.
 * Transparent on hero, solid on scroll.
 */
const navItems = [
  { label: "About", href: "/about" },
  { label: "Services", href: "/#services" },
  { label: "Our Team", href: "/#team" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const logoUrl =
  "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/3d99200b-f6c7-41b4-5c63-c40b4fbc9000/public";
---

<header
  id='site-header'
  class='fixed top-0 left-0 right-0 z-50 transition-all duration-500'
>
  <nav
    class='nav-inner mx-auto flex items-center justify-between px-6 sm:px-10 md:px-16 lg:px-20 h-20 md:h-24'
    aria-label='Main navigation'
  >
    <!-- Logo -->
    <a
      href='/'
      class='relative z-50 flex-shrink-0'
      aria-label='Healthy Mind Specialists - Home'
    >
      <img
        src={logoUrl}
        alt='Healthy Mind Specialists'
        width='180'
        height='54'
        class='h-10 md:h-12 w-auto nav-logo transition-all duration-300'
        loading='eager'
        fetchpriority='high'
      />
    </a>

    <!-- Desktop links -->
    <div class='hidden lg:flex items-center gap-1'>
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class='nav-link relative px-4 py-2 text-[13px] font-medium tracking-[0.08em] uppercase text-brand-white/70 hover:text-brand-white transition-colors duration-300'
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- CTA + Menu button -->
    <div class='flex items-center gap-6'>
      <a
        href='/get-started/appointment-request'
        class='nav-cta hidden lg:inline-flex items-center gap-2 px-6 py-3 text-[12px] font-semibold tracking-[0.15em] uppercase border border-brand-gold/50 text-brand-gold hover:bg-brand-gold hover:text-brand-blue transition-all duration-400'
      >
        Book Now
      </a>

      <!-- Mobile hamburger -->
      <button
        id='mobile-menu-btn'
        type='button'
        class='relative z-50 lg:hidden flex flex-col items-end gap-1.5 p-2'
        aria-expanded='false'
        aria-controls='mobile-menu'
        aria-label='Toggle menu'
      >
        <span
          class='hamburger-line block w-7 h-[1.5px] bg-brand-white transition-all duration-300 origin-center'
        ></span>
        <span
          class='hamburger-line block w-5 h-[1.5px] bg-brand-white transition-all duration-300 origin-center'
        ></span>
        <span
          class='hamburger-line block w-7 h-[1.5px] bg-brand-white transition-all duration-300 origin-center'
        ></span>
      </button>
    </div>
  </nav>
</header>

<!-- Fullscreen mobile menu -->
<div
  id='mobile-menu'
  class='fixed inset-0 z-40 bg-brand-blue flex flex-col justify-center items-center opacity-0 pointer-events-none transition-opacity duration-500'
  role='navigation'
  aria-label='Mobile navigation'
  aria-hidden='true'
>
  <div class='flex flex-col items-center gap-2'>
    {
      navItems.map((item, i) => (
        <a
          href={item.href}
          class='mobile-nav-link block text-3xl sm:text-4xl font-display font-bold text-brand-white/80 hover:text-brand-gold tracking-tight transition-all duration-300 py-2'
          style={`transition-delay: ${i * 60}ms`}
        >
          {item.label}
        </a>
      ))
    }
    <div class='w-12 h-px bg-brand-gold/30 my-6'></div>
    <a
      href='/get-started/appointment-request'
      class='inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold tracking-[0.15em] uppercase bg-brand-gold text-brand-blue transition-all duration-500 hover:bg-brand-gold-light mt-2'
    >
      Book a Consultation
    </a>
  </div>

  <!-- Contact in mobile -->
  <div class='absolute bottom-10 flex flex-col items-center gap-2'>
    <a
      href='tel:8136092034'
      class='font-mono text-sm text-brand-white/40 hover:text-brand-gold transition-colors'
    >
      813-609-2034
    </a>
    <a
      href='mailto:info@healthymindspecialists.com'
      class='font-mono text-xs text-brand-white/30 hover:text-brand-gold transition-colors'
    >
      info@healthymindspecialists.com
    </a>
  </div>
</div>

<script>
  const header = document.getElementById("site-header");
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerLines = document.querySelectorAll(".hamburger-line");
  let isMenuOpen = false;

  // Scroll behavior — add background on scroll
  function updateHeader() {
    if (!header) return;
    if (window.scrollY > 60) {
      header.classList.add("nav-scrolled");
    } else {
      header.classList.remove("nav-scrolled");
    }
  }

  window.addEventListener("scroll", updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", () => {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        mobileMenu.classList.remove("opacity-0", "pointer-events-none");
        mobileMenu.classList.add("opacity-100", "pointer-events-auto");
        mobileMenu.setAttribute("aria-hidden", "false");
        menuBtn.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
        // X shape
        hamburgerLines[0]?.classList.add("translate-y-[4.5px]", "rotate-45");
        hamburgerLines[1]?.classList.add("opacity-0", "scale-x-0");
        hamburgerLines[2]?.classList.add("-translate-y-[4.5px]", "-rotate-45");
      } else {
        mobileMenu.classList.add("opacity-0", "pointer-events-none");
        mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
        mobileMenu.setAttribute("aria-hidden", "true");
        menuBtn.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        hamburgerLines[0]?.classList.remove("translate-y-[4.5px]", "rotate-45");
        hamburgerLines[1]?.classList.remove("opacity-0", "scale-x-0");
        hamburgerLines[2]?.classList.remove(
          "-translate-y-[4.5px]",
          "-rotate-45",
        );
      }
    });

    // Close on link click
    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        isMenuOpen = false;
        mobileMenu.classList.add("opacity-0", "pointer-events-none");
        mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
        mobileMenu.setAttribute("aria-hidden", "true");
        menuBtn.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        hamburgerLines[0]?.classList.remove("translate-y-[4.5px]", "rotate-45");
        hamburgerLines[1]?.classList.remove("opacity-0", "scale-x-0");
        hamburgerLines[2]?.classList.remove(
          "-translate-y-[4.5px]",
          "-rotate-45",
        );
      });
    });
  }
</script>

<style>
  /* Transparent by default, solid white on scroll */
  #site-header {
    background: transparent;
  }

  /* Logo inverted to white over dark hero */
  .nav-logo {
    filter: brightness(0) invert(1);
  }

  #site-header.nav-scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
  }

  #site-header.nav-scrolled .nav-inner {
    height: 4rem;
  }

  /* Scrolled: show original dark logo */
  #site-header.nav-scrolled .nav-logo {
    height: 2rem;
    filter: none;
  }

  /* Link underline effect */
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Scrolled state — dark text links */
  #site-header.nav-scrolled .nav-link {
    color: rgba(15, 23, 42, 0.65);
  }

  #site-header.nav-scrolled .nav-link:hover {
    color: rgba(15, 23, 42, 1);
  }

  /* Scrolled state — dark CTA border */
  #site-header.nav-scrolled .nav-cta {
    border-color: rgba(15, 23, 42, 0.2);
    color: rgba(15, 23, 42, 0.8);
  }

  #site-header.nav-scrolled .nav-cta:hover {
    background: var(--color-brand-gold, #c8a24e);
    border-color: var(--color-brand-gold, #c8a24e);
    color: #fff;
  }

  /* Scrolled state — dark hamburger lines */
  #site-header.nav-scrolled .hamburger-line {
    background: rgba(15, 23, 42, 0.8);
  }
</style>
