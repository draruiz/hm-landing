---
/**
 * Footer — three-column layout with logo, office hours, contact info,
 * social icons, and a branded bottom bar.
 */
const logoUrl =
  "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/3d99200b-f6c7-41b4-5c63-c40b4fbc9000/public";

const socialLinks = [
  {
    label: "Email us",
    href: "mailto:info@healthymindspecialists.com",
    icon: "email",
  },
  { label: "Call us", href: "tel:8136092034", icon: "phone" },
  {
    label: "Follow us on Instagram",
    href: "https://www.instagram.com/healthymindspecialists",
    icon: "instagram",
  },
];

const locations = [
  { street: "11906 Boyette Road", city: "Riverview, FL 33569" },
  { city: "Venice, FL" },
];
---

<footer class='bg-white border-t border-gray-100' aria-label='Site footer'>
  <!-- Main footer content -->
  <div class='max-w-7xl mx-auto px-6 py-16 md:py-20'>
    <div
      class='grid grid-cols-1 md:grid-cols-3 gap-14 md:gap-8 lg:gap-16 items-start'
    >
      <!-- Column 1: Logo & Social -->
      <div class='flex flex-col items-center md:items-start'>
        <a href='/' aria-label='Healthy Mind Specialists - Home'>
          <img
            src={logoUrl}
            alt='Healthy Mind Specialists - Integrative Psychological Services'
            width='220'
            height='66'
            class='h-auto w-52 md:w-56'
            loading='lazy'
          />
        </a>

        <p
          class='mt-3 text-sm tracking-[0.15em] uppercase text-brand-blue/50 font-sans font-medium text-center md:text-left'
        >
          Integrative Psychological Services
        </p>

        <!-- Social Icons -->
        <div class='flex items-center gap-3 mt-8'>
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target={link.icon === "instagram" ? "_blank" : undefined}
                rel={
                  link.icon === "instagram" ? "noopener noreferrer" : undefined
                }
                aria-label={link.label}
                class='group flex items-center justify-center w-11 h-11 bg-brand-blue text-white rounded-sm transition-all duration-300 hover:bg-brand-gold hover:shadow-lg hover:shadow-brand-gold/20 hover:-translate-y-0.5'
              >
                {link.icon === "email" && (
                  <svg
                    class='w-[18px] h-[18px]'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke='currentColor'
                    stroke-width='1.8'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d='M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75'
                    />
                  </svg>
                )}
                {link.icon === "phone" && (
                  <svg
                    class='w-[18px] h-[18px]'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke='currentColor'
                    stroke-width='1.8'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z'
                    />
                  </svg>
                )}
                {link.icon === "instagram" && (
                  <svg
                    class='w-[18px] h-[18px]'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke='currentColor'
                    stroke-width='1.8'
                  >
                    <rect x='2' y='2' width='20' height='20' rx='5' ry='5' />
                    <path d='M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z' />
                    <line x1='17.5' y1='6.5' x2='17.51' y2='6.5' />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Column 2: Office Hours -->
      <div class='text-center'>
        <h3
          class='font-display text-2xl md:text-[1.65rem] text-brand-blue mb-5'
        >
          Office Hours
        </h3>
        <div
          class='w-8 h-[1.5px] bg-brand-gold mx-auto mb-5'
          aria-hidden='true'
        >
        </div>
        <p class='text-brand-blue/70 text-base leading-relaxed font-sans'>
          Monday – Friday
        </p>
        <p class='text-brand-blue/70 text-base font-sans'>8AM – 9PM</p>
      </div>

      <!-- Column 3: Contact Information -->
      <div class='text-center md:text-right'>
        <h3
          class='font-display text-2xl md:text-[1.65rem] text-brand-blue mb-5'
        >
          Contact Information
        </h3>
        <div
          class='w-8 h-[1.5px] bg-brand-gold mx-auto md:ml-auto md:mr-0 mb-5'
          aria-hidden='true'
        >
        </div>

        <address class='not-italic space-y-3 text-brand-blue/70 font-sans'>
          <!-- Phone -->
          <p class='flex items-center justify-center md:justify-end gap-2'>
            <svg
              class='w-4 h-4 text-brand-gold flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.8'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z'
              ></path>
            </svg>
            <a
              href='tel:8136092034'
              class='hover:text-brand-gold transition-colors duration-300'
              >813-609-2034</a
            >
          </p>

          <!-- Email -->
          <p class='flex items-center justify-center md:justify-end gap-2'>
            <svg
              class='w-4 h-4 text-brand-gold flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.8'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75'
              ></path>
            </svg>
            <a
              href='mailto:info@healthymindspecialists.com'
              class='hover:text-brand-gold transition-colors duration-300'
              >info@healthymindspecialists.com</a
            >
          </p>

          <!-- Locations -->
          {
            locations.map((loc) => (
              <div class='flex items-start justify-center md:justify-end gap-2'>
                <svg
                  class='w-4 h-4 text-brand-gold flex-shrink-0 mt-0.5'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='1.8'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M15 10.5a3 3 0 11-6 0 3 3 0 016 0z'
                  />
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z'
                  />
                </svg>
                <span>
                  {loc.street && (
                    <>
                      {loc.street}
                      <br />
                    </>
                  )}
                  {loc.city}
                </span>
              </div>
            ))
          }
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class='bg-brand-blue-dark'>
    <div
      class='max-w-7xl mx-auto px-6 py-4 flex items-center justify-center md:justify-end'
    >
      <p class='text-white/50 text-sm font-sans tracking-wide'>
        Designed &amp; Developed by
        <a
          href='https://github.com/neurophxze'
          target='_blank'
          rel='noopener noreferrer'
          class='text-brand-gold/70 hover:text-brand-gold transition-colors duration-300 font-medium'
        >
          neurophxze
        </a>
        <span class='text-white/30'>(Camilo Hernandez)</span>
      </p>
    </div>
  </div>
</footer>
