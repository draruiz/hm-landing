---
/**
 * Agency-grade Footer — Large typographic CTA + editorial grid + minimal credits.
 */
const logoUrl =
  "https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/3d99200b-f6c7-41b4-5c63-c40b4fbc9000/public";

const footerLinks = [
  {
    heading: "Services",
    links: [
      { label: "Individual Therapy", href: "/services/individual-therapy" },
      { label: "EMDR Therapy", href: "/services/emdr" },
      { label: "Evaluations", href: "/services/evaluations" },
      { label: "Group Therapy", href: "/services/group-therapy" },
      { label: "Life Coaching", href: "/services/coaching" },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "About Us", href: "/about" },
      { label: "Our Team", href: "/#team" },
      { label: "Blog", href: "/blog" },
      { label: "FAQs", href: "/get-started/faqs" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    heading: "Resources",
    links: [
      { label: "Mental Health Links", href: "/resources/mental-health-links" },
      {
        label: "Physical Health Links",
        href: "/resources/physical-health-links",
      },
      { label: "Rates & Insurance", href: "/get-started/rates-insurance" },
      { label: "HIPAA Consent", href: "/legal/hipaa-consent" },
    ],
  },
];
---

<footer class='bg-brand-blue text-brand-white' aria-label='Site footer'>
  <!-- Large CTA Section -->
  <div class='border-b border-brand-white/10'>
    <div
      class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20 py-20 md:py-28'
    >
      <div class='grid grid-cols-1 lg:grid-cols-2 gap-10 items-end'>
        <div>
          <span
            class='font-mono text-[11px] tracking-[0.3em] uppercase text-brand-gold block mb-4'
          >
            Ready to begin?
          </span>
          <h2
            class='text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display font-extrabold leading-[0.95] tracking-[-0.03em]'
          >
            Let's start<br />your journey.
          </h2>
        </div>
        <div class='lg:text-right'>
          <a
            href='/get-started/appointment-request'
            class='group inline-flex items-center gap-3 px-8 py-4 text-sm font-semibold tracking-[0.15em] uppercase bg-brand-gold text-brand-blue transition-all duration-500 hover:bg-brand-gold-light'
          >
            <span>Book an Appointment</span>
            <svg
              class='w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
            </svg>
          </a>
          <p class='mt-4 text-brand-white/40 text-sm font-light'>
            or call us at
            <a
              href='tel:8136092034'
              class='text-brand-gold/70 hover:text-brand-gold transition-colors'
            >
              813-609-2034
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Links grid -->
  <div class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20 py-16 md:py-20'>
    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8'>
      <!-- Brand column -->
      <div class='lg:col-span-2'>
        <a href='/' aria-label='Healthy Mind Specialists - Home'>
          <img
            src={logoUrl}
            alt='Healthy Mind Specialists'
            width='180'
            height='54'
            class='h-10 w-auto mb-5'
            loading='lazy'
          />
        </a>
        <p
          class='text-brand-white/40 text-sm font-light leading-relaxed max-w-xs mb-6'
        >
          Integrative psychological services providing compassionate,
          evidence-based mental health care in Tampa, FL.
        </p>
        <!-- Social icons -->
        <div class='flex items-center gap-3'>
          <a
            href='mailto:info@healthymindspecialists.com'
            aria-label='Email us'
            class='flex items-center justify-center w-10 h-10 border border-brand-white/15 text-brand-white/50 hover:text-brand-gold hover:border-brand-gold/40 transition-all duration-300'
          >
            <svg
              class='w-4 h-4'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.5'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75'
              ></path>
            </svg>
          </a>
          <a
            href='tel:8136092034'
            aria-label='Call us'
            class='flex items-center justify-center w-10 h-10 border border-brand-white/15 text-brand-white/50 hover:text-brand-gold hover:border-brand-gold/40 transition-all duration-300'
          >
            <svg
              class='w-4 h-4'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.5'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z'
              ></path>
            </svg>
          </a>
          <a
            href='https://www.instagram.com/healthymindspecialists'
            target='_blank'
            rel='noopener noreferrer'
            aria-label='Follow on Instagram'
            class='flex items-center justify-center w-10 h-10 border border-brand-white/15 text-brand-white/50 hover:text-brand-gold hover:border-brand-gold/40 transition-all duration-300'
          >
            <svg
              class='w-4 h-4'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='1.5'
            >
              <rect x='2' y='2' width='20' height='20' rx='5' ry='5'></rect>
              <path d='M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z'></path>
              <line x1='17.5' y1='6.5' x2='17.51' y2='6.5'></line>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {
        footerLinks.map((col) => (
          <div>
            <h3 class='font-mono text-[11px] tracking-[0.2em] uppercase text-brand-gold mb-5'>
              {col.heading}
            </h3>
            <ul class='space-y-3'>
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class='text-sm text-brand-white/50 hover:text-brand-white transition-colors duration-300'
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Bottom bar -->
  <div class='border-t border-brand-white/[0.06]'>
    <div
      class='max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-20 py-5 flex flex-col sm:flex-row items-center justify-between gap-3'
    >
      <p class='text-brand-white/25 text-xs font-mono tracking-wide'>
        &copy; {new Date().getFullYear()} Healthy Mind Specialists. All rights reserved.
      </p>
      <address
        class='not-italic text-brand-white/25 text-xs font-mono tracking-wide'
      >
        11906 Boyette Rd, Riverview FL 33569
      </address>
      <p class='text-brand-white/25 text-xs font-mono tracking-wide'>
        Built by
        <a
          href='https://github.com/neurophxze'
          target='_blank'
          rel='noopener noreferrer'
          class='text-brand-gold/50 hover:text-brand-gold transition-colors duration-300'
        >
          neurophxze
        </a>
      </p>
    </div>
  </div>
</footer>
